---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout, { type JsonLdGraph } from "../../layouts/BaseLayout.astro";
import { breadcrumbSchema, ROSE_PERSON_SCHEMA } from "../../lib/seo.ts";

const siteUrl = Astro.site!.toString().replace(/\/$/, "");

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

// Static TOC from h2/h3 (the loader strips stray "Table of Contents",
// but guard defensively).
const tocHeadings = headings.filter(
  (h) =>
    (h.depth === 2 || h.depth === 3) &&
    !/^table of contents$/i.test(h.text.trim()),
);

const sortedPosts = [...allPosts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const currentIdx = sortedPosts.findIndex((p) => p.id === post.id);
const nextPost = currentIdx > 0 ? sortedPosts[currentIdx - 1] : null;
const prevPost =
  currentIdx >= 0 && currentIdx < sortedPosts.length - 1
    ? sortedPosts[currentIdx + 1]
    : null;

function fmtDate(d: Date): string {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
function fmtISO(d: Date): string {
  return d.toISOString();
}
function readingMin(p: CollectionEntry<"blog">): number {
  if (p.data.readingTime) return p.data.readingTime;
  const body = p.body ?? "";
  const words = body.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const tags = post.data.tags.length > 0 ? post.data.tags : [post.data.category];

const jsonLd: JsonLdGraph[] = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: fmtISO(post.data.pubDate),
    ...(post.data.updatedDate ? { dateModified: fmtISO(post.data.updatedDate) } : {}),
    author: { "@id": ROSE_PERSON_SCHEMA["@id"] },
    publisher: { "@id": `${siteUrl}/#organization` },
    ...(post.data.heroImage ? { image: post.data.heroImage } : {}),
    mainEntityOfPage: `${siteUrl}/blog/${post.id}/`,
  },
  ROSE_PERSON_SCHEMA,
  breadcrumbSchema([
    { name: "Home", url: `${siteUrl}/` },
    { name: "Blog", url: `${siteUrl}/blog/` },
    { name: post.data.title },
  ]),
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="post-shell">
    {/* Left rail — sticky product CTA with the value prop. */}
    <aside class="post-cta">
      <div class="cta-card">
        <p class="cta-k">letmepost</p>
        <p class="cta-h">Post to every network with one API call.</p>
        <p class="cta-p">
          The open-source social publishing API. One <span class="mono">POST</span> fans
          out to eight platforms, with preflight validation, idempotency, and structured
          errors built in.
        </p>
        <a
          class="btn pri cta-btn"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props='{"location":"blog-rail","target":"dashboard","page":"blog-post","label":"Start for free"}'
        >Start for free →</a>
        <a class="cta-docs" href="https://docs.letmepost.dev">Read the docs ↗</a>
      </div>
    </aside>

    {/* Center — article. */}
    <article class="post-main">
      <p class="crumb"><a href="/blog">Blog</a> / {tags[0]}</p>
      <div class="art-tags">
        {tags.map((t) => <span class="a-tag">{t}</span>)}
      </div>
      <h1 class="art-h1">{post.data.title}</h1>
      <p class="art-lede">{post.data.description}</p>
      <div class="art-meta">
        <span class="who">{post.data.author}</span><span>·</span>
        <span>{fmtDate(post.data.pubDate)}</span><span>·</span>
        <span>{readingMin(post)} min read</span>
      </div>

      {post.data.heroImage && (
        <figure class="art-cover">
          <img src={post.data.heroImage} alt={post.data.title} loading="eager" fetchpriority="high" />
        </figure>
      )}

      <div class="prose">
        <Content />
      </div>

      <div class="art-cta">
        <h3>Publish everywhere from one POST.</h3>
        <p>Free during alpha. Connect an account and send your first post in ninety seconds.</p>
        <a class="btn pri" href="https://dashboard.letmepost.dev">Start for free →</a>
      </div>

      {(prevPost || nextPost) && (
        <nav class="art-nav">
          {prevPost ? (
            <a href={`/blog/${prevPost.id}`} class="art-nav-card">
              <span class="lbl">← Previous</span>
              <span class="ttl">{prevPost.data.title}</span>
            </a>
          ) : <span />}
          {nextPost ? (
            <a href={`/blog/${nextPost.id}`} class="art-nav-card right">
              <span class="lbl">Next →</span>
              <span class="ttl">{nextPost.data.title}</span>
            </a>
          ) : <span />}
        </nav>
      )}

      <nav class="art-foot">
        <a class="trust" href="/blog">← All writing</a>
      </nav>
    </article>

    {/* Right rail — static table of contents. */}
    {tocHeadings.length > 0 && (
      <aside class="post-toc">
        <div class="toc-inner">
          <p class="toc-h">On this page</p>
          <ul>
            {tocHeadings.map((h) => (
              <li class={`toc-d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style is:global>
  /* ── /blog/[slug] — 3-column reading layout ─────────────── */
  .post-shell {
    display: grid;
    grid-template-columns: 240px minmax(0, 680px) 220px;
    gap: 48px;
    justify-content: center;
    padding: 56px 32px 0;
  }

  /* Left rail CTA */
  .post-cta .cta-card {
    position: sticky; top: 96px;
    border: 1px solid var(--line); border-radius: 16px;
    padding: 24px 22px; background: var(--panel);
  }
  .cta-card .cta-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--acc); margin: 0 0 10px; }
  .cta-card .cta-h { font-family: var(--disp); font-weight: 600; font-size: 19px; line-height: 1.22; letter-spacing: -0.01em; color: var(--ink); margin: 0 0 10px; }
  .cta-card .cta-p { font-size: 13.5px; color: var(--mut); line-height: 1.55; margin: 0 0 18px; }
  .cta-card .cta-btn { display: flex; justify-content: center; width: 100%; }
  .cta-card .cta-docs { display: inline-block; margin-top: 12px; font-family: var(--mono); font-size: 12px; color: var(--mut); text-decoration: none; }
  .cta-card .cta-docs:hover { color: var(--acc); }

  /* Center article */
  .post-main { min-width: 0; }
  .post-main .art-tags { display: flex; gap: 8px; margin-bottom: 20px; }
  .post-main .a-tag { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--acc); background: var(--acc-soft); padding: 3px 9px; border-radius: 999px; }
  .post-main .art-h1 { font-family: var(--disp); font-weight: 600; font-size: 42px; line-height: 1.08; letter-spacing: -0.025em; margin: 0 0 18px; text-wrap: balance; }
  .post-main .art-lede { font-size: 20px; line-height: 1.5; color: var(--mut); margin: 0 0 4px; max-width: 60ch; }
  .post-main .art-meta { display: flex; align-items: center; gap: 14px; font-family: var(--mono); font-size: 12.5px; color: var(--faint); padding: 18px 0 28px; border-bottom: 1px solid var(--line); margin-top: 14px; }
  .post-main .art-meta .who { color: var(--ink); }
  .post-main .art-cover { margin: 36px 0; }
  .post-main .art-cover img { width: 100%; height: auto; display: block; border-radius: 14px; border: 1px solid var(--line); }

  .post-main .prose { max-width: none; font-size: 18px; }
  .post-main .prose blockquote { font-family: var(--disp); font-weight: 500; font-size: 22px; line-height: 1.35; letter-spacing: -0.01em; color: var(--ink); font-style: normal; }

  .post-main .art-cta { margin-top: 48px; padding: 32px 34px; border: 1px solid var(--line); border-radius: 16px; background: var(--acc-soft); }
  .post-main .art-cta h3 { font-family: var(--disp); font-weight: 600; font-size: 22px; margin: 0 0 8px; }
  .post-main .art-cta p { margin: 0 0 18px; color: var(--mut); font-size: 16px; }

  .post-main .art-nav { margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .post-main .art-nav-card { display: flex; flex-direction: column; gap: 6px; padding: 18px 20px; border: 1px solid var(--line); border-radius: 14px; text-decoration: none; color: inherit; transition: border-color 140ms; }
  .post-main .art-nav-card:hover { border-color: var(--acc); }
  .post-main .art-nav-card.right { text-align: right; }
  .post-main .art-nav-card .lbl { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); }
  .post-main .art-nav-card .ttl { font-family: var(--disp); font-weight: 600; font-size: 16px; line-height: 1.25; color: var(--ink); }

  .post-main .art-foot { margin: 48px 0 0; padding-top: 28px; border-top: 1px solid var(--line); }

  /* Right rail TOC */
  .post-toc .toc-inner { position: sticky; top: 96px; }
  .post-toc .toc-h { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--faint); margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid var(--line); }
  .post-toc ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
  .post-toc a { display: block; font-size: 13px; line-height: 1.4; color: var(--mut); text-decoration: none; border-left: 2px solid transparent; padding-left: 12px; margin-left: -12px; transition: color 120ms, border-color 120ms; }
  .post-toc a:hover { color: var(--acc); border-left-color: var(--acc); }
  .post-toc li.toc-d3 a { padding-left: 26px; font-size: 12.5px; }

  @media (max-width: 1180px) {
    .post-shell { grid-template-columns: minmax(0, 720px); }
    .post-cta, .post-toc { display: none; }
  }
  @media (max-width: 760px) {
    .post-shell { padding: 32px 20px 0; }
    .post-main .art-h1 { font-size: 32px; }
    .post-main .prose { font-size: 17px; }
    .post-main .art-nav { grid-template-columns: 1fr; }
    .post-main .art-nav-card.right { text-align: left; }
  }
</style>
