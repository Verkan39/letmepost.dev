---
/**
 * Clarity footer — brand column + Product / Integration / Company /
 * Community link columns. Replaces the receipt closeout footer across
 * every BaseLayout page.
 *
 * Links mirror the repo's source-of-truth set (richer than the design
 * prototype): real /privacy /terms /about /contact /status, the full
 * platform list, RSS, and Contribute. The Integration column is driven
 * by PLATFORMS with live/in-review badges from each platform's status.
 */
import { PLATFORMS } from "../data/platforms.ts";
import ClarityBrand from "./ClarityBrand.astro";

// platforms.ts currently lists TikTok twice (8 unique slugs across 9
// entries) — dedupe by slug, keeping the first occurrence.
const seen = new Set<string>();
const platforms = PLATFORMS.filter((p) => {
  if (seen.has(p.slug)) return false;
  seen.add(p.slug);
  return true;
});

const GITHUB = "https://github.com/letmepost/letmepost.dev";
const year = new Date().getFullYear();
---

<footer class="cl-foot">
  <div class="inner">
    <div class="cols">
      <div class="brandcol">
        <ClarityBrand size={22} />
        <p>Open-source social publishing API. One POST, eight platforms. Apache-2.0.</p>
        <a class="gh" href={GITHUB} target="_blank" rel="noopener">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0a8 8 0 00-2.53 15.59c.4.07.55-.17.55-.38v-1.36c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.16-.89-1.16-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.22 1.87.87 2.33.67.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.96 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.21 2.2.82a7.65 7.65 0 014.01 0c1.53-1.03 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.52.56.83 1.28.83 2.15 0 3.08-1.87 3.76-3.65 3.96.29.25.54.74.54 1.49v2.21c0 .22.15.46.55.38A8 8 0 008 0z"></path></svg>
          Star on GitHub
        </a>
      </div>

      <div>
        <h4>Product</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/api/publishing">Publishing API</a></li>
          <li><a href="/api/media">Media API</a></li>
          <li><a href="/api/webhooks">Webhooks</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="https://docs.letmepost.dev/changelog">Changelog</a></li>
        </ul>
      </div>

      <div>
        <h4>Integration</h4>
        <ul>
          {
            platforms.map((p) => (
              <li><a href={`/platforms/${p.slug}`}>{p.name}</a></li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/agents">For agents <span class="b mcp">MCP</span></a></li>
          <li><a href="/status">Status</a></li>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4>Community</h4>
        <ul>
          <li><a href={GITHUB} target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://bsky.app/profile/letmepost.dev" target="_blank" rel="noopener">Bluesky</a></li>
          <li><a href="https://x.com/letmepostdotdev" target="_blank" rel="noopener">X</a></li>
          <li><a href="/rss.xml">RSS feed</a></li>
          <li><a href={`${GITHUB}/blob/main/CONTRIBUTING.md`} target="_blank" rel="noopener">Contribute</a></li>
        </ul>
      </div>
    </div>

    <div class="legal">
      <span>letmepost.dev · © {year} · Apache-2.0 · built by Rose Kamal Love</span>
      <span><a href="/privacy">Privacy</a><a href="/terms">Terms</a></span>
    </div>
  </div>
</footer>
