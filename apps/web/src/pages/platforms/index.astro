---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlatformIcon from "../../components/PlatformIcon.astro";
import { PLATFORMS } from "../../data/platforms.ts";
import { highlight } from "../../lib/highlight.ts";

/**
 * Platforms index — Clarity direction. One grid of platform cards, each
 * carrying its status pill, then the "shape never changes" code sample
 * and a "more coming" note. Status reads from PLATFORMS (canonical
 * PLATFORM_STATE): seven live today, TikTok in App Review.
 */

const STATUS_LABEL: Record<string, string> = {
  live: "Live",
  pending: "In review",
  trial: "Trial",
  planned: "Planned",
};
const STATUS_PILL: Record<string, string> = {
  live: "live",
  pending: "in-review",
  trial: "trial",
  planned: "planned",
};
const order: Record<string, number> = { live: 0, trial: 0, pending: 1, planned: 2 };

// Dedupe by slug (platforms.ts lists TikTok twice), then sort live first.
const seen = new Set<string>();
const platforms = PLATFORMS.filter((p) => {
  if (seen.has(p.slug)) return false;
  seen.add(p.slug);
  return true;
}).sort((a, b) => (order[a.status] ?? 3) - (order[b.status] ?? 3));

const total = platforms.length;
const liveCount = platforms.filter((p) => p.status === "live").length;

const curlSample = `curl -X POST https://api.letmepost.dev/v1/posts \\
  -H "Authorization: Bearer $LMP_KEY" \\
  -d '{
    "targets": [
      { "platform": "bluesky" },
      { "platform": "linkedin" },
      { "platform": "instagram" },
      { "platform": "pinterest" }
    ],
    "text": "Shipped multi-target publishing today.",
    "media": [{ "mediaId": "med_01HXY…" }]
  }'`;
---

<BaseLayout
  title="Supported social media platforms"
  description={`${total} platforms behind one POST. Bluesky, X, and Pinterest are live end-to-end today; the rest are in review.`}
>
  <header class="wrap page-head">
    <p class="crumb"><a href="/">letmepost</a> / platforms</p>
    <p class="eyebrow">Platforms</p>
    <h1 class="cl-h1" style="max-width: 15ch;">Eight platforms. <span class="acc">One</span> endpoint.</h1>
    <p class="sub" style="max-width: 58ch;">
      The same <span class="mono">POST /v1/posts</span> body publishes everywhere.
      {liveCount} platforms are live end-to-end today; the rest flip on the day their
      review clears, with no code change on your side.
    </p>
  </header>

  <section class="wrap sec tight" style="padding-top: 36px;">
    <div class="plat-grid">
      {
        platforms.map((p) => (
          <a class="plat-card" href={`/platforms/${p.slug}`}>
            <span class="pg"><PlatformIcon platform={p.slug} size={22} /></span>
            <span>
              <span class="pn">{p.name}</span>
              <span class="pt">{p.tagline}</span>
            </span>
            <span class={`pill ${STATUS_PILL[p.status] ?? "planned"}`}>
              {STATUS_LABEL[p.status] ?? "Planned"}
            </span>
          </a>
        ))
      }
    </div>

    <div class="callout" style="margin-top: 28px;">
      <span class="callout-tag">No artificial gates</span>
      <p>
        <b>Live</b> means published end-to-end today. <b>In review</b> means the
        publisher is shipped and tested against developer-tier accounts; approval
        flips it live with no code change on your side. Self-hosters can BYO platform
        credentials and skip our shared review entirely.
      </p>
    </div>
  </section>

  <section class="wrap sec divider">
    <p class="kicker">The shape never changes</p>
    <h2 class="cl-h2">Add a target, not an integration.</h2>
    <p class="lead">
      Every platform is one entry in the <code class="inl">targets</code> array.
      Per-platform overrides are optional; the base post just works.
    </p>
    <div class="code">
      <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="file">publish.sh</span></div>
      <pre set:html={highlight("bash", curlSample)} />
    </div>
  </section>

  <section class="wrap sec" style="padding-top: 0;">
    <div class="callout">
      <span class="callout-tag">More coming</span>
      <p>
        The roadmap is long. Mastodon, Reddit, YouTube, Telegram, Snapchat, Google
        Business, and the Meta + LinkedIn + TikTok ad APIs are all under consideration.
        <a href="https://github.com/letmepost/letmepost.dev/issues/new">Open an issue with the platform you need next →</a>
      </p>
    </div>
  </section>

  <section class="wrap">
    <div class="final">
      <h2>Connect your first account in 90 seconds.</h2>
      <p>Free during alpha. No credit card. One OAuth flow per platform and your posts go live.</p>
      <div class="ctas">
        <a class="btn pri lg" href="https://dashboard.letmepost.dev">Start free →</a>
        <a class="btn ghost lg" href="/api/publishing">See the Publishing API</a>
      </div>
    </div>
  </section>
</BaseLayout>
