NEXT_PUBLIC_API_URL=http://localhost:3000

# Override the launch-state of platforms in the dashboard UI without a
# code change. Mirrors the API's `PLATFORM_STATE_OVERRIDES` env — set
# BOTH so the dashboard tile and the backend gate agree.
#
# Use case: temporarily un-grey Meta tiles while recording App Review
# demo videos, then revert. Format: comma-separated `platform:state`
# pairs. Valid states: live, trial, pending.
#
#   NEXT_PUBLIC_PLATFORM_STATE_OVERRIDES=facebook:live,instagram:live,threads:live
NEXT_PUBLIC_PLATFORM_STATE_OVERRIDES=

# PostHog product analytics. Leave blank to disable — the provider is a
# no-op when NEXT_PUBLIC_POSTHOG_KEY is unset, so local dev stays quiet
# unless you explicitly want to send events.
#
# Region hosts:
#   US:  https://us.i.posthog.com   (default)
#   EU:  https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Sentry ─────────────────────────────────────────────────────────────────
#
# Browser-side Sentry. The DSN is published to the client bundle by Next,
# which is the standard pattern (Sentry DSNs are public per-project IDs,
# not secrets — the project membership is enforced server-side).
NEXT_PUBLIC_SENTRY_DSN=
# `production` / `staging` / `preview`. Defaults to NODE_ENV.
# NEXT_PUBLIC_SENTRY_ENV=
# Sample 10% of traces in prod. Bump to 1.0 to debug perf issues.
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Server-side Sentry (Next.js API routes + server components + edge).
# Re-use the same DSN as the browser side OR use a separate project to
# keep server / browser error queues separate.
SENTRY_DSN=
# SENTRY_ENV=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Source-map upload — only needed at BUILD time on Vercel / CI. Without
# these, withSentryConfig is a no-op and you'll see minified frames in
# the Sentry dashboard. Generate the auth token at
# https://sentry.io/settings/account/api/auth-tokens/ (scope: project:write).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
