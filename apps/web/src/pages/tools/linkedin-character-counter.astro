---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CharacterCounter from "../../components/CharacterCounter.astro";
import { Icon } from "astro-icon/components";

const platforms = [
  {
    slug: "linkedin",
    name: "LinkedIn post",
    limit: 3000,
    mode: "graphemes" as const,
    hint: "main share text",
  },
  {
    slug: "linkedin-comment",
    name: "LinkedIn comment",
    limit: 1250,
    mode: "graphemes" as const,
    hint: "post / org comments",
  },
  {
    slug: "linkedin-connection-note",
    name: "Connection note",
    limit: 300,
    mode: "graphemes" as const,
    hint: "free LinkedIn tier",
  },
];

const rules = [
  {
    label: "Main post text",
    value: "3,000 characters",
    note: "Counted as grapheme clusters — emoji and accented characters count once.",
  },
  {
    label: "Comments (post + org page)",
    value: "1,250 characters",
    note: "Same counting rule as posts.",
  },
  {
    label: "Connection invitation note",
    value: "300 characters (free) · 1,900 (Premium)",
    note: "Premium and Sales Navigator unlock the longer cap.",
  },
  {
    label: "Article body",
    value: "110,000 characters",
    note: "Native LinkedIn articles, separate from the post limit.",
  },
];
---

<BaseLayout
  title="LinkedIn character counter"
  description="Free LinkedIn character counter — 3,000-character post limit, grapheme-aware, plus comment + connection-note caps. The same preflight rule letmepost.dev runs."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "LinkedIn character counter",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Free LinkedIn character counter for posts, comments, and connection notes. Grapheme-aware counting matches LinkedIn's published rule.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">LinkedIn character counter.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        3,000 characters for the main post body. 1,250 in comments. 300 in a
        free-tier connection note. All three counted as grapheme clusters —
        emoji and accents count once, the way LinkedIn does it.
      </p>
      <CharacterCounter platforms={platforms} />
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">LinkedIn's actual limits.</h2>
      <ul class="list-none p-0 mt-4">
        {
          rules.map((r) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <span class="font-bold text-[0.95rem]">{r.label}</span>
                <span class="text-accent font-mono text-[0.9rem]">
                  {r.value}
                </span>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{r.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">One API call, every platform.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code> runs this rule (and the equivalent on every other
        platform) before the upstream call. If your text would have been rejected,
        the API tells you which rule failed — not <code>{`{ body: {}, message: '' }`}</code>.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="https://dashboard.letmepost.dev">
          Try the API
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/social-media-character-counter"
          >All platforms at once</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
