---
import BaseLayout from "../layouts/BaseLayout.astro";
import Tape from "../components/Tape.astro";
import Closeout from "../components/Closeout.astro";

/**
 * Pricing — receipt direction. Mirrors design/pricing.html.
 * 4-tier RATE CARD, founding-member banner, WHAT'S METERED table,
 * quota wall, self-host card, billing FAQ, CTA strip.
 *
 * Strip widens to 720 to fit the 4-up tier grid comfortably on
 * desktop. Page-scoped styles live in <style is:global> at the
 * bottom so they only ship with this page.
 */

const faqs = [
  {
    q: "When does billing actually start?",
    a: "Not yet. Alpha is free for everyone. When billing turns on, you get a 60-day grace window from announcement before any charges. We'll email + webhook every billing contact, twice.",
  },
  {
    q: "What happens if I go over my quota?",
    a: "Posts stop publishing, they don't silently roll into overage charges. You get a webhook + email at 80% and 100%. Bump to a higher tier and any queued posts publish immediately.",
  },
  {
    q: "Can I downgrade?",
    a: "Yes, any time. The change takes effect at the next billing period. No downgrade penalty.",
  },
  {
    q: "Do you offer annual billing?",
    a: "Not in v1. Annual + invoiced billing lands when there are enough customers to justify the accounting overhead. Monthly Stripe Checkout in the meantime.",
  },
  {
    q: "Is there a free trial of Pro?",
    a: "No. The Free tier is the trial, it's the full API surface on a 50-post quota, indefinitely. If 50 posts a month is enough for your use, stay free forever.",
  },
  {
    q: "SSO / SCIM / DPA / custom SLA?",
    a: 'Beyond Business. <a href="mailto:rose@letmepost.dev">Email us</a> with what you need. The answer is almost certainly yes; it\'s a question of timing.',
  },
  {
    q: "Refunds?",
    a: 'If something we built is broken and we can\'t fix it in the period, yes. Email <a href="mailto:rose@letmepost.dev">rose@letmepost.dev</a>.',
  },
  {
    q: "Founding-member offer terms?",
    a: "Sign up during the first 30 days after billing is announced. Locks in $40/mo on Pro. Forfeit if you cancel, you can't pause and re-claim. Available to the first ~200 customers.",
  },
];
---

<BaseLayout
  title="Pricing"
  description="Per-org pricing, never per-profile. Free tier for evaluation, $79/mo Pro for real workloads, $299/mo Business for embedded SaaS. Self-host stays free forever under Apache 2.0."
  stripWidth={720}
>
  <Tape />

  <header class="page-head" data-sticky-anchor>
    <div class="crumb"><a href="/">letmepost</a> / pricing</div>
    <h1 class="page-h1">Pricing. <span class="acc">Per org.</span><br />Never per profile.</h1>
    <p class="lede">
      One flat number per month. Post volume is the only metered thing.
      Profiles, accounts, team members, webhook endpoints, and API keys
      are all free. <b>Self-host stays free forever under Apache 2.0.</b>
    </p>
  </header>

  <hr class="dash" />

  {/* RATE CARD */}
  <section class="section">
    <h2 class="h-caps">RATE CARD</h2>
    <div class="subtitle center">flat-rate · billed monthly</div>

    <div class="tiers">
      <div class="tier">
        <div class="name">Free</div>
        <div class="who">Personal projects. Single-platform automations. Indefinite, not a trial.</div>
        <div class="price">$0<small>/mo</small></div>
        <div class="quota">QUOTA · <b>50 posts/mo</b></div>
        <ul>
          <li>All 8 platforms</li>
          <li>Full API surface</li>
          <li>MCP server + CLI</li>
          <li>Webhooks (4 events)</li>
          <li>7-day publish logs</li>
          <li>Community Discord</li>
        </ul>
        <a href="https://dashboard.letmepost.dev" class="btn">Start free</a>
      </div>

      <div class="tier hi">
        <div class="ribbon">Recommended</div>
        <div class="name">Pro</div>
        <div class="who">Indie SaaS. Agencies with under 50 clients. Real production traffic.</div>
        <div class="price">$79<small>/mo</small></div>
        <div class="quota">QUOTA · <b>5,000 posts/mo</b></div>
        <ul>
          <li>All 8 platforms</li>
          <li>Full API surface</li>
          <li>MCP server + CLI</li>
          <li>All 8 webhook events</li>
          <li>30-day publish logs</li>
          <li>Email · 24h response</li>
          <li>Webhook replay</li>
        </ul>
        <a href="https://dashboard.letmepost.dev" class="btn pri">Start Pro</a>
      </div>

      <div class="tier">
        <div class="name">Business</div>
        <div class="who">Embedded social features in SaaS. Larger agencies. White-label.</div>
        <div class="price">$299<small>/mo</small></div>
        <div class="quota">QUOTA · <b>25,000 posts/mo</b></div>
        <ul>
          <li>Everything in Pro</li>
          <li>White-label OAuth</li>
          <li>99.9% uptime SLA</li>
          <li>180-day publish logs</li>
          <li>Priority Slack + email</li>
          <li>4h response</li>
          <li>Custom rate limits</li>
        </ul>
        <a href="https://dashboard.letmepost.dev" class="btn">Start Business</a>
      </div>

      <div class="tier">
        <div class="name">Self-host</div>
        <div class="who">Run our exact image on your own infra. Same code as hosted. No feature gate.</div>
        <div class="price">$0<small>/mo</small></div>
        <div class="quota">QUOTA · <b>∞ (your infra)</b></div>
        <ul>
          <li>Full API surface</li>
          <li>BYO Postgres + Redis</li>
          <li>BYO platform credentials</li>
          <li>Docker compose up</li>
          <li>Forever free, Apache 2.0</li>
          <li>Community Discord</li>
        </ul>
        <a href="https://docs.letmepost.dev/self-host" class="btn">Read the guide</a>
      </div>
    </div>

    <p class="lede" style="margin-top: 14px;">
      Beyond Business (volume, SSO, SCIM, custom SLA, DPA)?
      <a href="mailto:rose@letmepost.dev">Email us.</a>
      No enterprise card on the page because the answer is "let's talk".
    </p>
  </section>

  <hr class="dash" />

  {/* FOUNDING-MEMBER OFFER */}
  <section class="section">
    <div class="founding">
      <div class="l">
        <h3><b>Founding-member offer</b>, first 30 days after billing turns on</h3>
        <p>Lock in <b>$40/mo for life</b> on the Pro tier. Available to anyone who signs up during the alpha window. Forfeit on cancel.</p>
      </div>
      <div class="r">
        $40<small>/mo · for life</small>
      </div>
    </div>
    <p class="lede" style="margin-top: 10px;">
      Alpha customers also get a <b>60-day grace window</b> after billing is announced before charges begin. We will not surprise-bill anyone.
    </p>
  </section>

  <hr class="dash" />

  {/* WHAT'S METERED */}
  <section class="section">
    <h2 class="h-caps">WHAT'S METERED</h2>
    <div class="subtitle center">posts go on the bill. nothing else does.</div>

    <table class="metered">
      <thead>
        <tr><th>Resource</th><th>Cost</th><th>Notes</th></tr>
      </thead>
      <tbody>
        <tr>
          <td class="k">Posts</td>
          <td class="v"><span class="meter">metered</span></td>
          <td class="v">One per <code>POST /v1/posts</code>. Multi-target counts as 1, not N. Scheduled posts count when they publish.</td>
        </tr>
        <tr>
          <td class="k">Profiles</td>
          <td class="v"><span class="free">free · unlimited</span></td>
          <td class="v">Per-client isolation for agencies. Each profile owns its own connected accounts, API keys, webhooks.</td>
        </tr>
        <tr>
          <td class="k">Connected accounts</td>
          <td class="v"><span class="free">free · unlimited</span></td>
          <td class="v">Connect as many social accounts as you want, across any combination of platforms.</td>
        </tr>
        <tr>
          <td class="k">Team members</td>
          <td class="v"><span class="free">free · unlimited</span></td>
          <td class="v">Invite as many people as you want. No per-seat charge.</td>
        </tr>
        <tr>
          <td class="k">API keys</td>
          <td class="v"><span class="free">free · unlimited</span></td>
          <td class="v">Rotate freely. Prefixed <code>lmp_live_</code> or <code>lmp_test_</code>. Only last-4 stored after creation.</td>
        </tr>
        <tr>
          <td class="k">Webhook endpoints</td>
          <td class="v"><span class="free">free · unlimited</span></td>
          <td class="v">HMAC-signed deliveries. 7-day dead-letter inspection on Pro, 30-day on Business.</td>
        </tr>
        <tr>
          <td class="k">Media storage</td>
          <td class="v"><span class="free">free · 30 days</span></td>
          <td class="v">S3-backed. Upload once, reference by <code>mediaId</code>. 30-day retention before automatic GC.</td>
        </tr>
        <tr>
          <td class="k">Preflight checks</td>
          <td class="v"><span class="free">free · unlimited</span></td>
          <td class="v">A failed preflight does <b>not</b> count against your post quota. Only successful publishes meter.</td>
        </tr>
      </tbody>
    </table>
  </section>

  <hr class="dash" />

  {/* QUOTA WALL */}
  <section class="section">
    <h2 class="h-mixed">How the wall works.</h2>
    <p class="subtitle left">hard cap, no overages, no surprises</p>

    <div class="quota-wall">
      <div class="row">
        <div class="l">
          <b>0 → 79% of quota.</b>
          <p>Posts publish normally. No webhook noise.</p>
        </div>
        <div class="r ok">all good</div>
      </div>
      <div class="row">
        <div class="l">
          <b>80% of quota.</b>
          <p>Webhook <code>quota.warning</code> fires + email to billing contact.</p>
        </div>
        <div class="r">first warning</div>
      </div>
      <div class="row">
        <div class="l">
          <b>100% of quota.</b>
          <p>Webhook <code>quota.exceeded</code> + email. Posts queue but do not publish.</p>
        </div>
        <div class="r">hard cap</div>
      </div>
      <div class="row">
        <div class="l">
          <b>Upgrade or wait for reset.</b>
          <p>Bump to a higher tier and queued posts publish immediately. Or wait until next billing period.</p>
        </div>
        <div class="r ok">your call</div>
      </div>
    </div>
  </section>

  <hr class="dash" />

  {/* SELF-HOST DETAIL */}
  <section class="section">
    <h2 class="h-mixed">Self-host, <span class="acc">same code, forever free.</span></h2>
    <p class="subtitle left">apache 2.0 · no feature gate · no open-core trick</p>

    <div class="selfhost">
      <h3>One docker-compose away.</h3>
      <p>BYO Postgres and Redis. BYO platform OAuth apps (your own Meta App Review record, your own X dev portal entry). Identical API behavior to the hosted version. You get every preflight rule, every webhook event, every version pin, because the hosted version IS this code.</p>
      <code class="inline-cmd">$ docker compose up</code>
      <p style="margin-top: 14px;">
        <a href="https://docs.letmepost.dev/self-host">Read the self-host guide →</a> ·
        <a href="https://github.com/letmepost/letmepost.dev">Star on GitHub</a>
      </p>
    </div>
  </section>

  <hr class="dash" />

  {/* FAQ */}
  <section class="section">
    <h2 class="h-mixed">Fine print, billing.</h2>
    <p class="subtitle left">the questions a CFO would ask</p>

    <div class="faq">
      {
        faqs.map((f) => (
          <div class="item-q">
            <p class="q">{f.q}</p>
            <p class="a" set:html={f.a} />
          </div>
        ))
      }
    </div>
  </section>

  <hr class="double" />

  {/* CTA strip */}
  <div class="cta-strip">
    <h2>Pick a tier. Or self-host.</h2>
    <p>Free during alpha. Self-host forever free. No credit card required.</p>
    <div class="ctas">
      <a
        href="https://dashboard.letmepost.dev"
        class="btn pri"
        data-analytics-event="cta.clicked"
        data-analytics-props='{"location":"pricing-final","target":"dashboard","page":"pricing","label":"Start free"}'
      >START FREE →</a>
      <a href="https://docs.letmepost.dev/self-host" class="btn">SELF-HOST GUIDE</a>
      <a href="mailto:rose@letmepost.dev" class="btn">EMAIL US</a>
    </div>
  </div>

  <Closeout codeLine="000 LMP 0002 · 2026-05-23 · 14:21Z" />
  <Tape bottom />

  {/* Right rail — billing notes */}
  <aside class="marg" aria-label="Billing notes" slot="rightRail">
    <div class="note">
      <span class="tag">Per org</span>
      Every count below is org-wide. <b>Profiles, accounts, team members, webhooks, and API keys are free.</b>
    </div>
    <div class="note">
      <span class="tag">Hard caps</span>
      When you hit your monthly limit, we send a webhook + email at <b>80%</b> and <b>100%</b>. No surprise overages. No silent billing.
    </div>
    <div class="note">
      <span class="tag">Currency</span>
      USD. Tax / VAT added at checkout per your jurisdiction.
    </div>
    <div class="note">
      <span class="tag">Alpha credit</span>
      Sign up before <b>2026-07-22</b> and the first 60 days after billing turns on are free. No commitment.
    </div>
    <div class="note">
      <span class="tag">Why per-org</span>
      Per-profile pricing taxes the people who use the API correctly. Agencies with 30 clients on Ayrshare pay 30×. With us they pay 1×.
    </div>
    <div class="note">
      <span class="tag">Why hard caps</span>
      Overage billing has bitten too many small teams at 3am. We made the wall loud and the bill predictable.
    </div>
  </aside>
</BaseLayout>

<style is:global>
  /* ── Pricing-only ─────────────────────────────────────────
     The 4-up tier grid and supporting blocks. Kept page-scoped
     because every other page either uses tariff (landing) or
     no pricing tables at all. */

  .tiers {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
    margin: 14px 0 18px;
    border: 1px solid var(--r-line);
  }
  .tier {
    padding: 22px 20px 24px;
    border-right: 1px dashed var(--r-very);
    display: flex; flex-direction: column;
    background: var(--r-paper);
    position: relative;
  }
  .tier:last-child { border-right: 0; }
  .tier.hi { background: var(--r-accent-soft); }
  .tier .ribbon {
    position: absolute; top: 8px; right: 8px;
    font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--r-paper); background: var(--r-accent);
    padding: 3px 8px; line-height: 1;
  }
  .tier .name {
    font-size: 10px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--r-very);
    margin-bottom: 2px; font-weight: 700;
  }
  .tier .who {
    font-size: 11px; color: var(--r-dim); margin-bottom: 16px;
    min-height: 44px; line-height: 1.4;
  }
  .tier .price {
    font-size: 32px; font-weight: 700; letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums; line-height: 1; margin-bottom: 4px;
    color: var(--r-ink);
  }
  .tier .price small {
    font-size: 12px; color: var(--r-dim); font-weight: 400;
    margin-left: 4px; letter-spacing: 0;
  }
  .tier .quota {
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--r-very); padding: 10px 0 12px;
    border-bottom: 1px dotted var(--r-very);
    margin-bottom: 12px;
  }
  .tier .quota b { color: var(--r-ink); font-weight: 700; font-size: 12px; font-variant-numeric: tabular-nums; }
  .tier ul {
    list-style: none; padding: 0; margin: 0 0 18px;
    font-size: 11.5px; color: var(--r-dim);
    flex: 1; line-height: 1.5;
  }
  .tier ul li {
    padding: 5px 0;
    display: grid; grid-template-columns: 14px 1fr; gap: 4px;
  }
  .tier ul li::before { content: '+'; color: var(--r-accent); font-weight: 700; }
  .tier .btn {
    font-family: var(--r-mono); font-size: 11px; font-weight: 700;
    letter-spacing: 0.06em;
    padding: 10px 14px;
    border: 2px solid var(--r-ink);
    background: var(--r-paper); color: var(--r-ink);
    text-decoration: none; text-align: center;
    cursor: pointer; display: block;
  }
  .tier .btn:hover { background: var(--r-ink); color: var(--r-paper); }
  .tier .btn.pri { background: var(--r-ink); color: var(--r-paper); }
  .tier .btn.pri:hover { background: var(--r-accent); border-color: var(--r-accent); }
  [data-theme="dark"] .tier .btn.pri:hover { color: #0e0e0a; }

  /* Founding-member banner */
  .founding {
    border: 2px dashed var(--r-accent);
    padding: 16px 20px;
    margin: 14px 0;
    background: var(--r-accent-soft);
    display: grid; grid-template-columns: 1fr auto; gap: 16px;
    align-items: center;
  }
  .founding .l h3 {
    font-family: var(--r-mono); font-size: 14px; font-weight: 700;
    margin: 0 0 4px; letter-spacing: 0.04em; text-transform: uppercase;
  }
  .founding .l h3 b { color: var(--r-accent); }
  .founding .l p { margin: 0; font-size: 12px; color: var(--r-dim); }
  .founding .r {
    font-size: 26px; font-weight: 700; color: var(--r-accent);
    font-variant-numeric: tabular-nums; line-height: 1;
    text-align: right; white-space: nowrap;
  }
  .founding .r small {
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--r-very); display: block; margin-top: 4px; font-weight: 400;
  }

  /* What's metered table */
  .metered { width: 100%; border-collapse: collapse; font-size: 12.5px; margin: 6px 0; }
  .metered th {
    text-align: left;
    font-size: var(--r-fs-xs); letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--r-very);
    padding: 10px 0; border-bottom: 2px solid var(--r-ink); font-weight: 700;
  }
  .metered td {
    padding: 10px 0; border-bottom: 1px dotted var(--r-very);
    vertical-align: top;
  }
  .metered td.k { color: var(--r-fg); font-weight: 700; }
  .metered td.v { color: var(--r-dim); }
  .metered td .free { color: var(--r-accent); font-weight: 700; }
  .metered td .meter { color: var(--r-ink); font-weight: 700; }
  .metered code { background: var(--r-accent-soft); padding: 1px 5px; font-size: 0.92em; }

  /* Quota wall */
  .quota-wall { margin: 12px 0; }
  .quota-wall .row {
    display: grid; grid-template-columns: 1fr auto;
    padding: 8px 0; border-bottom: 1px dotted var(--r-very);
    align-items: center;
  }
  .quota-wall .row:last-child { border-bottom: 0; }
  .quota-wall .row .l b { color: var(--r-ink); font-weight: 700; }
  .quota-wall .row .l p { margin: 2px 0 0; font-size: 11px; color: var(--r-very); }
  .quota-wall .row .l code { background: var(--r-accent-soft); padding: 1px 5px; font-size: 0.92em; }
  .quota-wall .row .r {
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--r-very);
  }
  .quota-wall .row .r.ok { color: var(--r-accent); }

  /* Self-host card */
  .selfhost {
    border: 1px solid var(--r-line);
    background: var(--r-paper);
    padding: 22px;
    margin: 6px 0;
  }
  .selfhost h3 {
    font-family: var(--r-mono); margin: 0 0 6px;
    font-size: 14px; letter-spacing: 0.04em; color: var(--r-ink);
  }
  .selfhost p { margin: 0 0 10px; color: var(--r-dim); }
  .selfhost a { color: var(--r-accent); }

  /* Footer CTA strip */
  .cta-strip {
    margin-top: 24px; padding: 28px 24px;
    border: 2px solid var(--r-ink);
    text-align: center; background: var(--r-paper);
  }
  .cta-strip h2 {
    margin: 0 0 6px; font-family: var(--r-mono); font-weight: 700;
    font-size: 18px; letter-spacing: -0.005em; color: var(--r-ink);
  }
  .cta-strip p { margin: 0 0 16px; color: var(--r-dim); font-size: 13px; }
  .cta-strip .ctas { justify-content: center; }

  @media (max-width: 820px) {
    .tiers { grid-template-columns: 1fr 1fr; }
    .tier:nth-child(2) { border-right: 0; }
    .tier:nth-child(1), .tier:nth-child(2) { border-bottom: 1px dashed var(--r-very); }
  }
  @media (max-width: 540px) {
    .tiers { grid-template-columns: 1fr; }
    .tier { border-right: 0; border-bottom: 1px dashed var(--r-very); }
    .tier:last-child { border-bottom: 0; }
    .founding { grid-template-columns: 1fr; text-align: center; }
    .founding .r { text-align: center; }
  }
</style>
