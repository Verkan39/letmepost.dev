---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Tape from "../components/Tape.astro";
import Closeout from "../components/Closeout.astro";
import { PLATFORMS } from "../data/platforms.ts";
import { highlight } from "../lib/highlight.ts";

const recentPosts = (
  await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  })
)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function fmtPostDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

/**
 * Landing page — receipt direction. Pixel-mirrors design/letmepost.html.
 * Brand head with stampbox, code-block tabs (curl/ts/py), itemized
 * `WHAT YOU GET`, platform status, error envelope, MCP teaser, tariff
 * sheet, fine-print FAQ, and a final centered CTA.
 *
 * Voice rules: no em dashes; no banned adjectives; honest status only
 * (Bluesky/X/Pinterest live, four Meta+LinkedIn in review, TikTok planned).
 */

// Phosphor names mirror PlatformIcon's mapping, kept inline so the
// landing's tight column doesn't pull in the wrapper component.
const phosphor: Record<string, string> = {
  bluesky: "ph:butterfly",
  twitter: "ph:x-logo",
  pinterest: "ph:pinterest-logo",
  instagram: "ph:instagram-logo",
  facebook: "ph:facebook-logo",
  threads: "ph:threads-logo",
  linkedin: "ph:linkedin-logo",
  tiktok: "ph:tiktok-logo",
};

const faqs = [
  {
    q: "What actually works today?",
    a: "Bluesky, X, and Pinterest are live end-to-end. You can connect an account, send a post, attach images or video, and get a webhook back. Instagram, Facebook, Threads, and LinkedIn are in platform review and flip on the day approval clears.",
  },
  {
    q: "Why another social media API?",
    a: "Because the existing ones fail silently, charge per-profile, and break every six months when a platform sunsets a version. This one fails loudly, charges per-org, and pins the version internally. Apache 2.0 from day one.",
  },
  {
    q: "How much does it cost?",
    a: 'Flat-rate per org. A real free tier covers 50 posts a month. <a href="/pricing">Full pricing →</a>',
  },
  {
    q: "Is it really open source?",
    a: "Apache 2.0. The hosted SaaS runs the exact same image you can self-host. No feature gate, no open-core trick.",
  },
  {
    q: "Do I have to handle Meta App Review myself?",
    a: "No. Connect through our OAuth flow and you publish through our reviewed app. Self-hosters can BYO Meta app if they want their own reviewer-of-record.",
  },
  {
    q: "Can my AI agent drive this?",
    a: 'Yes. Native MCP server at <code>api.letmepost.dev/mcp</code> and a stdio binary on npm. See the agents landing for the full tool surface.',
  },
];

const stripHtml = (html: string) => html.replace(/<[^>]+>/g, "");
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: stripHtml(f.a) },
  })),
};

const curlSample = `curl -X POST https://api.letmepost.dev/v1/posts \\
  -H "Authorization: Bearer $LMP_KEY" \\
  -H "Idempotency-Key: $(uuidgen)" \\
  -H "Content-Type: application/json" \\
  -d '{
    "targets": [
      { "platform": "bluesky" },
      { "platform": "x" },
      { "platform": "pinterest" }
    ],
    "text": "Shipped multi-target publishing today."
  }'`;

const tsSample = `import { Letmepost } from "@letmepost/sdk";

const lmp = new Letmepost({ apiKey: process.env.LMP_KEY });

const result = await lmp.posts.create({
  targets: [
    { platform: "bluesky" },
    { platform: "x" },
    { platform: "pinterest" },
  ],
  text: "Shipped multi-target publishing today.",
  // Idempotency-Key stamped automatically.
});

// Per-target outcomes, never a single ambiguous boolean.
for (const r of result.targets) {
  console.log(r.platform, r.status, r.url ?? r.error?.code);
}`;

const pySample = `from letmepost import Letmepost

lmp = Letmepost(api_key=os.environ["LMP_KEY"])

result = lmp.posts.create(
    targets=[
        {"platform": "bluesky"},
        {"platform": "x"},
        {"platform": "pinterest"},
    ],
    text="Shipped multi-target publishing today.",
)

for r in result.targets:
    print(r.platform, r.status, r.url or r.error.code)`;
---

<BaseLayout
  title="Open-source social media publishing API"
  description="One POST, eight platforms. Meta App Review absorbed, LinkedIn's 2024-25 sunsets pinned, 80 preflight rules built in. Apache 2.0, native MCP server, real free tier."
  jsonLd={[faqJsonLd]}
>
  <Tape />

  {/* HERO v2 — top utility links row, then the small stamp + solid
      rule + H1. Old ledger ("LETMEPOST · v0 alpha · apache-2.0 ·
      est. 2026") is replaced with quick links a reader actually
      wants to click. */}
  <nav class="ledger-row quick-links" aria-label="Top utility">
    <a href="https://docs.letmepost.dev">Docs</a>
    <span class="sep" aria-hidden="true">·</span>
    <a href="/pricing">Pricing</a>
    <span class="sep" aria-hidden="true">·</span>
    <a href="/blog">Blog</a>
    <span class="sep" aria-hidden="true">·</span>
    <a
      href="https://github.com/letmepost/letmepost.dev"
      target="_blank"
      rel="noopener"
    >GitHub ↗</a>
  </nav>

  <div class="hero-stamp" aria-hidden="true">
    <div class="stampbox stampbox-sm">
      <div class="l1">PLATFORM REVIEW</div>
      <div class="l2">PAID IN FULL</div>
      <div class="l3">SO YOU DON'T HAVE TO</div>
    </div>
  </div>

  <hr class="solid" />

  <section class="hero-main" data-sticky-anchor>
    <h1 class="hero-h1">
      OSS Social Media API.
      <br />
      <span class="acc">Built for developers and AI agents.</span>
    </h1>

    <p class="lede">
      Ship social features in minutes, not months. One API to publish
      across 8 platforms, with scheduling, webhooks, and idempotency
      built in. Native MCP server. Apache 2.0.
    </p>

    <div class="ctas">
      <a
        href="https://dashboard.letmepost.dev"
        class="btn pri"
        data-analytics-event="cta.clicked"
        data-analytics-props='{"location":"hero","target":"dashboard","page":"home","label":"Send my first post"}'
      >SEND MY FIRST POST →</a>
      <a
        href="#request"
        class="btn"
        data-analytics-event="cta.clicked"
        data-analytics-props='{"location":"hero-secondary","target":"code","page":"home","label":"See the code"}'
      >SEE THE CODE ↓</a>
    </div>
    <div class="reassurance">
      No credit card · 50 posts/mo free, forever ·
      <a href="https://docs.letmepost.dev/quickstart">90-second quickstart →</a>
    </div>
  </section>

  <hr class="dash" />

  {/* SHOW THE CODE */}
  <section class="section" id="request">
    <h2 class="h-caps">SHOW THE CODE</h2>
    <div class="subtitle center">$ one terminal session</div>

    <div
      class="code-block"
      data-tabs
      data-files='{"curl":"publish.sh","ts":"publish.ts","py":"publish.py"}'
    >
      <div class="head-bar">
        <div class="tabs" role="tablist">
          <button type="button" class="tab on" data-tab="curl" role="tab">curl</button>
          <button type="button" class="tab" data-tab="ts" role="tab">typescript</button>
          <button type="button" class="tab" data-tab="py" role="tab">python</button>
        </div>
        <span class="file">publish.sh</span>
      </div>
      <pre data-pane="curl" set:html={highlight("bash", curlSample)} />
      <pre data-pane="ts" hidden set:html={highlight("ts", tsSample)} />
      <pre data-pane="py" hidden set:html={highlight("python", pySample)} />
    </div>
  </section>

  <hr class="dash" />

  {/* PLATFORMS — simple icon+name grid, each row clickable.
      Replaces the heavier status-pill list that previously lived
      after WHAT YOU GET; the per-platform pages carry the
      live/in-review/planned signal now. */}
  <section class="section">
    <h2 class="h-caps">PLATFORMS</h2>
    <div class="subtitle center">one POST, every connected account</div>

    <div class="simple-platforms">
      {
        PLATFORMS.map((p) => (
          <a href={`/platforms/${p.slug}`}>
            <Icon name={phosphor[p.slug] ?? "ph:circle"} width={16} height={16} />
            <span>{p.name}</span>
          </a>
        ))
      }
    </div>
  </section>

  <hr class="dash" />

  {/* WHAT YOU GET */}
  <section class="section">
    <h2 class="h-caps">PAID-IN-FULL LEDGER</h2>
    <div class="subtitle center">work we did once, so you don't have to</div>

    <div class="items">
      <div class="item">
        <span class="qty">1×</span>
        <span class="desc">
          Multi-target publish endpoint
          <span class="sub">POST /v1/posts, fans out to every connected account in one call</span>
        </span>
        <span class="val">~ 4 wk</span>
      </div>
      <div class="item">
        <span class="qty">3×</span>
        <span class="desc">
          Meta App Review absorbed
          <span class="sub">Instagram + Facebook + Threads, one shared review, our app of record. Three rejections, four re-shot demo videos. Once.</span>
        </span>
        <span class="val">~11 wk</span>
      </div>
      <div class="item">
        <span class="qty">1×</span>
        <span class="desc">
          LinkedIn Marketing Developer Platform review
          <span class="sub">submitted, version-pinned, sunset-monitored</span>
        </span>
        <span class="val">~12 wk</span>
      </div>
      <div class="item">
        <span class="qty">80×</span>
        <span class="desc">
          Preflight rules
          <span class="sub">char-count, media-format, audit-state, URN patterns. One docs page each.</span>
        </span>
        <span class="val">~ 6 wk</span>
      </div>
      <div class="item">
        <span class="qty">7×</span>
        <span class="desc">
          Platform versions pinned for you
          <span class="sub">we own the LinkedIn-sunsets-every-six-weeks problem</span>
        </span>
        <span class="val">∞</span>
      </div>
    </div>

    <div class="total">
      <span>TIME RECLAIMED</span>
      <span class="v">≈ 6 months</span>
    </div>
  </section>

  <hr class="dash" />

  {/* ANATOMY OF A FAILURE */}
  <section class="section">
    <h2 class="h-caps">ANATOMY OF A FAILURE</h2>
    <div class="subtitle center">structured every time, no empty 500s</div>

    <div class="envelope">
      <div class="head-bar">
        <span>HTTP/1.1 422 Unprocessable Entity</span>
        <span>application/json</span>
      </div>
      <div class="body">
        <div class="field"><span class="k">code</span><span class="v b">preflight_failed</span></div>
        <div class="field"><span class="k">rule</span><span class="v acc b">bluesky.text.max_graphemes</span></div>
        <div class="field"><span class="k">platform</span><span class="v">bluesky</span></div>
        <div class="field"><span class="k">platform_version</span><span class="v">atproto-2026-04</span></div>
        <div class="field"><span class="k">message</span><span class="v">Text is 312 graphemes; Bluesky allows at most 300.</span></div>
        <div class="field"><span class="k">remediation</span><span class="v">Trim the text to 300 graphemes or fewer.</span></div>
        <div class="field"><span class="k">doc_url</span><span class="v acc">docs.letmepost.dev/errors/preflight_failed</span></div>
        <div class="field"><span class="k">rule_url</span><span class="v acc">docs.letmepost.dev/preflight/bluesky-text-max_graphemes</span></div>
        <div class="field"><span class="k">request_id</span><span class="v">req_01HXY7Z8K9MNB1P2QR3STVW</span></div>
        <div class="field"><span class="k">trace_id</span><span class="v">01jb7q9c4e5f6g7h8i9k0lm1np</span></div>
      </div>
    </div>
  </section>

  <hr class="dash" />

  {/* For agents — stacked layout: bigger heading, prose below, then
      the full-width config block at the bottom. The previous 2-col
      grid made the code feel tucked away beside the text instead of
      being the punch the section actually leads to. */}
  <section class="section mcp-section">
    <h2>For agents, letmepost speaks <span class="acc">MCP</span>.</h2>
    <p class="subtitle left">a hosted server + a stdio binary on npm</p>

    <div class="mcp">
      <div>
        <p style="margin-top: 0;">A hosted MCP server at <code>api.letmepost.dev/mcp</code> (Streamable HTTP, stateless) and a stdio binary on npm. Twenty-one tools, autogenerated from OpenAPI. Same auth as the HTTP API. Claude, Cursor, Claude Code, opencode, any MCP-aware client drives the full surface.</p>
        <p><a href="/agents">Read the agents landing →</a></p>
      </div>
      <pre class="config" set:html={highlight("json", `{
  "mcpServers": {
    "letmepost": {
      "command": "npx",
      "args":    ["@letmepost/mcp@latest"],
      "env":     { "LMP_API_KEY": "lmp_live_…" }
    }
  }
}`)} />
    </div>
  </section>

  <hr class="dash" />

  {/* Tariff sheet */}
  <section class="section">
    <h2 class="h-mixed">Tariff sheet.</h2>
    <p class="subtitle left">flat-rate · billed monthly</p>

    <table class="tariff">
      <thead>
        <tr>
          <th>Tier</th>
          <th>Posts / mo</th>
          <th class="r">Price</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="tier">Free<span class="who">Personal · single-platform automations</span></td>
          <td>50</td>
          <td class="r"><span class="price">$0</span></td>
        </tr>
        <tr class="hi">
          <td class="tier">Pro <span class="stars">★</span><span class="who">Indie SaaS · agencies under 50 clients</span></td>
          <td>5,000</td>
          <td class="r"><span class="price">$79</span></td>
        </tr>
        <tr>
          <td class="tier">Business<span class="who">Embedded social · uptime SLA · white-label OAuth</span></td>
          <td>25,000</td>
          <td class="r"><span class="price">$299</span></td>
        </tr>
        <tr>
          <td class="tier">Self-host<span class="who">Same image · BYO Postgres + Redis · Apache 2.0</span></td>
          <td>∞</td>
          <td class="r"><span class="price">$0</span></td>
        </tr>
      </tbody>
    </table>
    <p class="lede" style="margin-top: 10px; text-align: right;">
      <a href="/pricing">Full pricing →</a>
    </p>
  </section>

  {recentPosts.length > 0 && (
    <>
      <hr class="dash" />

      {/* Latest writing — surfaces blog posts on the highest-authority
          page so Outrank-published articles inherit link equity from
          the home page. */}
      <section class="section">
        <h2 class="h-mixed">Latest writing.</h2>
        <p class="subtitle left">engineering notes from the platform-review queue</p>

        <ul class="recent-posts">
          {recentPosts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                <span class="rp-date">{fmtPostDate(post.data.pubDate)}</span>
                <span class="rp-title">{post.data.title}</span>
                <span class="rp-desc">{post.data.description}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="recent-more">
          <a href="/blog">All writing →</a>
        </p>
      </section>
    </>
  )}

  <hr class="dash" />

  {/* Fine print */}
  <section class="section">
    <h2 class="h-mixed">Fine print.</h2>
    <p class="subtitle left">questions you'd ask in a code review</p>

    <div class="faq">
      {
        faqs.map((f) => (
          <div class="item-q">
            <p class="q">{f.q}</p>
            <p class="a" set:html={f.a} />
          </div>
        ))
      }
    </div>
  </section>

  <hr class="double" />

  {/* FINAL CTA */}
  <section class="section" style="text-align: center;">
    <h2 class="h-caps" style="margin-bottom: 8px;">SEND THE FIRST POST.</h2>
    <p class="lede" style="margin: 6px auto 18px; text-align: center;">
      Ninety seconds from sign-up to a Bluesky post in production.<br />
      Star the repo, file an issue when something's weird — we build in the open.
    </p>
    <div class="ctas" style="justify-content: center;">
      <a
        href="https://dashboard.letmepost.dev"
        class="btn pri"
        data-analytics-event="cta.clicked"
        data-analytics-props='{"location":"home-final","target":"dashboard","page":"home","label":"Send my first post"}'
      >SEND MY FIRST POST →</a>
      <a
        href="https://docs.letmepost.dev"
        class="btn"
        data-analytics-event="docs.link_clicked"
        data-analytics-props='{"from_page":"home","location":"home-final","to_section":"root"}'
      >READ THE DOCS ↗</a>
    </div>
  </section>

  <Closeout
    codeLine="000 LMP 0001 · 2026-05-23 · 14:21Z"
    links={[
      { href: "https://docs.letmepost.dev", label: "docs" },
      { href: "https://github.com/letmepost/letmepost.dev", label: "github" },
      { href: "https://status.letmepost.dev", label: "status" },
      { href: "/privacy", label: "privacy" },
      { href: "/terms", label: "terms" },
    ]}
  />

  <Tape bottom />

  {/* Right rail — technical annotations */}
  <aside class="marg" aria-label="Technical notes" slot="rightRail">
    <div class="note">
      <span class="tag">Method</span>
      Every <b>POST</b> runs through 80 preflight rules locally before the platform sees the request. The rule that fires is named on the failure envelope.
    </div>
    <div class="note">
      <span class="tag">Idempotency</span>
      Every write accepts <b>Idempotency-Key</b>. Retries return the cached response for 24h. Conflicting bodies surface as <code>idempotency_conflict</code> (HTTP 409).
    </div>
    <div class="note">
      <span class="tag">Webhooks</span>
      HMAC-SHA256 signed.<br />
      <b>post.queued</b>, post.published, post.failed, post.rejected, <b>token.expiring</b>, token.revoked, version.deprecated, quota.warning.
    </div>
    <div class="note">
      <span class="tag">Errors</span>
      Eleven stable codes, each with its own docs page. Plus the rule id that fired, the pinned platform version, and a remediation hint.
    </div>
    <div class="note">
      <span class="tag">Self-host</span>
      <code>docker compose up</code> against your own Postgres + Redis. BYO platform credentials. Same image as hosted.
    </div>
    <div class="note">
      <span class="tag">Contact</span>
      File an issue on the repo or email <b>rose@letmepost.dev</b>. There's no priority-routing tier because there's only one person to route to.
    </div>
  </aside>
</BaseLayout>

<style is:global>
  /* Latest writing strip — surfaces blog posts on the home page */
  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 14px 0 14px;
    display: grid;
    gap: 0;
    border-top: 1px dotted var(--r-very);
  }
  .recent-posts li a {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px dotted var(--r-very);
    text-decoration: none;
    color: inherit;
  }
  .recent-posts li a:hover .rp-title { color: var(--r-accent); }
  .recent-posts .rp-date {
    font-family: var(--r-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--r-very);
    padding-top: 3px;
  }
  .recent-posts .rp-title {
    font-family: var(--r-mono);
    font-weight: 700;
    font-size: 14px;
    line-height: 1.3;
    color: var(--r-ink);
    grid-column: 2;
    margin-bottom: 3px;
  }
  .recent-posts .rp-desc {
    grid-column: 2;
    font-size: 12px;
    line-height: 1.5;
    color: var(--r-dim);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .recent-more {
    margin: 8px 0 0;
    font-family: var(--r-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .recent-more a { color: var(--r-accent); text-decoration: none; }
  .recent-more a:hover { text-decoration: underline; }

  /* ── /index landing-only overrides ────────────────────────
     Quieter hero pattern: tiny ledger row at top, big H1 leading
     left-aligned, with the PAID-IN-FULL stamp demoted to a small
     rotated mark on the right of the headline. The previous big
     centered stamp pulled the eye away from the H1; this layout
     puts the headline first and uses the stamp as a tertiary
     accent instead of a focal element. */

  .ledger-row {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--r-very);
    text-align: center;
    padding-top: 36px;
  }
  /* Top utility nav — styled like the "90-second quickstart →" inline
     link in the hero reassurance row: uppercase, accent-colored, with
     a dotted-underline on hover. Same visual vocabulary as the rest
     of the hero's small CTAs. */
  .ledger-row.quick-links {
    display: flex; gap: 14px; justify-content: center; align-items: center;
    flex-wrap: wrap;
  }
  .ledger-row.quick-links a {
    color: var(--r-accent);
    text-decoration: none;
    transition: color 120ms;
    font-size: var(--r-fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .ledger-row.quick-links a:hover {
    color: var(--r-accent-hover, var(--r-ink));
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }
  .ledger-row.quick-links .sep { color: var(--r-line); }

  /* Simple platforms grid — icon + name, 3 columns on desktop,
     2 on tablet, 1 on mobile. No status pills, no taglines; the
     per-platform page carries that detail. */
  .simple-platforms {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 6px 24px; margin: 14px 0 4px;
  }
  .simple-platforms a {
    display: inline-flex; align-items: center; gap: 10px;
    text-decoration: none; color: var(--r-fg);
    padding: 7px 0; font-size: 13px;
    transition: color 100ms;
  }
  .simple-platforms a:hover { color: var(--r-accent); }
  .simple-platforms a svg {
    flex-shrink: 0; color: var(--r-ink);
    transition: color 100ms;
  }
  .simple-platforms a:hover svg { color: var(--r-accent); }
  @media (max-width: 600px) {
    .simple-platforms { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 400px) {
    .simple-platforms { grid-template-columns: 1fr; }
  }

  /* Hero body — H1 leads the page, full-width inside the strip. */
  .hero-main { padding-top: 28px; padding-bottom: 8px; }
  .hero-main h1.hero-h1 {
    font-size: 44px;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 18px;
  }
