{
  "name": "@letmepost/mcp",
  "version": "0.2.0",
  "description": "MCP server for letmepost.dev. Autogenerates a tool per OpenAPI operation so agents can drive the entire publishing API — posts, media, accounts, webhooks, API keys — without bespoke wrappers.",
  "type": "module",
  "main": "./dist/autogen.js",
  "types": "./dist/autogen.d.ts",
  "exports": {
    ".": {
      "types": "./dist/autogen.d.ts",
      "default": "./dist/autogen.js"
    },
    "./autogen": {
      "types": "./dist/autogen.d.ts",
      "default": "./dist/autogen.js"
    },
    "./openapi.json": "./dist/openapi.json"
  },
  "bin": {
    "letmepost-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node scripts/copy-openapi.mjs",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-openapi.mjs",
    "predev": "node scripts/copy-openapi.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "node scripts/copy-openapi.mjs && tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "letmepost",
    "social-media",
    "publishing-api",
    "agents"
  ],
  "license": "Apache-2.0",
  "homepage": "https://docs.letmepost.dev/agents/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/letmepost/letmepost.dev.git",
    "directory": "apps/mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@letmepost/config-tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
