---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const urnTypes = [
  { value: "person", label: "person", note: "Personal profile actor — author of a member-side post." },
  { value: "organization", label: "organization", note: "Company page — author of an org post." },
  { value: "share", label: "share", note: "Legacy share post (UGC predecessor)." },
  { value: "ugcPost", label: "ugcPost", note: "UGC post — current default for member + org posts." },
  { value: "activity", label: "activity", note: "Activity wrapper around a post; what feed URLs reference." },
  { value: "image", label: "image", note: "Uploaded image asset (newer image API)." },
  { value: "video", label: "video", note: "Uploaded video asset." },
  { value: "document", label: "document", note: "Uploaded document (PDF) asset." },
  { value: "digitalmediaAsset", label: "digitalmediaAsset", note: "Legacy media asset URN (Vector Asset API)." },
  { value: "fsd_company", label: "fsd_company", note: "Federated company URN (newer endpoints)." },
  { value: "fsd_member", label: "fsd_member", note: "Federated member URN." },
  { value: "comment", label: "comment", note: "Comment on a post or article." },
  { value: "learningCourse", label: "learningCourse", note: "LinkedIn Learning course." },
];

const examples = [
  { urn: "urn:li:person:abc123", explain: "A specific personal profile." },
  { urn: "urn:li:organization:1337", explain: "A specific company page." },
  { urn: "urn:li:share:6845678901234567890", explain: "An old-style share post." },
  { urn: "urn:li:ugcPost:7245678901234567890", explain: "A current UGC post — what /ugcPosts and /posts return." },
  { urn: "urn:li:activity:7245678901234567891", explain: "An activity wrapper — what appears in feed URLs (linkedin.com/feed/update/urn:li:activity:…)." },
];
---

<BaseLayout
  title="LinkedIn URN encoder / decoder"
  description="Free LinkedIn URN encoder and decoder. Build urn:li:share, urn:li:ugcPost, urn:li:organization, urn:li:person URNs (and the URL-encoded variants) without typing colons by hand."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "LinkedIn URN encoder / decoder",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Encode (type + id → urn) and decode (urn → type + id) LinkedIn URNs. Includes URL-encoded variants for path-segment use.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">LinkedIn URN encoder / decoder.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        Build <code>urn:li:ugcPost:…</code>, <code>urn:li:organization:…</code>,
        <code>urn:li:person:…</code> — or paste one and split it back into type
        and id. Both raw and URL-encoded variants, since LinkedIn's API needs
        the encoded form in path segments.
      </p>

      <div class="lmp-urn" data-urn>
        <div class="lmp-urn-tabs">
          <button
            type="button"
            class="lmp-urn-tab"
            data-urn-tab="encode"
            aria-selected="true">Encode</button
          >
          <button
            type="button"
            class="lmp-urn-tab"
            data-urn-tab="decode"
            aria-selected="false">Decode</button
          >
        </div>

        <!-- ENCODE pane -->
        <div class="lmp-urn-pane" data-urn-pane="encode">
          <div class="lmp-urn-grid">
            <label class="lmp-urn-field">
              <span class="lmp-urn-label">Type</span>
              <select data-urn-type>
                {urnTypes.map((t) => <option value={t.value}>{t.label}</option>)}
              </select>
            </label>
            <label class="lmp-urn-field">
              <span class="lmp-urn-label">ID</span>
              <input
                type="text"
                placeholder="e.g. 7245678901234567890"
                data-urn-id
              />
            </label>
          </div>

          <div class="lmp-urn-row">
            <div class="lmp-urn-row-head">
              <span class="lmp-urn-name">URN</span>
              <button
                type="button"
                class="lmp-counter-copy"
                data-urn-copy="raw">Copy</button
              >
            </div>
            <code class="lmp-urn-out" data-urn-raw>—</code>
          </div>

          <div class="lmp-urn-row">
            <div class="lmp-urn-row-head">
              <span class="lmp-urn-name">URL-encoded</span>
              <button
                type="button"
                class="lmp-counter-copy"
                data-urn-copy="encoded">Copy</button
              >
            </div>
            <code class="lmp-urn-out" data-urn-encoded>—</code>
            <span class="lmp-urn-meta">Use this in path segments (e.g. <code>/ugcPosts/{`{encoded-urn}`}</code>).</span>
          </div>

          <div class="lmp-urn-row">
            <div class="lmp-urn-row-head">
              <span class="lmp-urn-name">Type description</span>
            </div>
            <span class="lmp-urn-meta" data-urn-typedesc>—</span>
          </div>
        </div>

        <!-- DECODE pane -->
        <div class="lmp-urn-pane" data-urn-pane="decode" hidden>
          <label class="lmp-urn-field">
            <span class="lmp-urn-label">Paste URN (raw or URL-encoded)</span>
            <input
              type="text"
              placeholder="urn:li:ugcPost:7245678901234567890"
              data-urn-decode-input
            />
          </label>

          <div class="lmp-urn-grid">
            <div class="lmp-urn-row">
              <div class="lmp-urn-row-head">
                <span class="lmp-urn-name">Type</span>
              </div>
              <code class="lmp-urn-out" data-urn-decode-type>—</code>
            </div>
            <div class="lmp-urn-row">
              <div class="lmp-urn-row-head">
                <span class="lmp-urn-name">ID</span>
              </div>
              <code class="lmp-urn-out" data-urn-decode-id>—</code>
            </div>
          </div>

          <div class="lmp-urn-row">
            <div class="lmp-urn-row-head">
              <span class="lmp-urn-name">Validity</span>
            </div>
            <span class="lmp-urn-meta" data-urn-decode-validity>—</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">URN reference.</h2>
      <ul class="list-none p-0 mt-4">
        {
          urnTypes.map((t) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <code class="font-mono text-[0.9rem]">urn:li:{t.label}:{`{id}`}</code>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{t.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Real examples.</h2>
      <ul class="list-none p-0 mt-4">
        {
          examples.map((e) => (
            <li class="border border-border p-4 mb-2">
              <code class="font-mono text-[0.9rem]">{e.urn}</code>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{e.explain}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">URNs are a chore. We handle them.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code>'s LinkedIn integration takes account ids,
        not raw URNs — we build, encode, and route them server-side. If you
        want to keep doing it by hand, this tool is here.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="/platforms/linkedin">
          LinkedIn on letmepost.dev
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/linkedin-oauth-scope-checker"
          >LinkedIn OAuth checker</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-urn {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-urn-tabs {
    display: inline-flex;
    border: 1px solid var(--color-border);
    margin-bottom: 0.85rem;
  }
  .lmp-urn-tab {
    background: transparent;
    border: none;
    border-right: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.45rem 0.95rem;
    cursor: pointer;
    transition:
      background 120ms ease,
      color 120ms ease;
  }
  .lmp-urn-tab:last-child {
    border-right: none;
  }
  .lmp-urn-tab[aria-selected="true"] {
    background: var(--color-accent);
    color: var(--color-accent-text);
  }
  .lmp-urn-pane[hidden] {
    display: none;
  }
  .lmp-urn-grid {
    display: grid;
    grid-template-columns: minmax(160px, 240px) 1fr;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }
  @media (max-width: 540px) {
    .lmp-urn-grid {
      grid-template-columns: 1fr;
    }
  }
  .lmp-urn-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .lmp-urn-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }
  .lmp-urn-field input,
  .lmp-urn-field select {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    padding: 0.5rem 0.65rem;
    outline: none;
  }
  .lmp-urn-field input:focus,
  .lmp-urn-field select:focus {
    border-color: var(--color-accent);
  }
  .lmp-urn-row {
    padding: 0.6rem 0;
    border-bottom: 1px dashed var(--color-border);
  }
  .lmp-urn-row:last-of-type {
    border-bottom: none;
  }
  .lmp-urn-row-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .lmp-urn-name {
    font-weight: 700;
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }
  .lmp-urn-out {
    display: block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.55rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    word-break: break-all;
    user-select: all;
  }
  .lmp-urn-meta {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin-top: 0.35rem;
  }
  .lmp-counter-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }
  .lmp-counter-copy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

<script>
  // Brief descriptions per type — must mirror the Astro-side urnTypes
  // array. Server-rendered list is the source of truth; this client copy
  // exists so the encode pane can refresh the description without a round
  // trip when the user changes the type select.
  const TYPE_DESC: Record<string, string> = {
    person: "Personal profile actor — author of a member-side post.",
    organization: "Company page — author of an org post.",
    share: "Legacy share post (UGC predecessor).",
    ugcPost: "UGC post — current default for member + org posts.",
    activity: "Activity wrapper around a post; what feed URLs reference.",
    image: "Uploaded image asset (newer image API).",
    video: "Uploaded video asset.",
    document: "Uploaded document (PDF) asset.",
    digitalmediaAsset: "Legacy media asset URN (Vector Asset API).",
    fsd_company: "Federated company URN (newer endpoints).",
    fsd_member: "Federated member URN.",
    comment: "Comment on a post or article.",
    learningCourse: "LinkedIn Learning course.",
  };

  function setupUrn(root: HTMLElement) {
    const tabs = Array.from(
      root.querySelectorAll<HTMLButtonElement>(".lmp-urn-tab"),
    );
    const panes = Array.from(
      root.querySelectorAll<HTMLElement>("[data-urn-pane]"),
    );

    // Encode pane refs.
    const typeSel = root.querySelector<HTMLSelectElement>("[data-urn-type]");
    const idInput = root.querySelector<HTMLInputElement>("[data-urn-id]");
    const rawOut = root.querySelector<HTMLElement>("[data-urn-raw]");
    const encodedOut = root.querySelector<HTMLElement>("[data-urn-encoded]");
    const typeDesc = root.querySelector<HTMLElement>("[data-urn-typedesc]");

    // Decode pane refs.
    const decInput = root.querySelector<HTMLInputElement>(
      "[data-urn-decode-input]",
    );
    const decType = root.querySelector<HTMLElement>("[data-urn-decode-type]");
    const decId = root.querySelector<HTMLElement>("[data-urn-decode-id]");
    const decValidity = root.querySelector<HTMLElement>(
      "[data-urn-decode-validity]",
    );

    // Tab plumbing.
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.setAttribute("aria-selected", "false"));
        tab.setAttribute("aria-selected", "true");
        const target = tab.dataset.urnTab;
        panes.forEach((pane) => {
          pane.hidden = pane.dataset.urnPane !== target;
        });
      });
    });

    function refreshEncode() {
      const type = typeSel?.value || "person";
      const id = (idInput?.value || "").trim();
      if (!id) {
        if (rawOut) rawOut.textContent = "—";
        if (encodedOut) encodedOut.textContent = "—";
        if (typeDesc) typeDesc.textContent = TYPE_DESC[type] || "—";
        return;
      }
      const raw = `urn:li:${type}:${id}`;
      const encoded = encodeURIComponent(raw);
      if (rawOut) rawOut.textContent = raw;
      if (encodedOut) encodedOut.textContent = encoded;
      if (typeDesc) typeDesc.textContent = TYPE_DESC[type] || "—";
    }

    function refreshDecode() {
      const raw = (decInput?.value || "").trim();
      if (!raw) {
        if (decType) decType.textContent = "—";
        if (decId) decId.textContent = "—";
        if (decValidity) decValidity.textContent = "—";
        return;
      }
      // Accept URL-encoded by decoding once before parsing.
      let decoded = raw;
      try {
        decoded = decodeURIComponent(raw);
      } catch {
        decoded = raw;
      }
      const m = decoded.match(/^urn:li:([a-zA-Z_]+):(.+)$/);
      if (!m) {
        if (decType) decType.textContent = "—";
        if (decId) decId.textContent = "—";
        if (decValidity)
          decValidity.textContent =
            "Invalid — expected `urn:li:<type>:<id>` shape.";
        return;
      }
      const [, type, id] = m;
      if (decType) decType.textContent = type;
      if (decId) decId.textContent = id;
      if (decValidity) {
        const known = type in TYPE_DESC;
        decValidity.textContent = known
          ? `Valid — known LinkedIn URN type.`
          : `Parsed, but \`${type}\` isn't in our reference list. Could still be valid.`;
      }
    }

    typeSel?.addEventListener("change", refreshEncode);
    idInput?.addEventListener("input", refreshEncode);
    decInput?.addEventListener("input", refreshDecode);

    // Copy buttons.
    root
      .querySelectorAll<HTMLButtonElement>("[data-urn-copy]")
      .forEach((btn) => {
        btn.addEventListener("click", async () => {
          const which = btn.dataset.urnCopy as "raw" | "encoded";
          const target = which === "raw" ? rawOut : encodedOut;
          const text = target?.textContent || "";
          if (!text || text === "—") return;
          try {
            await navigator.clipboard.writeText(text);
            const original = btn.textContent;
            btn.textContent = "Copied";
            setTimeout(() => (btn.textContent = original), 1100);
          } catch {
            /* clipboard blocked */
          }
        });
      });

    refreshEncode();
    refreshDecode();
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>("[data-urn]").forEach(setupUrn);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
