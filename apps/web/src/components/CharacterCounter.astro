---
/**
 * Reusable per-platform text counter. Each platform card reads the
 * shared `<textarea>` and shows the platform-specific count vs. limit.
 *
 * `mode` controls the counting algorithm:
 *   - "chars"            — JS string `.length` (UTF-16 code units). Useful
 *                          baseline; matches what most platforms' web UIs
 *                          count, but over-counts emoji on the API side.
 *   - "graphemes"        — Intl.Segmenter("grapheme"). What a human reads
 *                          as "one character." Used by Bluesky's actual
 *                          AT-Proto rule and the closest match to
 *                          LinkedIn's published count.
 *   - "twitter-weighted" — twitter-text weighted count: Latin/CJK have
 *                          different costs. Used by X.
 *
 * `byteLimit` adds a secondary UTF-8 byte cap (Bluesky enforces both
 * 300 graphemes AND 3000 bytes — whichever hits first).
 */

export interface PlatformLimit {
  slug: string;
  name: string;
  icon?: string;
  limit: number;
  mode: "chars" | "graphemes" | "twitter-weighted";
  byteLimit?: number;
  /** Short note shown under the count. */
  hint?: string;
}

interface Props {
  platforms: PlatformLimit[];
  /** Default placeholder text. */
  placeholder?: string;
  /** Initial textarea value. Useful for a worked example. */
  initialText?: string;
}

const {
  platforms,
  placeholder = "Type or paste your post…",
  initialText = "",
} = Astro.props;

// Embed config as JSON for the client script — avoids string-templating
// platform data into JS by hand. Astro renders the dataset attribute
// inline at build time.
const config = JSON.stringify(platforms);
---

<div class="lmp-counter" data-counter data-platforms={config}>
  <label class="lmp-counter-label" for="lmp-counter-text">
    <span class="text-text-muted">Your post</span>
    <button
      type="button"
      class="lmp-counter-copy"
      data-counter-copy
      aria-label="Copy text"
    >
      Copy
    </button>
  </label>
  <textarea
    id="lmp-counter-text"
    class="lmp-counter-textarea"
    rows="6"
    placeholder={placeholder}
    spellcheck="true"
    data-counter-input>{initialText}</textarea>

  <div class="lmp-counter-cards" data-counter-cards>
    {platforms.map((p) => (
      <div class="lmp-counter-card" data-platform={p.slug}>
        <div class="lmp-counter-card-head">
          <span class="lmp-counter-name">{p.name}</span>
          <span class="lmp-counter-readout" data-readout>0 / {p.limit.toLocaleString()}</span>
        </div>
        <div class="lmp-counter-track" aria-hidden="true">
          <div class="lmp-counter-fill" data-fill style="width: 0%"></div>
        </div>
        <div class="lmp-counter-meta">
          <span class="lmp-counter-status" data-status>under limit</span>
          {p.hint ? <span class="lmp-counter-hint">{p.hint}</span> : null}
        </div>
        {p.byteLimit ? (
          <div class="lmp-counter-byteline">
            <span class="text-text-muted">UTF-8 bytes</span>
            <span data-bytes>0 / {p.byteLimit.toLocaleString()}</span>
          </div>
        ) : null}
      </div>
    ))}
  </div>
</div>

<style>
  .lmp-counter {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }

  .lmp-counter-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .lmp-counter-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }
  .lmp-counter-copy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .lmp-counter-copy[data-copied="true"] {
    color: var(--color-success);
    border-color: var(--color-success);
  }

  .lmp-counter-textarea {
    width: 100%;
    min-height: 8.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 0.75rem 0.85rem;
    resize: vertical;
    outline: none;
  }
  .lmp-counter-textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent);
  }

  .lmp-counter-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  .lmp-counter-card {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    padding: 0.7rem 0.8rem;
  }

  .lmp-counter-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.45rem;
  }

  .lmp-counter-name {
    font-weight: 700;
    font-size: 0.85rem;
  }

  .lmp-counter-readout {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .lmp-counter-track {
    height: 4px;
    background: var(--color-border);
    overflow: hidden;
  }

  .lmp-counter-fill {
    height: 100%;
    background: var(--color-accent);
    transition:
      width 80ms linear,
      background 120ms ease;
  }

  .lmp-counter-card[data-state="warn"] .lmp-counter-fill {
    background: var(--color-http-put);
    /* Amber tone in light, accent in dark — simple swap by token. */
    background: hsl(38 75% 48%);
  }

  .lmp-counter-card[data-state="over"] .lmp-counter-fill {
    background: var(--color-error);
  }

  .lmp-counter-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin-top: 0.35rem;
  }

  .lmp-counter-status {
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .lmp-counter-card[data-state="warn"] .lmp-counter-status {
    color: hsl(38 80% 38%);
  }
  .lmp-counter-card[data-state="over"] .lmp-counter-status {
    color: var(--color-error);
  }

  .lmp-counter-hint {
    text-align: right;
  }

  .lmp-counter-byteline {
    display: flex;
    justify-content: space-between;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  // Each counter card declares its own platform config via data-platforms.
  // The script wires up a single textarea -> N cards. Multiple counter
  // blocks on a page (unlikely but supported) work because we scope every
  // query to the wrapping [data-counter] element.

  type PlatformLimit = {
    slug: string;
    name: string;
    limit: number;
    mode: "chars" | "graphemes" | "twitter-weighted";
    byteLimit?: number;
    hint?: string;
  };

  // Twitter-text "weighted" range table — codepoints inside these ranges
  // count as 1, everything else counts as 2. Mirrors twitter-text's
  // default config (https://github.com/twitter/twitter-text). Trimmed to
  // the ranges that actually matter; the long tail beyond U+10FF is all
  // weight-2 anyway.
  const TWITTER_LIGHT_RANGES: [number, number][] = [
    [0x0000, 0x10ff],
    [0x2000, 0x200d],
    [0x2010, 0x2010],
    [0x2013, 0x2027],
    [0x202f, 0x205e],
    [0x2060, 0x2064],
    [0x206a, 0x206f],
  ];

  function twitterWeightedCount(text: string): number {
    let total = 0;
    for (const ch of text) {
      const cp = ch.codePointAt(0)!;
      let light = false;
      for (const [lo, hi] of TWITTER_LIGHT_RANGES) {
        if (cp >= lo && cp <= hi) {
          light = true;
          break;
        }
      }
      total += light ? 1 : 2;
    }
    return total;
  }

  // Lazy single-shared Segmenter — Intl.Segmenter is expensive to construct
  // (10s of ms in some engines) so we reuse one for the whole page.
  let segmenter: Intl.Segmenter | null = null;
  function graphemeCount(text: string): number {
    if (typeof Intl === "undefined" || !("Segmenter" in Intl)) {
      // Pre-2022 browser fallback — close enough for a counter UI.
      return [...text].length;
    }
    if (!segmenter) {
      segmenter = new Intl.Segmenter("en", { granularity: "grapheme" });
    }
    let count = 0;
    // eslint-disable-next-line @typescript-eslint/no-unused-vars
    for (const _ of segmenter.segment(text)) count += 1;
    return count;
  }

  function utf8ByteCount(text: string): number {
    return new TextEncoder().encode(text).length;
  }

  function countFor(text: string, mode: PlatformLimit["mode"]): number {
    switch (mode) {
      case "chars":
        return [...text].length; // codepoint count, not UTF-16 units
      case "graphemes":
        return graphemeCount(text);
      case "twitter-weighted":
        return twitterWeightedCount(text);
    }
  }

  function setupCounter(root: HTMLElement) {
    const platforms: PlatformLimit[] = JSON.parse(
      root.dataset.platforms || "[]",
    );
    const input = root.querySelector<HTMLTextAreaElement>("[data-counter-input]");
    const cards = Array.from(
      root.querySelectorAll<HTMLElement>("[data-platform]"),
    );
    const copy = root.querySelector<HTMLButtonElement>("[data-counter-copy]");
    if (!input) return;

    function update() {
      const text = input!.value;
      const bytes = utf8ByteCount(text);

      for (const card of cards) {
        const slug = card.dataset.platform;
        const cfg = platforms.find((p) => p.slug === slug);
        if (!cfg) continue;

        const count = countFor(text, cfg.mode);
        const readout = card.querySelector<HTMLElement>("[data-readout]");
        const fill = card.querySelector<HTMLElement>("[data-fill]");
        const status = card.querySelector<HTMLElement>("[data-status]");
        const bytesEl = card.querySelector<HTMLElement>("[data-bytes]");

        // Bluesky-style: % is the worst of (chars/limit, bytes/byteLimit).
        const charPct = (count / cfg.limit) * 100;
        const bytePct = cfg.byteLimit ? (bytes / cfg.byteLimit) * 100 : 0;
        const pct = Math.max(charPct, bytePct);

        if (readout) {
          readout.textContent = `${count.toLocaleString()} / ${cfg.limit.toLocaleString()}`;
        }
        if (fill) {
          fill.style.width = `${Math.min(pct, 100)}%`;
        }

        let state: "ok" | "warn" | "over" = "ok";
        if (pct >= 100) state = "over";
        else if (pct >= 85) state = "warn";
        card.dataset.state = state;

        if (status) {
          if (state === "over") {
            const overBy = Math.max(count - cfg.limit, 0);
            const overByBytes =
              cfg.byteLimit && bytes > cfg.byteLimit
                ? bytes - cfg.byteLimit
                : 0;
            status.textContent =
              overByBytes > 0 && overByBytes >= overBy
                ? `over by ${overByBytes.toLocaleString()} bytes`
                : `over by ${overBy.toLocaleString()}`;
          } else if (state === "warn") {
            status.textContent = "approaching limit";
          } else {
            status.textContent = "under limit";
          }
        }

        if (bytesEl && cfg.byteLimit) {
          bytesEl.textContent = `${bytes.toLocaleString()} / ${cfg.byteLimit.toLocaleString()}`;
        }
      }
    }

    input.addEventListener("input", update);
    // Run once on mount for any prefilled text.
    update();

    if (copy) {
      copy.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(input.value);
          copy.dataset.copied = "true";
          copy.textContent = "Copied";
          setTimeout(() => {
            copy.dataset.copied = "false";
            copy.textContent = "Copy";
          }, 1200);
        } catch {
          /* clipboard blocked — silently no-op */
        }
      });
    }
  }

  function bootAll() {
    document
      .querySelectorAll<HTMLElement>("[data-counter]")
      .forEach(setupCounter);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
