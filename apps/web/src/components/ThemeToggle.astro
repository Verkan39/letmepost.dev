---
import { Icon } from "astro-icon/components";
---

<button
  type="button"
  data-theme-toggle
  aria-label="Theme"
  title="Theme"
  class="theme-toggle inline-flex items-center justify-center w-7 h-7 transition-colors text-text-muted hover:text-accent"
>
  <Icon name="ph:sun" width={16} height={16} class="theme-icon-light" />
  <Icon name="ph:moon" width={16} height={16} class="theme-icon-dark" />
  <Icon
    name="ph:monitor"
    width={16}
    height={16}
    class="theme-icon-system"
  />
</button>

<style>
  /* Show only the icon for the user's stored preference (not the resolved
     theme). That way you can tell at a glance whether you're on system,
     forced-light, or forced-dark — and the cycle order is predictable. */
  .theme-toggle .theme-icon-light,
  .theme-toggle .theme-icon-dark,
  .theme-toggle .theme-icon-system {
    display: none;
  }
  :global(html[data-theme-pref="light"]) .theme-toggle .theme-icon-light {
    display: inline-block;
  }
  :global(html[data-theme-pref="dark"]) .theme-toggle .theme-icon-dark {
    display: inline-block;
  }
  :global(html[data-theme-pref="system"]) .theme-toggle .theme-icon-system {
    display: inline-block;
  }
</style>

<script>
  type Theme = "light" | "dark" | "system";
  const KEY = "lmp-theme";
  // Cycle order is deterministic — light → dark → system → light.
  const ORDER: Theme[] = ["light", "dark", "system"];

  function resolve(t: Theme): "light" | "dark" {
    return t === "system"
      ? window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light"
      : t;
  }

  function apply(pref: Theme) {
    document.documentElement.setAttribute("data-theme", resolve(pref));
    document.documentElement.dataset.themePref = pref;
    try {
      localStorage.setItem(KEY, pref);
    } catch {}
  }

  function read(): Theme {
    try {
      const v = localStorage.getItem(KEY);
      if (v === "light" || v === "dark" || v === "system") return v;
    } catch {}
    return "system";
  }

  function bind() {
    const btn = document.querySelector<HTMLButtonElement>(
      "[data-theme-toggle]",
    );
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", () => {
      const cur = read();
      const idx = ORDER.indexOf(cur);
      const next = ORDER[(idx + 1) % ORDER.length];
      apply(next);
    });
  }

  // When the user is on `system`, follow OS-level changes live.
  const mq = window.matchMedia("(prefers-color-scheme: dark)");
  mq.addEventListener("change", () => {
    if (read() === "system") apply("system");
  });

  bind();
  document.addEventListener("astro:page-load", bind);
</script>
