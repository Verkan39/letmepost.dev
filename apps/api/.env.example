# letmepost.dev — apps/api environment variables
# Copy to .env (git-ignored) and fill in real values.
#
# Sections:
#   1. Core (required to boot)
#   2. Queue / Redis
#   3. Auth (better-auth + social sign-in providers)
#   4. Platform OAuth credentials (LinkedIn, Twitter/X, Pinterest, Meta, YouTube)
#
# When you register the developer app for each platform, the redirect URI
# you must configure on the platform's portal is listed under each section.
# In production swap `http://localhost:3000` for your real API base URL.

# ─── 1. Core ────────────────────────────────────────────────────────────────

# Postgres connection string. NeonDB pooler URL recommended for hosted use.
# Local Postgres also works — the driver is selected automatically.
#
# NeonDB example:   postgres://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require
# Local example:    postgres://postgres:postgres@localhost:5432/letmepost
DATABASE_URL=

# AES-256-GCM master key for the token envelope. Base64 of exactly 32 bytes.
# Generate with:  openssl rand -base64 32
# Must be rotated via re-wrap, not replacement — see apps/api/src/encryption/envelope.ts.
KEK_MASTER=

# HTTP port the API listens on. Default 3000.
# PORT=3000

# Bind address. Defaults to 0.0.0.0 so the server is reachable from outside
# the container/host. Override to 127.0.0.1 if you only want local reads.
# HOST=0.0.0.0

# Base URL of the public docs site. Stamped on every error envelope as
# `error.docUrl` (and `ruleUrl` when a preflight rule fires) so callers
# land on the canonical remediation page in one click. Default
# https://docs.letmepost.dev; override for staging / self-hosted docs.
# DOCS_BASE_URL=https://docs.letmepost.dev

# Public origin where the API is reachable from the outside world. Used by
# platform providers to build their OAuth redirect URIs at runtime — must
# match exactly what each platform's developer portal has on file. Defaults
# to http://localhost:3000 if unset (fine for dev).
# Prod: https://api.letmepost.dev (or wherever the API is mounted)
PUBLIC_API_BASE_URL=http://localhost:3000

# Override the launch state of a platform without a deploy. The default
# state map lives in `@letmepost/schemas` (platform-state.ts). Comma-
# separated `platform:state` pairs; valid states are `live`, `trial`,
# `pending`. Example: flip Pinterest live the moment Standard Access lands.
#   PLATFORM_STATE_OVERRIDES=pinterest:live,linkedin:trial
PLATFORM_STATE_OVERRIDES=

# Extra CORS origins, comma-separated. The dashboard at http://localhost:3001
# is always allowed. Add your prod dashboard origin here.
# Example: https://app.letmepost.dev,https://staging.letmepost.dev
CORS_ORIGINS=

# Optional. Postgres connection string used by the repository test suite (per-test
# transaction rollback). If unset, those tests are skipped — the encryption tests
# and existing Bluesky / preflight / health tests still run. Point at a disposable
# local Postgres or a NeonDB preview branch.
TEST_DATABASE_URL=

# ─── 2. Queue / Redis ───────────────────────────────────────────────────────

# Upstash Redis connection string used by BullMQ for publish / validate /
# refresh-token / webhook-deliver queues. Local Redis works for dev:
#   redis://localhost:6379
# Upstash example:
#   rediss://default:<password>@<region>.upstash.io:6379
REDIS_URL=

# ─── 3. Auth ────────────────────────────────────────────────────────────────

# better-auth signing secret. 32 bytes minimum.
# Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public origin where better-auth callbacks land. Must match the URL the
# dashboard hits at runtime.
# Dev: http://localhost:3000
# Prod: https://api.letmepost.dev (or wherever the API is mounted)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated list of dashboard origins better-auth should trust for
# cross-origin auth flows. Local :3001 is always allowed; add the prod
# dashboard origin here.
# Prod: https://dashboard.letmepost.dev
TRUSTED_ORIGINS=

# Dashboard origin the OAuth provider redirects to when it needs the user to
# sign in (`/sign-in`) or grant consent (`/consent`). Default works for local
# dev; production must point at the live dashboard.
# Prod: https://dashboard.letmepost.dev
# DASHBOARD_URL=http://localhost:3001

# Where the OAuth callback redirects the browser after a successful (or
# failed) connect — typically the dashboard's /accounts page. Used by
# GET /v1/accounts/oauth/:platform/callback so the user lands back in the
# UI after the provider hands them off.
# Dev:  http://localhost:3001
# Prod: https://dashboard.letmepost.dev
DASHBOARD_URL=http://localhost:3001

# Set in production when the API and dashboard live on different subdomains
# of the same parent domain. Configures the session cookie with
# `Domain=<value>; SameSite=None; Secure` so dashboard.letmepost.dev can
# read the cookie set by api.letmepost.dev. Leave blank in dev.
# Prod example: .letmepost.dev   (note the leading dot)
COOKIE_DOMAIN=

# Pairwise subject identifier secret for the OAuth 2.1 authorization-server
# surface (better-auth's oauth-provider plugin). HMAC-SHA256 key used to derive
# per-client `sub` claims when an oauth_client opts into `subject_type: pairwise`
# — privacy nicety that stops two MCP clients from correlating the same user
# across their installs. Generate with: openssl rand -base64 32
# Leave unset to disable pairwise (default is `public`, where every client sees
# the same `sub` for a given user).
# PAIRWISE_SECRET=

# ── Optional: social sign-in providers for the dashboard (better-auth)
# Set both ID + SECRET to enable; leaving them blank disables that provider.

# Google OAuth (Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (Settings → Developer settings → OAuth Apps).
# Authorization callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── 4. Platform OAuth credentials ──────────────────────────────────────────
#
# Each platform follows the same pattern: register a developer app, configure
# the redirect URI listed below, paste the client id + secret here. The scope
# strings letmepost requests are listed verbatim — paste them into the
# platform's "permissions" / "products" / "scopes" form when verification asks.

# ── LinkedIn ────────────────────────────────────────────────────────────────
# Portal:        https://www.linkedin.com/developers/apps
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/linkedin/callback
# Products to enable on the app:
#   • "Sign In with LinkedIn using OpenID Connect"  (gives openid, profile)
#   • "Share on LinkedIn"                            (gives w_member_social)
# Scopes letmepost requests:
#   write     openid, profile, w_member_social
#   extended  email, r_organization_social, w_organization_social
# Notes: org / Company-Page posting (`w_organization_social`) requires the
# Marketing Developer Platform (MDP) review — separate, slower process. The
# personal-posting MVP works without it.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Twitter / X ─────────────────────────────────────────────────────────────
# Portal:        https://developer.x.com/en/portal/dashboard
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/twitter/callback
# OAuth 2.0 settings:
#   • Type of App:       "Web App, Automated App or Bot"
#   • Authentication:    OAuth 2.0 with PKCE (Confidential client)
#   • Scopes (write):    tweet.read, tweet.write, users.read, offline.access
#   • Scopes (extended): like.read, follows.read
# Notes: as of Feb 2026 X killed tiered pricing for new signups — Basic/Pro
# tiers are closed; pay-per-use is the only option for new developers.
# Posting requires write access on the paid tier.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Per-account launch cap: max billable posts (published/rejected/failed —
# i.e. anything that reached the X API) per rolling 30-day window. PPU
# billing makes an uncapped publish loop expensive fast. Default 50.
# TWITTER_LAUNCH_CAP_PER_ACCOUNT=50

# ── Pinterest ───────────────────────────────────────────────────────────────
# Portal:        https://developers.pinterest.com/apps/
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/pinterest/callback
# Scopes letmepost requests:
#   write     boards:read, boards:write, pins:read, pins:write, user_accounts:read
#   extended  pins:read_secret
# Notes: new apps start in Trial Access — pin creation on production
# (api.pinterest.com) is BLOCKED with a hard "use sandbox" error until
# Standard Access approves. Set PINTEREST_API_BASE to the sandbox URL
# during the trial window; clear it (back to default) after approval.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Trial Access only — set to https://api-sandbox.pinterest.com/v5 while
# Pinterest reviews your Standard Access submission. Leave blank in
# production once approved (defaults to https://api.pinterest.com/v5).
# Affects every /v5/* call AND the OAuth token-exchange endpoint, since
# both live under the same host on Pinterest's API.
PINTEREST_API_BASE=

# ── Meta — Facebook + Instagram (Threads is separate, see below) ──────────
# Portal:        https://developers.facebook.com/apps/
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/facebook/callback
# (NOT /meta/callback — the provider registers under the `facebook` platform
# key and fans out to IG on completeConnect. Earlier docs incorrectly said
# /meta/callback; if your Meta app has that registered, update it.)
# Products to add on the app:
#   • Facebook Login for Business
#   • Instagram (Business)
# Scopes letmepost requests (write):
#   pages_manage_posts, pages_read_engagement, pages_show_list,
#   business_management, instagram_basic, instagram_content_publish
# Notes: Meta App Review takes 2–8 weeks per cycle and rejections are normal.
# Build against Development Mode + Tester accounts during the wait — same
# Graph API endpoints, same response shapes; review just lifts the
# testers-only gate. Business verification is required before submission.
META_APP_ID=
META_APP_SECRET=
# Pin the Graph API version. Default lives in the Meta provider; bump on
# each platform version cut and run the contract test suite.
# META_GRAPH_VERSION=v23.0

# ── Instagram (Instagram API with Instagram Login — IG-only OAuth) ────────
# Portal:        https://developers.facebook.com/apps/ (same app as Meta, but
#                with the "Instagram" product / "Instagram API setup with
#                Instagram Login" enabled).
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/instagram/callback
# Scopes letmepost requests (write):
#   instagram_business_basic, instagram_business_content_publish
# Notes: This is DIFFERENT from the IG fan-out you get via Facebook Login for
# Business above. IG Login is for users who want to connect with just their
# Instagram account (Professional accounts only — Business or Creator),
# no Facebook Page required. Token is bound to the IG user; publishes hit
# graph.instagram.com instead of graph.facebook.com. App Review is separate
# from the FB Login scopes — different scope namespace.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
# Override the IG Graph base for tests pointing at MSW. Defaults to
# https://graph.instagram.com — leave blank in production.
# INSTAGRAM_GRAPH_BASE=
# INSTAGRAM_OAUTH_AUTHORIZE_URL=
# INSTAGRAM_OAUTH_TOKEN_URL=

# ── Threads ─────────────────────────────────────────────────────────────────
# Portal:        https://developers.facebook.com/apps/  (add the "Threads API" product)
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/threads/callback
# Authorize URL: https://threads.net/oauth/authorize  (NOT facebook.com/dialog/oauth)
# Scopes letmepost requests:
#   write     threads_basic, threads_content_publish
#   extended  threads_manage_replies, threads_read_replies
# Notes: Threads has its OWN OAuth flow + client credentials, separate from
# Facebook Login for Business. The Threads API product on developers.facebook.com
# generates a distinct THREADS_CLIENT_ID / THREADS_CLIENT_SECRET — do not
# reuse META_APP_ID. Tokens are short-lived (1h) on first exchange, swapped
# server-side for 60-day long-lived tokens which are what we persist.
# App Review for `threads_content_publish` is required for production; Dev
# Mode with Tester accounts is fully functional in the meantime (same API,
# same response shapes — review only lifts the testers-only gate).
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
# Override the Graph API base for tests pointed at MSW. Leave blank in
# production (defaults to https://graph.threads.net).
# THREADS_API_BASE=
# THREADS_API_VERSION=v1.0

# ── YouTube ─────────────────────────────────────────────────────────────────
# Portal:        https://console.cloud.google.com/apis/credentials
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/youtube/callback
# OAuth client type: Web application
# Enable the YouTube Data API v3 on the project before creating credentials.
# Scopes letmepost requests (write):
#   https://www.googleapis.com/auth/youtube.upload
#   https://www.googleapis.com/auth/youtube
#   https://www.googleapis.com/auth/youtube.readonly
# Notes: YouTube enforces an OAuth verification + security review for any
# scope marked "sensitive" or "restricted" — the upload scope is restricted
# and requires an annual third-party security assessment for production
# verification (3–6 weeks first time, expensive). Unverified apps are
# capped at 100 lifetime users; that's fine for staged rollout while the
# review clears.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Media upload service (S3) ───────────────────────────────────────────────
# Bucket: single bucket, prefixed by env. Layout: ${MEDIA_ENV_PREFIX}/${orgId}/${mediaId}.${ext}
# Block Public Access: OFF (objects are publicly readable via bucket policy
# on s3:GetObject — security rests on unguessable mediaIds, ~131 bits of
# entropy). Object Ownership: "Bucket owner enforced" (ACLs disabled).
# IAM user: see plan.md Phase 7.5 for the policy spec — needs s3:PutObject,
# GetObject, DeleteObject, AbortMultipartUpload, ListMultipartUploadParts on
# the bucket's objects, plus ListBucket / ListBucketMultipartUploads on the
# bucket itself.
AWS_REGION=us-east-1
S3_BUCKET=letmepost-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL — direct S3 in v1; swap to CloudFront / media.letmepost.dev
# later without code changes (see plan.md Phase 7.5 future-work note).
MEDIA_PUBLIC_BASE_URL=https://letmepost-media.s3.us-east-1.amazonaws.com
# Env prefix carved off the bucket — keeps prod / dev objects in separate
# key namespaces while sharing a bucket.
MEDIA_ENV_PREFIX=dev

# ─── 5. Billing — Lemon Squeezy ─────────────────────────────────────────────
#
# Set BILLING_ENABLED=true in any environment where you want quota gating to
# fire. Self-hosters leave this false (or unset) and every call goes through
# as if the org is on a synthetic "self_host" tier with infinite quota.
#
# When BILLING_ENABLED=true the rest of the LMSQ_* variables are required.
# Quota gating, webhook signature verification, and the customer-portal /
# checkout / cancel routes all read from these.
BILLING_ENABLED=false

# Optional. ISO 8601 timestamp marking when billing went live. Every org
# created before this time gets a 60-day grandfather window where their
# quota is treated as Infinity (the row stays in their resolved tier, but
# quotaPerMonth is bumped to Infinity until the window expires).
# Example: 2026-06-01T00:00:00Z
BILLING_ANNOUNCED_AT=

# Lemon Squeezy numeric store id. Used to build the hosted-checkout URL
# host: https://<store-slug>.lemonsqueezy.com/checkout/buy/<variant-id>.
# Find this on the Settings -> General tab of the LS dashboard.
LMSQ_STORE_ID=

# Bearer token for the LS REST API (POST /api/keys in the LS dashboard).
# Read-write scope is required so we can mint customer-portal URLs, cancel
# subscriptions, and list invoices.
LMSQ_API_KEY=

# Optional. Override the LS API base for tests pointed at MSW.
# Defaults to https://api.lemonsqueezy.com/v1.
# LMSQ_API_BASE=

# HMAC-SHA256 signing secret configured on the LS webhook endpoint. We
# verify every inbound webhook against this with constant-time comparison.
# Rotate it via the LS dashboard; update this env, redeploy.
LMSQ_WEBHOOK_SECRET=

# Numeric variant ids for the paid tiers. Find them under Products ->
# <product> -> Variants in the LS dashboard. tierForVariant() maps these
# to the canonical "pro" / "business" tier names, so renames in LS don't
# break our internal tier strings.
LMSQ_VARIANT_PRO=
LMSQ_VARIANT_BUSINESS=

# ── TikTok (deferred to v2) ─────────────────────────────────────────────────
# Not wired in v1. The portal + scopes when we revisit:
#   Portal:   https://developers.tiktok.com/apps/
#   Scopes:   user.info.basic, video.publish, video.upload
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
