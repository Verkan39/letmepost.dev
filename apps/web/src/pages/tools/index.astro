---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const groups = [
  {
    label: "Character counters",
    tools: [
      {
        slug: "social-media-character-counter",
        title: "Multi-platform counter",
        body: "One textarea, every limit at once. Bluesky graphemes + bytes, X weighted, LinkedIn 3,000, Threads 500.",
        icon: "list-bullets",
      },
      {
        slug: "linkedin-character-counter",
        title: "LinkedIn",
        body: "3,000-char share limit, grapheme-aware. Includes the org-comment + connection-note caps.",
        icon: "linkedin-logo",
      },
      {
        slug: "x-character-counter",
        title: "X (Twitter)",
        body: "280 weighted characters using twitter-text's own range table — CJK and emoji counted accurately.",
        icon: "x-logo",
      },
      {
        slug: "bluesky-grapheme-counter",
        title: "Bluesky",
        body: "300 graphemes AND 3,000 UTF-8 bytes. Whichever caps first. Same rule the AT Protocol enforces.",
        icon: "butterfly",
      },
      {
        slug: "threads-character-counter",
        title: "Threads",
        body: "500-character cap. Grapheme-aware so multi-codepoint emoji don't over-count.",
        icon: "infinity",
      },
    ],
  },
  {
    label: "Generators",
    tools: [
      {
        slug: "idempotency-key-generator",
        title: "Idempotency key generator",
        body: "UUID v4, ULID, or nanoid — the three formats you actually want as an Idempotency-Key header.",
        icon: "key",
      },
    ],
  },
  {
    label: "Platform helpers",
    tools: [
      {
        slug: "youtube-quota-cost-calculator",
        title: "YouTube API quota calculator",
        body: "Pick the operations you call, see daily quota burn against your 10,000-unit default — and how fast videos.insert eats it.",
        icon: "youtube-logo",
      },
      {
        slug: "linkedin-oauth-scope-checker",
        title: "LinkedIn OAuth scope checker",
        body: "Pick scopes, see what they actually unlock. Or pick an action and see the minimum scope set.",
        icon: "shield-check",
      },
    ],
  },
];
---

<BaseLayout
  title="Free developer tools"
  description="Free tools for building against social media APIs — character counters, idempotency key generators, OAuth scope checkers, quota calculators."
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-7 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Free · No login
      </div>

      <h1 class="!m-0">
        Tools that fail loudly,<br class="max-[640px]:hidden" />
        <span class="text-accent">so your code doesn't have to.</span>
      </h1>

      <p
        class="text-[1.1rem] leading-[1.6] max-w-[42rem] mt-5 mb-8 text-text-secondary"
      >
        The same preflight rules <code>letmepost.dev</code> runs against your posts,
        broken out into pages you can use without an account. Hand them to a teammate, embed them in your runbook, paste them into your CI script — they're public and free.
      </p>
    </div>
  </section>

  {
    groups.map((group) => (
      <section class="pt-2 pb-10">
        <div class="container">
          <div class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted mb-3">
            {group.label}
          </div>
          <ul class="list-none p-0 m-0 grid grid-cols-1 sm:grid-cols-2 gap-3">
            {group.tools.map((t) => (
              <li>
                <a
                  href={`/tools/${t.slug}`}
                  class="block border border-border p-5 no-underline transition-colors hover:border-border-strong hover:bg-bg-elev"
                >
                  <div class="flex items-center gap-2 mb-2 text-accent">
                    <Icon name={`ph:${t.icon}`} width={18} height={18} />
                    <span class="font-bold text-[0.95rem] text-text">
                      {t.title}
                    </span>
                  </div>
                  <p class="text-text-muted m-0 text-[0.86rem]">{t.body}</p>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    ))
  }

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Why these tools exist.</h2>
      <p class="text-text-muted">
        Every one of these is a preflight rule we already run inside the API. We
        publish them as standalone tools because the rule itself is useful even
        if you're not (yet) on the platform — and because half the long-tail
        bugs in social-API integrations are "oh, I didn't know LinkedIn counted
        emoji like that."
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="https://dashboard.letmepost.dev">
          Try the API for free
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="https://docs.letmepost.dev/preflight"
          >Read the preflight docs</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
