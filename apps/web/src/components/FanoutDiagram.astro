---
/**
 * "Fan-out topology" schematic: one source fanning out through animated
 * curved wires to every connected platform. Platforms come from PLATFORMS
 * (canonical), live ones sorted first.
 *
 * mode="post" (default, landing): source is `POST /v1/posts`.
 * mode="agents" (for-agents page): source cycles through popular AI agent
 * logos — same fan-out, framed as "your agent posts everywhere".
 */
import PlatformIcon from "./PlatformIcon.astro";
import { Icon } from "astro-icon/components";
import { PLATFORMS } from "../data/platforms.ts";

interface Props {
  mode?: "post" | "agents";
}
const { mode = "post" } = Astro.props;

const AGENTS = [
  { icon: "simple-icons:claude", name: "Claude" },
  { icon: "simple-icons:openai", name: "ChatGPT" },
  { icon: "simple-icons:cursor", name: "Cursor" },
  { icon: "simple-icons:zedindustries", name: "Zed" },
];

const order: Record<string, number> = { live: 0, trial: 0, pending: 1, planned: 2 };
const seen = new Set<string>();
const platforms = PLATFORMS.filter((p) =>
  seen.has(p.slug) ? false : (seen.add(p.slug), true),
).sort((a, b) => (order[a.status] ?? 3) - (order[b.status] ?? 3));

// SVG connector geometry. Rows are a fixed height so the curve endpoints
// line up with each platform row's vertical center.
const ROW_H = 56;
const W = 96;
const H = platforms.length * ROW_H;
const cy = H / 2;
const wires = platforms.map((_, i) => {
  const y = i * ROW_H + ROW_H / 2;
  return `M0 ${cy} C ${W * 0.55} ${cy} ${W * 0.45} ${y} ${W} ${y}`;
});

const label =
  mode === "agents"
    ? "Fan-out topology: your AI agent publishes to every connected platform through one tool call"
    : "Fan-out topology: one POST to /v1/posts fans out to every connected platform";
---

<figure class="topo" aria-label={label}>
  <div class="topo-body" style={`--row-h:${ROW_H}px`}>
    {
      mode === "agents" ? (
        <div class="topo-source agents">
          <span class="lbl">Your agent</span>
          <span class="agent-rotator" data-agent-rotator>
            {AGENTS.map((a, i) => (
              <span class={`agent${i === 0 ? " on" : ""}`}>
                <Icon name={a.icon} width={18} height={18} />
                {a.name}
              </span>
            ))}
          </span>
        </div>
      ) : (
        <div class="topo-source">
          <span class="lbl">Source</span>
          <span class="m">POST</span>
          <span class="path">/v1/posts</span>
        </div>
      )
    }

    <svg class="topo-wires" viewBox={`0 0 ${W} ${H}`} width={W} height={H} preserveAspectRatio="none" aria-hidden="true">
      {wires.map((d) => <path class="wire" d={d} />)}
      {wires.map((d, i) => (
        <path class="flow" d={d} pathLength="100" style={`animation-delay:${(i * 0.16).toFixed(2)}s`} />
      ))}
    </svg>

    <div class="topo-rows">
      {
        platforms.map((p) => (
          <div class="topo-row">
            <span class="g"><PlatformIcon platform={p.slug} size={18} /></span>
            <span class="nm">{p.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</figure>

<style>
  .topo { margin: 0; }

  .topo-body { display: grid; grid-template-columns: 132px 96px 1fr; gap: 0; align-items: center; }

  .topo-source {
    align-self: center;
    display: flex; flex-direction: column; gap: 3px; text-align: center;
    border: 2px solid var(--ink); border-radius: 12px; padding: 18px 14px;
    background: transparent;
  }
  .topo-source .lbl { font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--faint); }
  .topo-source .m { font-family: var(--mono); font-weight: 600; font-size: 18px; color: var(--acc); line-height: 1.1; }
  .topo-source .path { font-family: var(--mono); font-size: 15px; color: var(--ink); }

  /* agents mode: rotating AI-agent logo in the source box */
  .topo-source.agents { gap: 8px; }
  .agent-rotator { position: relative; display: flex; align-items: center; justify-content: center; height: 26px; }
  .agent-rotator .agent { position: absolute; inset: 0; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: var(--mono); font-weight: 600; font-size: 16px; color: var(--ink); white-space: nowrap; opacity: 0; transition: opacity 320ms ease; }
  .agent-rotator .agent.on { opacity: 1; }
  .agent-rotator .agent :global(svg) { color: var(--acc); }

  .topo-wires { display: block; height: 100%; overflow: visible; }
  .topo-wires .wire { fill: none; stroke: var(--line); stroke-width: 1.5; }
  .topo-wires .flow {
    fill: none; stroke: var(--acc); stroke-width: 1.5; stroke-linecap: round;
    stroke-dasharray: 1.5 98.5; opacity: 0.35;
    animation: topo-flow 1.5s linear infinite;
  }
  @keyframes topo-flow {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0; }
  }

  .topo-rows { display: flex; flex-direction: column; }
  .topo-row { display: grid; grid-template-columns: 26px 1fr; gap: 12px; align-items: center; height: var(--row-h, 56px); }
  .topo-row .g { display: flex; align-items: center; justify-content: center; color: var(--ink); }
  .topo-row .nm { font-family: var(--mono); font-weight: 600; font-size: 15px; color: var(--ink); white-space: nowrap; }

  @media (prefers-reduced-motion: reduce) {
    .topo-wires .flow { animation: none; opacity: 0; }
  }

  @media (max-width: 560px) {
    .topo { padding: 18px 16px; }
    .topo-body { grid-template-columns: 1fr; }
    .topo-source { align-self: stretch; margin-bottom: 18px; }
    .topo-wires { display: none; }
    .topo-rows { border-top: 1px solid var(--line); }
    .topo-row { border-bottom: 1px solid var(--line); }
  }
</style>

<script>
  // Cycle the AI-agent logo in agents-mode fan-out diagrams.
  function bindFanoutRotator() {
    document.querySelectorAll<HTMLElement>("[data-agent-rotator]").forEach((root) => {
      if (root.dataset.lmpBound) return;
      root.dataset.lmpBound = "1";
      const agents = Array.from(root.querySelectorAll<HTMLElement>(".agent"));
      if (agents.length < 2) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      let i = 0;
      setInterval(() => {
        agents[i].classList.remove("on");
        i = (i + 1) % agents.length;
        agents[i].classList.add("on");
      }, 2000);
    });
  }
  bindFanoutRotator();
  document.addEventListener("astro:page-load", bindFanoutRotator);
</script>
