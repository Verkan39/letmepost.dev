---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";

// Meta's OAuth surface spans Facebook + Instagram + Threads + WhatsApp,
// plus Business/Ads. Most of the useful scopes are "Advanced Access"
// gated behind App Review. We tag each scope with `review: "advanced"`
// so users know going in which ones will block until reviewed.

const actions = [
  {
    id: "signin",
    label: "Sign in (Facebook Login)",
    scopes: ["public_profile"],
  },
  {
    id: "email",
    label: "Read user email",
    scopes: ["public_profile", "email"],
  },
  {
    id: "list-pages",
    label: "List user's Facebook Pages",
    scopes: ["pages_show_list"],
  },
  {
    id: "post-page",
    label: "Post on a Facebook Page",
    scopes: ["pages_show_list", "pages_manage_posts", "pages_read_engagement"],
    note: "pages_manage_posts is Advanced Access — needs App Review.",
  },
  {
    id: "read-page-eng",
    label: "Read Page post engagement",
    scopes: ["pages_show_list", "pages_read_engagement"],
  },
  {
    id: "manage-comments",
    label: "Moderate comments on a Page",
    scopes: [
      "pages_show_list",
      "pages_read_engagement",
      "pages_manage_engagement",
    ],
    note: "pages_manage_engagement is Advanced Access.",
  },
  {
    id: "messenger",
    label: "Send Messenger messages",
    scopes: ["pages_show_list", "pages_messaging"],
    note: "pages_messaging is Advanced Access.",
  },
  {
    id: "ig-read",
    label: "Read Instagram Business / Creator account",
    scopes: ["pages_show_list", "instagram_basic"],
  },
  {
    id: "ig-publish",
    label: "Publish to Instagram (feed / Reels / Stories / Carousel)",
    scopes: [
      "pages_show_list",
      "instagram_basic",
      "instagram_content_publish",
    ],
    note: "instagram_content_publish is Advanced Access — App Review required.",
  },
  {
    id: "ig-comments",
    label: "Moderate Instagram comments",
    scopes: [
      "pages_show_list",
      "instagram_basic",
      "instagram_manage_comments",
    ],
    note: "instagram_manage_comments is Advanced Access.",
  },
  {
    id: "ig-dm",
    label: "Send + read Instagram DMs",
    scopes: [
      "pages_show_list",
      "instagram_basic",
      "instagram_manage_messages",
      "pages_messaging",
    ],
    note: "instagram_manage_messages is Advanced Access — restricted use case.",
  },
  {
    id: "ig-insights",
    label: "Read Instagram insights",
    scopes: [
      "pages_show_list",
      "instagram_basic",
      "instagram_manage_insights",
    ],
    note: "instagram_manage_insights is Advanced Access.",
  },
  {
    id: "threads-read",
    label: "Read Threads profile",
    scopes: ["threads_basic"],
  },
  {
    id: "threads-publish",
    label: "Publish to Threads",
    scopes: ["threads_basic", "threads_content_publish"],
    note: "threads_content_publish is Advanced Access.",
  },
  {
    id: "threads-replies",
    label: "Read + manage Threads replies",
    scopes: [
      "threads_basic",
      "threads_read_replies",
      "threads_manage_replies",
    ],
  },
  {
    id: "threads-insights",
    label: "Read Threads insights",
    scopes: ["threads_basic", "threads_manage_insights"],
  },
  {
    id: "wa-messaging",
    label: "WhatsApp Business — send + receive messages",
    scopes: [
      "whatsapp_business_management",
      "whatsapp_business_messaging",
    ],
    note: "Both Advanced Access. Plus WhatsApp BSP onboarding.",
  },
  {
    id: "ads-read",
    label: "Read ads campaigns + reporting",
    scopes: ["ads_read"],
    note: "Advanced Access.",
  },
  {
    id: "ads-manage",
    label: "Manage ads campaigns",
    scopes: ["ads_management"],
    note: "Advanced Access.",
  },
  {
    id: "leads",
    label: "Lead Ads retrieval",
    scopes: ["leads_retrieval", "pages_show_list", "pages_read_engagement"],
    note: "leads_retrieval is Advanced Access.",
  },
  {
    id: "catalog",
    label: "Manage product catalog (Commerce)",
    scopes: ["catalog_management", "business_management"],
    note: "Advanced Access.",
  },
  {
    id: "insights",
    label: "Read business insights",
    scopes: ["business_management", "read_insights"],
    note: "Advanced Access.",
  },
];

type ScopeRef = { name: string; purpose: string; review?: "advanced" };

const allScopes: ScopeRef[] = [
  { name: "public_profile", purpose: "Default — name, profile picture, id." },
  { name: "email", purpose: "User's primary email." },
  { name: "pages_show_list", purpose: "List the Facebook Pages the user manages.", review: "advanced" },
  { name: "pages_read_engagement", purpose: "Read post likes, comments, share counts.", review: "advanced" },
  { name: "pages_read_user_content", purpose: "Read content posted by users on the Page.", review: "advanced" },
  { name: "pages_manage_posts", purpose: "Create, edit, delete Page posts.", review: "advanced" },
  { name: "pages_manage_engagement", purpose: "Moderate comments and reactions on the Page.", review: "advanced" },
  { name: "pages_manage_metadata", purpose: "Update Page settings, categories, info.", review: "advanced" },
  { name: "pages_messaging", purpose: "Send and receive Messenger messages.", review: "advanced" },
  { name: "pages_manage_ads", purpose: "Manage ad campaigns owned by the Page.", review: "advanced" },
  { name: "instagram_basic", purpose: "Read basic Instagram Business / Creator info.", review: "advanced" },
  { name: "instagram_content_publish", purpose: "Publish to feed, Reels, Stories, Carousel.", review: "advanced" },
  { name: "instagram_manage_comments", purpose: "Moderate comments on IG posts.", review: "advanced" },
  { name: "instagram_manage_messages", purpose: "Send / receive IG DMs. Restricted-use approval.", review: "advanced" },
  { name: "instagram_manage_insights", purpose: "Read IG account + post insights.", review: "advanced" },
  { name: "threads_basic", purpose: "Read Threads profile and posts.", review: "advanced" },
  { name: "threads_content_publish", purpose: "Publish posts to Threads.", review: "advanced" },
  { name: "threads_read_replies", purpose: "Read replies to user's Threads posts.", review: "advanced" },
  { name: "threads_manage_replies", purpose: "Hide, restrict, or delete replies on Threads.", review: "advanced" },
  { name: "threads_manage_insights", purpose: "Read Threads insights.", review: "advanced" },
  { name: "whatsapp_business_management", purpose: "Manage WABA, phone numbers, templates.", review: "advanced" },
  { name: "whatsapp_business_messaging", purpose: "Send + receive WhatsApp Business messages.", review: "advanced" },
  { name: "ads_read", purpose: "Read Ads campaigns, ad sets, creatives.", review: "advanced" },
  { name: "ads_management", purpose: "Manage Ads campaigns, ad sets, creatives.", review: "advanced" },
  { name: "read_insights", purpose: "Read Business / Page insights." },
  { name: "business_management", purpose: "Manage Business Manager assets." },
  { name: "catalog_management", purpose: "Manage Commerce product catalogs.", review: "advanced" },
  { name: "leads_retrieval", purpose: "Pull Lead Ads form submissions.", review: "advanced" },
];

const exampleAuthorizeUrl = `https://www.facebook.com/v22.0/dialog/oauth
  ?client_id=YOUR_APP_ID
  &redirect_uri=YOUR_REDIRECT
  &state=RANDOM_STATE
  &response_type=code
  &scope=public_profile,email,pages_show_list,pages_manage_posts`;
---

<BaseLayout
  title="Meta OAuth scope checker — Facebook, Instagram, Threads, WhatsApp"
  description="Free Meta OAuth scope checker. Pick what your app does — get the minimum permission set, with App Review (Advanced Access) flags called out."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Meta OAuth scope checker",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Pick Facebook, Instagram, Threads, or WhatsApp actions and see the minimum Meta OAuth scopes required. App Review / Advanced Access flagged on each scope.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">Meta OAuth scope checker.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        Facebook, Instagram, Threads, and WhatsApp all share the same
        permission system. Pick what your app does — we compute the minimum
        scope set and flag which ones need App Review (Advanced Access).
      </p>

      <div class="lmp-scope" data-scope>
        <ul class="list-none p-0 m-0">
          {
            actions.map((a) => (
              <li class="lmp-scope-row">
                <label class="lmp-scope-label">
                  <input
                    type="checkbox"
                    data-scope-action
                    data-scopes={JSON.stringify(a.scopes)}
                    aria-describedby={`note-${a.id}`}
                  />
                  <span class="lmp-scope-text">
                    <span class="font-bold text-[0.92rem]">{a.label}</span>
                    {a.note ? (
                      <span class="lmp-scope-note" id={`note-${a.id}`}>
                        {a.note}
                      </span>
                    ) : null}
                    <span class="lmp-scope-list">{a.scopes.join(" + ")}</span>
                  </span>
                </label>
              </li>
            ))
          }
        </ul>

        <div class="lmp-scope-output">
          <div class="lmp-scope-output-label">
            <span class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
              >Minimum scope param (Meta uses commas, not spaces)</span
            >
            <button
              type="button"
              class="lmp-counter-copy"
              data-scope-copy
              aria-label="Copy scope string">Copy</button
            >
          </div>
          <code class="lmp-scope-out" data-scope-out>—</code>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">In your authorize URL.</h2>
      <Code code={exampleAuthorizeUrl} lang="text" theme="github-dark" />
      <p class="text-text-muted mt-4 text-[0.88rem]">
        Meta uses comma-separated scopes (not space-separated like LinkedIn /
        X). Versions like <code>v22.0</code> in the URL pin the Graph API version —
        use the latest stable one for new flows.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Every Meta scope, with App Review flag.</h2>
      <ul class="list-none p-0 mt-4">
        {
          allScopes.map((s) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <code class="font-mono text-[0.9rem]">{s.name}</code>
                <span
                  class={
                    s.review === "advanced"
                      ? "text-[0.72rem] uppercase tracking-[0.08em] text-accent"
                      : "text-[0.72rem] uppercase tracking-[0.08em] text-text-muted"
                  }
                >
                  {s.review === "advanced" ? "App Review" : "Standard"}
                </span>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{s.purpose}</p>
            </li>
          ))
        }
      </ul>
      <p class="text-text-muted text-[0.85rem] mt-4">
        Standard Access only works for the app's own admins, developers, and
        testers. Anyone else needs the scope to be approved via App Review —
        which is the longest part of getting a Meta integration to production.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Or skip the App Review gauntlet for v1.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code> ships with a single Meta app reviewed for
        the publish + read scopes our customers actually use. Self-host with
        your own Meta app gets the same code path; hosted hands you a working
        Facebook + Instagram + Threads connection without the audit cycle.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="/platforms/instagram">
          Meta on letmepost.dev
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/linkedin-oauth-scope-checker"
          >LinkedIn OAuth checker</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-scope {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-scope-row {
    border-bottom: 1px dashed var(--color-border);
    padding: 0.55rem 0;
  }
  .lmp-scope-row:last-of-type {
    border-bottom: none;
  }
  .lmp-scope-label {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    cursor: pointer;
    align-items: start;
  }
  .lmp-scope-label input {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
  }
  .lmp-scope-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .lmp-scope-note {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .lmp-scope-list {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    padding: 0.15rem 0.4rem;
    align-self: start;
  }
  .lmp-scope-output {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .lmp-scope-output-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .lmp-scope-out {
    display: block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.85rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    word-break: break-all;
    user-select: all;
  }
  .lmp-counter-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }
  .lmp-counter-copy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

<script>
  function setupScope(root: HTMLElement) {
    const checkboxes = Array.from(
      root.querySelectorAll<HTMLInputElement>("[data-scope-action]"),
    );
    const out = root.querySelector<HTMLElement>("[data-scope-out]");
    const copy = root.querySelector<HTMLButtonElement>("[data-scope-copy]");

    function recompute() {
      const set = new Set<string>();
      for (const cb of checkboxes) {
        if (!cb.checked) continue;
        try {
          const list: string[] = JSON.parse(cb.dataset.scopes || "[]");
          for (const s of list) set.add(s);
        } catch {
          /* skip */
        }
      }
      const scopes = Array.from(set);
      // Meta uses comma-separated scopes — different from LinkedIn / X.
      if (out) out.textContent = scopes.length === 0 ? "—" : scopes.join(",");
    }

    checkboxes.forEach((cb) => cb.addEventListener("change", recompute));
    copy?.addEventListener("click", async () => {
      const text = out?.textContent || "";
      if (!text || text === "—") return;
      try {
        await navigator.clipboard.writeText(text);
        copy.textContent = "Copied";
        setTimeout(() => (copy.textContent = "Copy"), 1100);
      } catch {
        /* clipboard blocked */
      }
    });

    recompute();
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>("[data-scope]").forEach(setupScope);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
