---
import BaseLayout from "../layouts/BaseLayout.astro";
import Tape from "../components/Tape.astro";
import Closeout from "../components/Closeout.astro";
---

<BaseLayout
  title="Contact"
  description="How to get in touch with letmepost.dev."
>
  <Tape />

  <header class="page-head" data-sticky-anchor>
    <div class="crumb"><a href="/">letmepost</a> / contact</div>
    <h1 class="page-h1">Contact.</h1>
  </header>

  <hr class="dash" />

  <div class="prose">
      <p>
        letmepost.dev is operated by M/S Rose Creator (trading as letmepost.dev),
        a sole proprietorship based in India. Solo-dev shop. Messages come to a real inbox and get
        real replies.
      </p>

      <h2>Email</h2>
      <p>
        <a href="mailto:support@letmepost.dev">support@letmepost.dev</a> — for
        anything: product questions, privacy, security, bug reports.
      </p>

      <h2>Security disclosures</h2>
      <p>
        Found a vulnerability? Please email the address above with
        <code>[security]</code> in the subject line. Please don't file a public
        GitHub issue for security reports.
      </p>

      <h2>Open source</h2>
      <p>
        <a
          href="https://github.com/rosekamallove/letmepost.dev"
          rel="noopener"
          target="_blank"
          data-analytics-event="external.github_clicked"
          data-analytics-props='{"from_page":"contact","location":"contact-body"}'
        >github.com/rosekamallove/letmepost.dev</a
        > — file issues, send PRs, read the roadmap.
      </p>

      <h2>Business address</h2>
      <p style="color: var(--r-dim);">
        Registered address is disclosed on request for billing / platform
        verification purposes. Email us.
      </p>
  </div>

  <hr class="double" />

  <Closeout codeLine="000 LMP CONTACT · 2026-05-23" />
  <Tape bottom />
</BaseLayout>
