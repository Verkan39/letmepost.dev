---
import Logo from "./Logo.astro";
import { Icon } from "astro-icon/components";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="border-b border-border bg-transparent">
  <div class="container flex items-center justify-between h-[52px]">
    <Logo />
    <nav aria-label="Primary" class="flex items-center gap-5 text-[0.85rem]">
      <a
        href="/#platforms"
        class="no-underline text-text-muted transition-colors hover:text-accent max-[520px]:hidden"
        >Platforms</a
      >
      <a
        href="/status"
        class="no-underline text-text-muted transition-colors hover:text-accent max-[520px]:hidden"
        >Status</a
      >
      <a
        class="inline-flex items-center gap-1 no-underline text-text-muted transition-colors hover:text-accent"
        href="https://github.com/rosekamallove/letmepost.dev"
        rel="noopener noreferrer"
        target="_blank"
      >
        GitHub
        <Icon name="ph:arrow-up-right" width={12} height={12} />
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
