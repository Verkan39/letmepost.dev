---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Tape from "../../components/Tape.astro";
import Closeout from "../../components/Closeout.astro";
import { APIS } from "../../data/platforms.ts";

/**
 * API index — the three surfaces in v1: Publishing, Media, Webhooks.
 * Each row links into /api/[slug] for the long-form pitch + sample.
 * Single-column ledger-style because three rows is a balanced shape.
 */
---

<BaseLayout
  title="API surfaces"
  description="The v1 API surface. Publishing, media uploads, HMAC-signed webhooks. One POST endpoint, eight platforms, idempotency by default."
>
  <Tape />

  <header class="page-head" data-sticky-anchor>
    <div class="crumb"><a href="/">letmepost</a> / api</div>
    <h1 class="page-h1">The API surface.</h1>
    <p class="lede">
      Three surfaces in v1. <b>Publishing</b> is the heart of it, <b>Media</b> uploads bytes once
      and references them by id, <b>Webhooks</b> push state changes back to you. Same auth, same
      error envelope, same idempotency rules across the whole API.
    </p>
  </header>

  <hr class="dash" />

  <section class="section" style="padding-top: 0;">
    <h2 class="h-caps">API SURFACES</h2>
    <div class="subtitle center">three endpoints, one consistent shape</div>

    <div class="api-list">
      {
        APIS.map((api) => (
          <a href={`/api/${api.slug}`} class="api-row">
            <span class="glyph">
              <Icon name={`ph:${api.icon}`} width={20} height={20} />
            </span>
            <div class="body">
              <div class="head-row">
                <div class="name">{api.name}</div>
                <span class="st live">{api.status === "live" ? "live" : api.status}</span>
              </div>
              <p class="tagline">{api.tagline}</p>
              <p class="pitch">{api.pitch}</p>
              <p class="detail">{api.detail}</p>
            </div>
            <span class="arrow">→</span>
          </a>
        ))
      }
    </div>
  </section>

  <hr class="dash" />

  <section class="section">
    <h2 class="h-mixed">One auth, one error shape, one retry contract.</h2>
    <p class="subtitle left">stable across every endpoint</p>
    <p class="lede">
      Same <code>Authorization: Bearer lmp_live_…</code> on every call. Same <code>Idempotency-Key</code>
      semantics on every write. Same failure envelope (stable code + rule + remediation + request id)
      on every non-2xx. Build against one endpoint and the others feel familiar in minutes.
    </p>
    <div class="ctas">
      <a class="btn" href="https://docs.letmepost.dev/api-reference">FULL REFERENCE ↗</a>
      <a class="btn" href="/platforms">SUPPORTED PLATFORMS →</a>
    </div>
  </section>

  <hr class="double" />

  <Closeout codeLine={`000 LMP API · ${APIS.length} / ${APIS.length}`} />
  <Tape bottom />

  {/* Right rail — API notes */}
  <aside class="marg" aria-label="Notes" slot="rightRail">
    <div class="note">
      <span class="tag">Auth</span>
      Bearer token on every call. Prefixed <code>lmp_live_</code> or <code>lmp_test_</code>.
      Only the last 4 chars are stored after creation. Rotate freely.
    </div>
    <div class="note">
      <span class="tag">Idempotency</span>
      Every write accepts <b>Idempotency-Key</b>. Retries return the cached response for 24h.
      Conflicting bodies surface as <code>idempotency_conflict</code> (HTTP 409).
    </div>
    <div class="note">
      <span class="tag">Errors</span>
      Eleven stable codes, each with its own docs page. Plus the rule id that fired,
      the pinned platform version, and a remediation hint.
    </div>
    <div class="note">
      <span class="tag">Versioning</span>
      We pin upstream platform versions for you. <code>GET /v1/platform-versions</code> is public,
      <code>version.deprecated</code> webhook fires before we cut over.
    </div>
    <div class="note">
      <span class="tag">Reference</span>
      Full OpenAPI 3.1 spec at <code>docs.letmepost.dev/api-reference</code>. SDKs (TypeScript today,
      Python + Go in flight) generated from the spec.
    </div>
  </aside>
</BaseLayout>

<style is:global>
  /* ── API index only ──────────────────────────────────── */

  .api-list {
    border: 1px solid var(--r-line);
    margin: 14px 0 8px;
  }
  .api-row {
    padding: 20px 22px 18px;
    background: var(--r-paper);
    display: grid; grid-template-columns: 36px 1fr 24px;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px dashed var(--r-very);
    transition: background 100ms;
    align-items: start;
  }
  .api-row:last-child { border-bottom: 0; }
  .api-row:hover { background: var(--r-accent-soft); }
  .api-row .glyph {
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--r-ink);
    border: 1px solid var(--r-line);
    background: var(--r-paper-deep);
  }
  .api-row .body { min-width: 0; }
  .api-row .head-row {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 4px;
  }
  .api-row .name {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 15px; line-height: 1.3;
    color: var(--r-ink);
  }
  .api-row .st {
    font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase;
    padding: 2px 7px; border: 1px solid var(--r-line);
    color: var(--r-dim); line-height: 1;
  }
  .api-row .st.live { color: var(--r-accent); border-color: var(--r-accent); }
  .api-row .tagline {
    font-size: 12px; line-height: 1.5; margin: 0 0 8px;
    color: var(--r-very); letter-spacing: 0.04em;
  }
  .api-row .pitch {
    font-size: 13px; line-height: 1.6; margin: 0 0 8px;
    color: var(--r-dim);
  }
  .api-row .detail {
    font-size: 10.5px; line-height: 1.5; margin: 0;
    color: var(--r-very);
  }
  .api-row .arrow {
    align-self: center;
    color: var(--r-very); font-size: 16px;
    transition: color 100ms, transform 100ms;
    text-align: right;
  }
  .api-row:hover .arrow { color: var(--r-accent); transform: translateX(2px); }
</style>
