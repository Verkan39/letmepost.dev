---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Tape from "../components/Tape.astro";
import Closeout from "../components/Closeout.astro";
import { PLATFORMS } from "../data/platforms.ts";

/**
 * Landing page — receipt direction. Pixel-mirrors design/letmepost.html.
 * Brand head with stampbox, code-block tabs (curl/ts/py), itemized
 * `WHAT YOU GET`, platform status, error envelope, MCP teaser, tariff
 * sheet, fine-print FAQ, and a final centered CTA.
 *
 * Voice rules: no em dashes; no banned adjectives; honest status only
 * (Bluesky/X/Pinterest live, four Meta+LinkedIn in review, TikTok planned).
 */

// Status mapping — backend PLATFORM_STATE ("live" | "pending" | "planned" |
// "trial") to the marketing-side labels the design uses.
function statusLabel(s: string): "live" | "in-review" | "planned" {
  if (s === "live" || s === "trial") return "live";
  if (s === "pending") return "in-review";
  return "planned";
}

// Per-platform tagline shown under the name on the status list.
const detail: Record<string, string> = {
  bluesky: "AT Proto · 300 graphemes",
  twitter: "v2 API · 280 graphemes",
  pinterest: "v5 · image + video pins",
  instagram: "Meta App Review · day 24 / ~56",
  facebook: "Meta App Review · day 24 / ~56",
  threads: "Meta App Review · day 24 / ~56",
  linkedin: "MDP · day 12 / ~84",
  youtube: "Data API v3 · CASA-gated",
};

// Phosphor names mirror PlatformIcon's mapping, kept inline so the
// landing's tight column doesn't pull in the wrapper component.
const phosphor: Record<string, string> = {
  bluesky: "ph:butterfly",
  twitter: "ph:x-logo",
  pinterest: "ph:pinterest-logo",
  instagram: "ph:instagram-logo",
  facebook: "ph:facebook-logo",
  threads: "ph:threads-logo",
  linkedin: "ph:linkedin-logo",
  youtube: "ph:youtube-logo",
  tiktok: "ph:tiktok-logo",
};

// Drop YouTube per voice rule ("Do not list YouTube"), and tack on
// TikTok as a marketing-only `planned` row.
const platformRows = [
  ...PLATFORMS.filter((p) => p.slug !== "youtube").map((p) => ({
    slug: p.slug,
    name: p.name,
    detail: detail[p.slug] ?? "",
    status: statusLabel(p.status),
  })),
  {
    slug: "tiktok",
    name: "TikTok",
    detail: "Publisher in build · v2",
    status: "planned" as const,
  },
];

const faqs = [
  {
    q: "What actually works today?",
    a: "Bluesky, X, and Pinterest are live end-to-end. You can connect an account, send a post, attach images or video, and get a webhook back. Instagram, Facebook, Threads, and LinkedIn are in platform review and flip on the day approval clears.",
  },
  {
    q: "Why another social media API?",
    a: "Because the existing ones fail silently, charge per-profile, and break every six months when a platform sunsets a version. This one fails loudly, charges per-org, and pins the version internally. Apache 2.0 from day one.",
  },
  {
    q: "How much does it cost?",
    a: "Free during alpha. When billing turns on, it's flat-rate per org with a real free tier. Self-host stays free forever.",
  },
  {
    q: "Is it really open source?",
    a: "Apache 2.0. The hosted SaaS runs the exact same image you can self-host. No feature gate, no open-core trick.",
  },
  {
    q: "Do I have to handle Meta App Review myself?",
    a: "No. Connect through our OAuth flow and you publish through our reviewed app. Self-hosters can BYO Meta app if they want their own reviewer-of-record.",
  },
  {
    q: "Can my AI agent drive this?",
    a: 'Yes. Native MCP server at <code>api.letmepost.dev/mcp</code> and a stdio binary on npm. See the agents landing for the full tool surface.',
  },
];

const stripHtml = (html: string) => html.replace(/<[^>]+>/g, "");
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: stripHtml(f.a) },
  })),
};

const curlSample = `curl -X POST https://api.letmepost.dev/v1/posts \\
  -H "Authorization: Bearer $LMP_KEY" \\
  -H "Idempotency-Key: $(uuidgen)" \\
  -H "Content-Type: application/json" \\
  -d '{
    "targets": [
      { "platform": "bluesky" },
      { "platform": "x" },
      { "platform": "pinterest" }
    ],
    "text": "Shipped multi-target publishing today."
  }'`;

const tsSample = `import { Letmepost } from "@letmepost/sdk";

const lmp = new Letmepost({ apiKey: process.env.LMP_KEY });

const result = await lmp.posts.create({
  targets: [
    { platform: "bluesky" },
    { platform: "x" },
    { platform: "pinterest" },
  ],
  text: "Shipped multi-target publishing today.",
  // Idempotency-Key stamped automatically.
});

// Per-target outcomes, never a single ambiguous boolean.
for (const r of result.targets) {
  console.log(r.platform, r.status, r.url ?? r.error?.code);
}`;

const pySample = `from letmepost import Letmepost

lmp = Letmepost(api_key=os.environ["LMP_KEY"])

result = lmp.posts.create(
    targets=[
        {"platform": "bluesky"},
        {"platform": "x"},
        {"platform": "pinterest"},
    ],
    text="Shipped multi-target publishing today.",
)

for r in result.targets:
    print(r.platform, r.status, r.url or r.error.code)`;
---

<BaseLayout
  title="letmepost.dev"
  description="One POST. Eight platforms. Zero days in Meta's review queue. Apache 2.0 social publishing API with preflight validation, idempotency, and a native MCP server."
  jsonLd={[faqJsonLd]}
>
  <Tape />

  {/* HEAD — centered brand + ASCII banner + PAID IN FULL stamp + meta grid */}
  <div class="head">
    <div class="brand-mark">LETMEPOST</div>
    <div class="url-line">letmepost.dev · est. 2026 · apache-2.0</div>

    <div class="ascii">+-------------------------------------+
|        OPEN SOURCE · ALPHA          |
+-------------------------------------+</div>

    <div class="stampbox" aria-hidden="true">
      <div class="l1">PLATFORM REVIEW</div>
      <div class="l2">PAID IN FULL</div>
      <div class="l3">SO YOU DON'T HAVE TO</div>
    </div>

    <div class="meta-grid">
      <div><span class="k">RECEIPT №</span><span class="v">000-LMP-0001</span></div>
      <div><span class="k">CASHIER</span><span class="v">rose</span></div>
      <div><span class="k">DATE</span><span class="v">2026-05-22</span></div>
      <div><span class="k">TERMINAL</span><span class="v">/v1/posts</span></div>
    </div>
  </div>

  <hr class="solid" />

  {/* HERO */}
  <section style="text-align: left;" data-sticky-anchor>
    <h1 class="hero-h1">
      One <span class="under">POST</span>. Eight platforms.
      <br />
      <span class="acc">Zero days</span> in Meta's review queue.
    </h1>

    <p class="lede">
      <b>letmepost</b> is the social-publishing API your backend has been hand-rolling.
      One <code>POST /v1/posts</code> fans out to Bluesky, X, Pinterest, and the
      four Meta + LinkedIn properties the day each review clears.
      We sit in the developer-portal queue so you don't have to. <b>That's the trade.</b>
    </p>

    <div class="ctas">
      <a
        href="https://dashboard.letmepost.dev"
        class="btn pri"
        data-analytics-event="cta.clicked"
        data-analytics-props='{"location":"hero","target":"dashboard","page":"home","label":"Start free"}'
      >START FREE →</a>
      <a
        href="https://docs.letmepost.dev/quickstart"
        class="btn"
        data-analytics-event="cta.clicked"
        data-analytics-props='{"location":"hero-secondary","target":"docs","page":"home","label":"Quickstart"}'
      >90-SEC QUICKSTART</a>
    </div>
    <div class="reassurance">
      No credit card · Free during alpha · Self-host free forever
    </div>
  </section>

  <hr class="dash" />

  {/* SHOW THE CODE */}
  <section class="section">
    <h2 class="h-caps">SHOW THE CODE</h2>
    <div class="subtitle center">$ one terminal session</div>

    <div
      class="code-block"
      data-tabs
      data-files='{"curl":"publish.sh","ts":"publish.ts","py":"publish.py"}'
    >
      <div class="head-bar">
        <div class="tabs" role="tablist">
          <button type="button" class="tab on" data-tab="curl" role="tab">curl</button>
          <button type="button" class="tab" data-tab="ts" role="tab">typescript</button>
          <button type="button" class="tab" data-tab="py" role="tab">python</button>
        </div>
        <span class="file">publish.sh</span>
      </div>
      <pre data-pane="curl">{curlSample}</pre>
      <pre data-pane="ts" hidden>{tsSample}</pre>
      <pre data-pane="py" hidden>{pySample}</pre>
    </div>

    <p class="lede" style="margin-top: 12px;">
      The shape is identical for every platform. The response is a per-target envelope so you
      never have to guess whether four succeeded and one didn't. Idempotency keys are stamped
      automatically by the SDKs; replays return the original response for 24 hours.
    </p>
  </section>

  <hr class="dash" />

  {/* WHAT YOU GET */}
  <section class="section">
    <h2 class="h-caps">WHAT YOU GET</h2>
    <div class="subtitle center">priced in time you don't spend</div>

    <div class="items">
      <div class="item">
        <span class="qty">1×</span>
        <span class="desc">
          Multi-target publish endpoint
          <span class="sub">POST /v1/posts, fans out to every connected account in one call</span>
        </span>
        <span class="val">~ 4 wk</span>
      </div>
      <div class="item">
        <span class="qty">3×</span>
        <span class="desc">
          Meta App Review absorbed
          <span class="sub">Instagram + Facebook + Threads, one shared review, our app of record</span>
        </span>
        <span class="val">~ 8 wk</span>
      </div>
      <div class="item">
        <span class="qty">1×</span>
        <span class="desc">
          LinkedIn Marketing Developer Platform review
          <span class="sub">submitted, version-pinned, sunset-monitored</span>
        </span>
        <span class="val">~12 wk</span>
      </div>
      <div class="item">
        <span class="qty">80×</span>
        <span class="desc">
          Preflight rules
          <span class="sub">char-count, media-format, audit-state, URN patterns. One docs page each.</span>
        </span>
        <span class="val">~ 6 wk</span>
      </div>
      <div class="item">
        <span class="qty">7×</span>
        <span class="desc">
          Platform versions pinned for you
          <span class="sub">we own the LinkedIn-sunsets-every-six-weeks problem</span>
        </span>
        <span class="val">∞</span>
      </div>
    </div>

    <div class="total">
      <span>TIME RECLAIMED</span>
      <span class="v">≈ 6 months</span>
    </div>
  </section>

  <hr class="dash" />

  {/* PLATFORM STATUS */}
  <section class="section">
    <h2 class="h-caps">PLATFORM STATUS</h2>
    <div class="subtitle center">as of 2026-05-23</div>

    <div class="platforms">
      {
        platformRows.map((p) => (
          <div class="row">
            <span class="pglyph">
              <Icon name={phosphor[p.slug] ?? "ph:circle"} width={18} height={18} />
            </span>
            <span class="nm">
              {p.name}
              <span class="h">{p.detail}</span>
            </span>
            <span class={`st ${p.status}`}>{p.status === "in-review" ? "in review" : p.status}</span>
          </div>
        ))
      }
    </div>

    <p class="lede" style="margin-top: 14px;">
      Eight platforms in v1. Twenty plus in scope. Each platform review is a separate weeks-to-months
      gauntlet we run on your behalf.
    </p>
  </section>

  <hr class="dash" />

  {/* ANATOMY OF A FAILURE */}
  <section class="section">
    <h2 class="h-caps">ANATOMY OF A FAILURE</h2>
    <div class="subtitle center">structured every time, no empty 500s</div>

    <div class="envelope">
      <div class="head-bar">
        <span>HTTP/1.1 422 Unprocessable Entity</span>
        <span>application/json</span>
      </div>
      <div class="body">
        <div class="field"><span class="k">code</span><span class="v b">preflight_failed</span></div>
        <div class="field"><span class="k">rule</span><span class="v acc b">bluesky.text.max_graphemes</span></div>
        <div class="field"><span class="k">platform</span><span class="v">bluesky</span></div>
        <div class="field"><span class="k">platform_version</span><span class="v">atproto-2026-04</span></div>
        <div class="field"><span class="k">message</span><span class="v">Text is 312 graphemes; Bluesky allows at most 300.</span></div>
        <div class="field"><span class="k">remediation</span><span class="v">Trim the text to 300 graphemes or fewer.</span></div>
        <div class="field"><span class="k">doc_url</span><span class="v acc">docs.letmepost.dev/errors/preflight_failed</span></div>
        <div class="field"><span class="k">rule_url</span><span class="v acc">docs.letmepost.dev/preflight/bluesky-text-max_graphemes</span></div>
        <div class="field"><span class="k">request_id</span><span class="v">req_01HXY7Z8K9MNB1P2QR3STVW</span></div>
        <div class="field"><span class="k">trace_id</span><span class="v">01jb7q9c4e5f6g7h8i9k0lm1np</span></div>
      </div>
    </div>

    <p class="lede" style="margin-top: 12px;">
      Every non-2xx carries the same shape. Greppable, actionable, linkable.
      Eleven stable error codes, each with its own docs page.
    </p>
  </section>

  <hr class="dash" />

  {/* For agents */}
  <section class="section">
    <h2 class="h-mixed">For agents, letmepost speaks <span class="acc">MCP</span>.</h2>
    <p class="subtitle left">a hosted server + a stdio binary on npm</p>

    <div class="mcp">
      <div>
        <p style="margin-top: 0;">A hosted MCP server at <code>api.letmepost.dev/mcp</code> (Streamable HTTP, stateless) and a stdio binary on npm. Twenty-one tools, autogenerated from OpenAPI. Same auth as the HTTP API. Claude, Cursor, Claude Code, opencode, any MCP-aware client drives the full surface.</p>
        <p><a href="/agents">Read the agents landing →</a></p>
      </div>
      <pre class="config">{`{
  "mcpServers": {
    "letmepost": {
      "command": "npx",
      "args":    ["@letmepost/mcp@latest"],
      "env":     { "LMP_API_KEY": "lmp_live_…" }
    }
  }
}`}</pre>
    </div>
  </section>

  <hr class="dash" />

  {/* Tariff sheet */}
  <section class="section">
    <h2 class="h-mixed">Tariff sheet, per org, <span class="acc">never per profile.</span></h2>
    <p class="subtitle left">flat-rate · self-host stays free forever</p>

    <table class="tariff">
      <thead>
        <tr>
          <th>Tier</th>
          <th>Posts / mo</th>
          <th class="r">Price</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="tier">Free<span class="who">Personal · single-platform automations</span></td>
          <td>50</td>
          <td class="r"><span class="price">$0</span></td>
        </tr>
        <tr class="hi">
          <td class="tier">Pro <span class="stars">★</span><span class="who">Indie SaaS · agencies under 50 clients</span></td>
          <td>5,000</td>
          <td class="r"><span class="price">$79</span></td>
        </tr>
        <tr>
          <td class="tier">Business<span class="who">Embedded social · uptime SLA · white-label OAuth</span></td>
          <td>25,000</td>
          <td class="r"><span class="price">$299</span></td>
        </tr>
        <tr>
          <td class="tier">Self-host<span class="who">Same image · BYO Postgres + Redis · Apache 2.0</span></td>
          <td>∞</td>
          <td class="r"><span class="price">$0</span></td>
        </tr>
      </tbody>
    </table>
    <p class="lede" style="margin-top: 8px;">
      Profiles, accounts, team members, webhook endpoints, API keys: <b>all free</b>.
      Hard caps with 80% + 100% webhooks. No surprise overages.
      <a href="/pricing">Full pricing →</a>
    </p>
  </section>

  <hr class="dash" />

  {/* Fine print */}
  <section class="section">
    <h2 class="h-mixed">Fine print.</h2>
    <p class="subtitle left">questions you'd ask in a code review</p>

    <div class="faq">
      {
        faqs.map((f) => (
          <div class="item-q">
            <p class="q">{f.q}</p>
            <p class="a" set:html={f.a} />
          </div>
        ))
      }
    </div>
  </section>

  <hr class="double" />

  {/* FINAL CTA */}
  <section class="section" style="text-align: center;">
    <h2 class="h-caps" style="margin-bottom: 8px;">KICK THE TIRES.</h2>
    <p class="lede" style="margin: 6px auto 18px; text-align: center;">
      Star the repo. Send your first post in ninety seconds.<br />
      File an issue when something's weird. We're building in the open.
    </p>
    <div class="ctas" style="justify-content: center;">
      <a
        href="https://dashboard.letmepost.dev"
        class="btn pri"
        data-analytics-event="cta.clicked"
        data-analytics-props='{"location":"home-final","target":"dashboard","page":"home","label":"Start free"}'
      >START FREE →</a>
      <a
        href="https://github.com/letmepost/letmepost.dev"
        class="btn"
        target="_blank"
        rel="noopener"
        data-analytics-event="external.github_clicked"
        data-analytics-props='{"from_page":"home","location":"home-final"}'
      >GITHUB ↗</a>
    </div>
  </section>

  <Closeout
    codeLine="000 LMP 0001 · 2026-05-23 · 14:21Z"
    links={[
      { href: "https://docs.letmepost.dev", label: "docs" },
      { href: "https://github.com/letmepost/letmepost.dev", label: "github" },
      { href: "https://status.letmepost.dev", label: "status" },
      { href: "/privacy", label: "privacy" },
      { href: "/terms", label: "terms" },
    ]}
  />

  <Tape bottom />

  {/* Right rail — technical annotations */}
  <aside class="marg" aria-label="Technical notes" slot="rightRail">
    <div class="note">
      <span class="tag">Method</span>
      Every <b>POST</b> runs through 80 preflight rules locally before the platform sees the request. The rule that fires is named on the failure envelope.
    </div>
    <div class="note">
      <span class="tag">Idempotency</span>
      Every write accepts <b>Idempotency-Key</b>. Retries return the cached response for 24h. Conflicting bodies surface as <code>idempotency_conflict</code> (HTTP 409).
    </div>
    <div class="note">
      <span class="tag">Webhooks</span>
      HMAC-SHA256 signed.<br />
      <b>post.queued</b>, post.published, post.failed, post.rejected, <b>token.expiring</b>, token.revoked, version.deprecated, quota.warning.
    </div>
    <div class="note">
      <span class="tag">Errors</span>
      Eleven stable codes, each with its own docs page. Plus the rule id that fired, the pinned platform version, and a remediation hint.
    </div>
    <div class="note">
      <span class="tag">Self-host</span>
      <code>docker compose up</code> against your own Postgres + Redis. BYO platform credentials. Same image as hosted.
    </div>
    <div class="note">
      <span class="tag">Contact</span>
      File an issue on the repo or email <b>rose@letmepost.dev</b>. There's no priority-routing tier because there's only one person to route to.
    </div>
  </aside>
</BaseLayout>
