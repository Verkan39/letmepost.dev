---
/**
 * First-touch attribution capture + propagation to dashboard CTAs.
 *
 * The marketing site and the dashboard live on different origins
 * (letmepost.dev vs dashboard.letmepost.dev), so localStorage on this
 * origin can't be read on the dashboard. We bridge the gap by appending
 * the captured fields as query params on every link to the dashboard;
 * the dashboard's `captureAttribution()` reads them from `window.location`
 * on first arrival and stores into its own localStorage.
 *
 * Rules:
 *   - First-touch: never overwrite an already-captured attribution.
 *   - Lightweight: pure inline JS, no imports. Adds <2KB to first load.
 *   - Defensive: handles localStorage failures (Safari private mode,
 *     cookie-blocker extensions) silently.
 *   - Re-binds on Astro view transitions so soft nav doesn't drop the
 *     rewritten hrefs after a page swap.
 */
---

<script is:inline>
  (function () {
    var STORAGE_KEY = "lmp_attribution";
    var DASHBOARD_HOST = "dashboard.letmepost.dev";
    var UTM_PASS_KEYS = [
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "utm_content",
      "utm_term",
    ];

    function safeGet() {
      try {
        var raw = window.localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" ? parsed : null;
      } catch (e) {
        return null;
      }
    }

    function safeSet(value) {
      try {
        window.localStorage.setItem(STORAGE_KEY, JSON.stringify(value));
      } catch (e) {
        // ignore — storage unavailable
      }
    }

    function captureFromUrl() {
      var existing = safeGet();
      if (existing && (existing.signupSource || existing.signupReferrer)) {
        return existing;
      }
      var search = new URLSearchParams(window.location.search);
      var utmSource = search.get("utm_source") || "";
      var utmMedium = search.get("utm_medium") || "";
      var utmCampaign = search.get("utm_campaign") || "";
      var utmContent = search.get("utm_content") || "";
      var utmTerm = search.get("utm_term") || "";
      var referrer = document.referrer || "";
      var landingPath = window.location.pathname || "";

      // No useful signal to remember — let the next visit try again rather
      // than poisoning the cache with an empty record.
      if (!utmSource && !referrer) return null;

      var record = {
        signupUtmSource: utmSource || undefined,
        signupUtmMedium: utmMedium || undefined,
        signupUtmCampaign: utmCampaign || undefined,
        signupUtmContent: utmContent || undefined,
        signupUtmTerm: utmTerm || undefined,
        signupReferrer: referrer || undefined,
        signupLandingPath: landingPath || undefined,
        // Mirror utm_source as the high-level bucket. The dashboard
        // re-derives from referrer if no utm_source is present, so we
        // don't try to do that classification here — pass the raw data
        // and let one canonical resolver live in `attribution.ts`.
        signupSource: utmSource || undefined,
      };
      safeSet(record);
      return record;
    }

    function buildDashboardSearch(attribution, currentSearch) {
      // Carry forward any UTM params on the current URL so the dashboard
      // sees them even if attribution was stored on an earlier visit
      // (e.g. user landed via UTM, browsed for 5 min, then clicked CTA).
      var params = new URLSearchParams();
      UTM_PASS_KEYS.forEach(function (key) {
        var fromCurrent = currentSearch.get(key);
        if (fromCurrent) params.set(key, fromCurrent);
      });
      if (attribution) {
        if (attribution.signupUtmSource && !params.has("utm_source"))
          params.set("utm_source", attribution.signupUtmSource);
        if (attribution.signupUtmMedium && !params.has("utm_medium"))
          params.set("utm_medium", attribution.signupUtmMedium);
        if (attribution.signupUtmCampaign && !params.has("utm_campaign"))
          params.set("utm_campaign", attribution.signupUtmCampaign);
        if (attribution.signupUtmContent && !params.has("utm_content"))
          params.set("utm_content", attribution.signupUtmContent);
        if (attribution.signupUtmTerm && !params.has("utm_term"))
          params.set("utm_term", attribution.signupUtmTerm);
        if (attribution.signupReferrer)
          params.set("lmp_referrer", attribution.signupReferrer);
        if (attribution.signupLandingPath)
          params.set("lmp_landing_path", attribution.signupLandingPath);
      }
      return params;
    }

    function rewriteDashboardLinks() {
      var attribution = safeGet();
      var currentSearch = new URLSearchParams(window.location.search);
      var newParams = buildDashboardSearch(attribution, currentSearch);
      if (newParams.toString() === "") return; // nothing to add

      var anchors = document.querySelectorAll(
        'a[href*="' + DASHBOARD_HOST + '"]',
      );
      anchors.forEach(function (a) {
        // Skip if we've already stamped this anchor — view transitions
        // may re-run this fn and we don't want compounding params.
        if (a.getAttribute("data-lmp-attr") === "1") return;
        try {
          var url = new URL(a.href);
          newParams.forEach(function (value, key) {
            if (!url.searchParams.has(key)) {
              url.searchParams.set(key, value);
            }
          });
          a.href = url.toString();
          a.setAttribute("data-lmp-attr", "1");
        } catch (e) {
          // anchor with a malformed href — ignore
        }
      });
    }

    function setup() {
      captureFromUrl();
      rewriteDashboardLinks();
    }

    setup();
    document.addEventListener("astro:page-load", setup);
  })();
</script>
