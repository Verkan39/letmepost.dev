---
import { Icon } from "astro-icon/components";

// Phosphor icon names for each platform. Bluesky isn't in Phosphor's brand
// set, so it falls through to `butterfly` (their actual brand mark is one).
// Accept both the backend Platform enum slugs and a handful of
// marketing-only aliases ("x" predates the rename). `twitter` resolves
// to the same icon as `x`.
type PlatformSlug =
  | "bluesky"
  | "linkedin"
  | "x"
  | "twitter"
  | "instagram"
  | "facebook"
  | "threads"
  | "youtube"
  | "tiktok"
  | "pinterest";

interface Props {
  /**
   * Accepted as a wide string so callers passing data from `PLATFORMS`
   * (whose slug is `string`) compile without a cast. Unknown slugs fall
   * back to a neutral icon — caller sees nothing rendered if the data
   * file drifts. Caught at integration time, not build.
   */
  platform: PlatformSlug | string;
  size?: number;
  class?: string;
}

const { platform, size = 16, class: className = "" } = Astro.props;

const phosphorName: Record<string, string> = {
  bluesky: "ph:butterfly",
  linkedin: "ph:linkedin-logo",
  x: "ph:x-logo",
  twitter: "ph:x-logo",
  instagram: "ph:instagram-logo",
  facebook: "ph:facebook-logo",
  threads: "ph:threads-logo",
  youtube: "ph:youtube-logo",
  tiktok: "ph:tiktok-logo",
  pinterest: "ph:pinterest-logo",
};
---

<Icon
  name={phosphorName[platform] ?? "ph:circle"}
  width={size}
  height={size}
  class={`shrink-0 text-text-muted transition-colors ${className}`}
/>
