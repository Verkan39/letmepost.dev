---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const presets = [
  { expr: "* * * * *", label: "every minute" },
  { expr: "*/5 * * * *", label: "every 5 minutes" },
  { expr: "*/15 * * * *", label: "every 15 minutes" },
  { expr: "0 * * * *", label: "hourly" },
  { expr: "0 9 * * *", label: "daily at 9:00" },
  { expr: "0 9 * * 1-5", label: "weekdays at 9:00" },
  { expr: "0 18 * * 5", label: "Fridays at 18:00" },
  { expr: "0 0 1 * *", label: "1st of month at midnight" },
  { expr: "0 0 * * 0", label: "Sundays at midnight" },
  { expr: "30 8 1 1,4,7,10 *", label: "quarterly (Jan/Apr/Jul/Oct 1st 08:30)" },
];

const referenceFields = [
  { label: "Minute", range: "0–59" },
  { label: "Hour", range: "0–23" },
  { label: "Day of month", range: "1–31" },
  { label: "Month", range: "1–12" },
  { label: "Day of week", range: "0–6 (Sun = 0)" },
];

const referenceSyntax = [
  { sym: "*", body: "Any value." },
  { sym: "5", body: "Specific value." },
  { sym: "1,3,5", body: "List of values." },
  { sym: "1-5", body: "Range." },
  { sym: "*/5", body: "Step — every 5 starting at 0." },
  { sym: "0-30/5", body: "Step within a range." },
];
---

<BaseLayout
  title="Cron expression builder + tester"
  description="Free cron expression builder. Type or pick a preset, see the next 5 fire times and a plain-English description. Validates standard 5-field cron, no server roundtrips."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Cron expression builder",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Build and test 5-field cron expressions. Live next-fire-time preview, plain-English description, and presets for common schedules.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">Cron expression builder.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        Type a 5-field cron expression. We show the plain-English description
        and the next 5 fire times. Times use your local browser timezone —
        adjust your scheduler's TZ env var to match.
      </p>

      <div class="lmp-cron" data-cron>
        <label class="lmp-cron-field">
          <span class="lmp-cron-label">Expression</span>
          <input
            type="text"
            class="lmp-cron-input"
            placeholder="*/5 * * * *"
            value="0 9 * * 1-5"
            data-cron-input
            spellcheck="false"
            autocapitalize="none"
          />
        </label>

        <div class="lmp-cron-presets">
          <span
            class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted mr-2"
            >Presets</span
          >
          {
            presets.map((p) => (
              <button
                type="button"
                class="lmp-cron-preset"
                data-cron-preset={p.expr}
                title={p.label}
              >
                {p.label}
              </button>
            ))
          }
        </div>

        <div class="lmp-cron-result">
          <div class="lmp-cron-result-row">
            <span
              class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
              >Description</span
            >
            <span class="lmp-cron-desc" data-cron-desc>—</span>
          </div>

          <div class="lmp-cron-result-row" data-cron-error-row hidden>
            <span
              class="text-[0.72rem] uppercase tracking-[0.1em] text-error"
              >Error</span
            >
            <span class="lmp-cron-error" data-cron-error>—</span>
          </div>

          <div class="lmp-cron-result-row">
            <span
              class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
              >Next 5 fires (browser timezone)</span
            >
            <ol class="lmp-cron-next" data-cron-next></ol>
          </div>

          <div class="lmp-cron-tz" data-cron-tz>—</div>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Cron field reference.</h2>
      <ul class="list-none p-0 m-0 grid grid-cols-1 sm:grid-cols-2 gap-2">
        {
          referenceFields.map((f, i) => (
            <li class="border border-border p-3">
              <div class="flex justify-between items-baseline gap-3">
                <span class="font-bold text-[0.92rem]">
                  Field {i + 1} · {f.label}
                </span>
                <code class="font-mono text-[0.78rem] text-accent">
                  {f.range}
                </code>
              </div>
            </li>
          ))
        }
      </ul>

      <h3 class="mt-8 mb-3">Syntax.</h3>
      <ul class="list-none p-0 m-0 grid grid-cols-1 sm:grid-cols-2 gap-2">
        {
          referenceSyntax.map((s) => (
            <li class="border border-border p-3">
              <div class="flex justify-between items-baseline gap-3">
                <code class="font-mono text-[0.92rem] text-accent">
                  {s.sym}
                </code>
                <span class="text-text-muted text-[0.85rem]">{s.body}</span>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">A note on day-of-month vs day-of-week.</h2>
      <p class="text-text-muted">
        Standard cron has a quirk: when both day-of-month and day-of-week are
        restricted (neither is <code>*</code>), the schedule fires when
        <em>either</em> matches, not both. So <code>0 0 13 * 5</code> fires on
        every Friday <em>and</em> the 13th. Most people get this wrong; this
        tester respects the OR semantics so what you see is what cron will
        actually do.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Schedule posts without writing cron.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code> takes <code>{`{ "scheduledAt": "<ISO 8601>" }`}</code>
        on any post. Run it under your own scheduler with a real cron, or
        let our queue handle the timing — either path uses the same API.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="https://docs.letmepost.dev/quickstart">
          Quickstart
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/idempotency-key-generator"
          >Idempotency key generator</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-cron {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-cron-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
  }
  .lmp-cron-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }
  .lmp-cron-input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    padding: 0.7rem 0.85rem;
    outline: none;
    letter-spacing: 0.04em;
  }
  .lmp-cron-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent);
  }
  .lmp-cron-presets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    padding-bottom: 0.85rem;
    border-bottom: 1px dashed var(--color-border);
    margin-bottom: 0.85rem;
  }
  .lmp-cron-preset {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.3rem 0.55rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }
  .lmp-cron-preset:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .lmp-cron-result-row {
    margin-bottom: 0.85rem;
  }
  .lmp-cron-result-row[hidden] {
    display: none;
  }
  .lmp-cron-desc {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    margin-top: 0.25rem;
  }
  .lmp-cron-error {
    display: block;
    font-size: 0.92rem;
    color: var(--color-error);
    margin-top: 0.25rem;
    font-family: var(--font-mono);
  }
  .lmp-cron-next {
    list-style: none;
    padding: 0;
    margin: 0.4rem 0 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
  }
  .lmp-cron-next li {
    padding: 0.5rem 0.8rem;
    border-bottom: 1px dashed var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .lmp-cron-next li:last-child {
    border-bottom: none;
  }
  .lmp-cron-next li .relative {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .lmp-cron-tz {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-align: right;
  }
</style>

<script>
  // Standard 5-field cron parser — minute, hour, day-of-month, month, day-of-week.
  // No special strings (@daily / @hourly etc.); spell those out.

  type Parsed = {
    minute: Set<number>;
    hour: Set<number>;
    dom: Set<number>;
    month: Set<number>;
    dow: Set<number>;
    domStar: boolean;
    dowStar: boolean;
  };

  function parseField(
    raw: string,
    min: number,
    max: number,
  ): Set<number> {
    const set = new Set<number>();
    if (raw === "*") {
      for (let i = min; i <= max; i++) set.add(i);
      return set;
    }
    for (const part of raw.split(",")) {
      // Step-on-everything: */N
      const stepMatch = part.match(/^(\*|\d+(-\d+)?)\/(\d+)$/);
      if (stepMatch) {
        const [, base, , stepStr] = stepMatch;
        const step = Number(stepStr);
        if (!Number.isFinite(step) || step <= 0) {
          throw new Error(`bad step in "${part}"`);
        }
        let lo = min;
        let hi = max;
        if (base !== "*") {
          if (base.includes("-")) {
            const [a, b] = base.split("-").map(Number);
            lo = a;
            hi = b;
          } else {
            lo = Number(base);
            hi = max;
          }
        }
        if (lo < min || hi > max || lo > hi) {
          throw new Error(`out-of-range step in "${part}"`);
        }
        for (let i = lo; i <= hi; i += step) set.add(i);
        continue;
      }
      // Range
      if (part.includes("-")) {
        const [a, b] = part.split("-").map(Number);
        if (
          !Number.isFinite(a) ||
          !Number.isFinite(b) ||
          a < min ||
          b > max ||
          a > b
        ) {
          throw new Error(`bad range "${part}"`);
        }
        for (let i = a; i <= b; i++) set.add(i);
        continue;
      }
      // Single value
      const n = Number(part);
      if (!Number.isFinite(n) || n < min || n > max) {
        throw new Error(`out-of-range value "${part}"`);
      }
      set.add(n);
    }
    return set;
  }

  function parse(expr: string): Parsed {
    const fields = expr.trim().split(/\s+/);
    if (fields.length !== 5) {
      throw new Error(
        `expected 5 fields, got ${fields.length} ("${expr.trim()}")`,
      );
    }
    const [m, h, d, mo, dw] = fields;
    return {
      minute: parseField(m, 0, 59),
      hour: parseField(h, 0, 23),
      dom: parseField(d, 1, 31),
      month: parseField(mo, 1, 12),
      // Map 7 -> 0 (Sunday) for crontab compatibility before parsing.
      dow: parseField(dw.replaceAll("7", "0"), 0, 6),
      domStar: d === "*",
      dowStar: dw === "*",
    };
  }

  function nextFire(after: Date, p: Parsed): Date | null {
    const d = new Date(after);
    d.setSeconds(0, 0);
    d.setMinutes(d.getMinutes() + 1);

    // Cap iteration to ~5 years of minutes — sparse expressions like
    // "0 0 29 2 *" (Feb 29) need to walk leap years.
    const maxIters = 5 * 366 * 24 * 60;
    for (let i = 0; i < maxIters; i++) {
      const month = d.getMonth() + 1;
      if (!p.month.has(month)) {
        d.setMonth(d.getMonth() + 1, 1);
        d.setHours(0, 0, 0, 0);
        continue;
      }
      const dom = d.getDate();
      const dow = d.getDay();
      // Standard cron OR semantics when BOTH dom and dow are restricted.
      let dayOk: boolean;
      if (p.domStar && p.dowStar) dayOk = true;
      else if (p.domStar) dayOk = p.dow.has(dow);
      else if (p.dowStar) dayOk = p.dom.has(dom);
      else dayOk = p.dom.has(dom) || p.dow.has(dow);

      if (!dayOk) {
        d.setDate(d.getDate() + 1);
        d.setHours(0, 0, 0, 0);
        continue;
      }
      if (!p.hour.has(d.getHours())) {
        d.setHours(d.getHours() + 1);
        d.setMinutes(0, 0, 0);
        continue;
      }
      if (!p.minute.has(d.getMinutes())) {
        d.setMinutes(d.getMinutes() + 1);
        continue;
      }
      return new Date(d);
    }
    return null;
  }

  // Plain-English description for common shapes; falls back to a generic
  // string when the expression is too custom to summarize cleanly.
  function describe(_p: Parsed, raw: string): string {
    const trimmed = raw.trim();
    const fields = trimmed.split(/\s+/);
    if (fields.length !== 5) return "Custom schedule.";
    const [m, h, dom, mon, dow] = fields;

    // Every minute
    if (m === "*" && h === "*" && dom === "*" && mon === "*" && dow === "*") {
      return "Every minute.";
    }
    // Step minutes
    const stepMin = m.match(/^\*\/(\d+)$/);
    if (
      stepMin &&
      h === "*" &&
      dom === "*" &&
      mon === "*" &&
      dow === "*"
    ) {
      return `Every ${stepMin[1]} minutes.`;
    }
    // Hourly on minute M
    if (
      /^\d+$/.test(m) &&
      h === "*" &&
      dom === "*" &&
      mon === "*" &&
      dow === "*"
    ) {
      return `Every hour at minute ${m}.`;
    }
    // Daily at H:M
    if (
      /^\d+$/.test(m) &&
      /^\d+$/.test(h) &&
      dom === "*" &&
      mon === "*" &&
      dow === "*"
    ) {
      return `Every day at ${pad(h)}:${pad(m)}.`;
    }
    // Weekday helpers
    const DOW_NAMES = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
    if (
      /^\d+$/.test(m) &&
      /^\d+$/.test(h) &&
      dom === "*" &&
      mon === "*" &&
      dow === "1-5"
    ) {
      return `Every weekday at ${pad(h)}:${pad(m)}.`;
    }
    if (
      /^\d+$/.test(m) &&
      /^\d+$/.test(h) &&
      dom === "*" &&
      mon === "*" &&
      (dow === "0,6" || dow === "6,0")
    ) {
      return `Every weekend day at ${pad(h)}:${pad(m)}.`;
    }
    if (
      /^\d+$/.test(m) &&
      /^\d+$/.test(h) &&
      dom === "*" &&
      mon === "*" &&
      /^\d$/.test(dow)
    ) {
      const idx = Number(dow);
      return `Every ${DOW_NAMES[idx] ?? dow} at ${pad(h)}:${pad(m)}.`;
    }
    // Day D of month at H:M
    if (
      /^\d+$/.test(m) &&
      /^\d+$/.test(h) &&
      /^\d+$/.test(dom) &&
      mon === "*" &&
      dow === "*"
    ) {
      return `On day ${dom} of every month at ${pad(h)}:${pad(m)}.`;
    }
    return "Custom schedule — see next fire times.";
  }

  function pad(n: string | number): string {
    return String(n).padStart(2, "0");
  }

  function formatDate(d: Date): string {
    // ISO-ish but readable, in browser local time.
    const date = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
    const time = `${pad(d.getHours())}:${pad(d.getMinutes())}`;
    const dow = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"][d.getDay()];
    return `${date} (${dow}) ${time}`;
  }

  function relative(d: Date, from: Date): string {
    const diffMs = d.getTime() - from.getTime();
    const min = Math.round(diffMs / 60000);
    if (min < 60) return `in ${min}m`;
    const hr = Math.round(min / 60);
    if (hr < 48) return `in ${hr}h`;
    const day = Math.round(hr / 24);
    if (day < 60) return `in ${day}d`;
    const mo = Math.round(day / 30);
    return `in ~${mo}mo`;
  }

  function setupCron(root: HTMLElement) {
    const input = root.querySelector<HTMLInputElement>("[data-cron-input]");
    const desc = root.querySelector<HTMLElement>("[data-cron-desc]");
    const errRow = root.querySelector<HTMLElement>("[data-cron-error-row]");
    const err = root.querySelector<HTMLElement>("[data-cron-error]");
    const next = root.querySelector<HTMLOListElement>("[data-cron-next]");
    const tz = root.querySelector<HTMLElement>("[data-cron-tz]");
    const presets = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-cron-preset]"),
    );

    function refresh() {
      const expr = input?.value || "";
      if (!expr.trim()) return;

      try {
        const parsed = parse(expr);
        if (errRow) errRow.hidden = true;
        if (err) err.textContent = "";
        if (desc) desc.textContent = describe(parsed, expr);

        const fires: Date[] = [];
        let cursor = new Date();
        for (let i = 0; i < 5; i++) {
          const f = nextFire(cursor, parsed);
          if (!f) break;
          fires.push(f);
          cursor = f;
        }
        if (next) {
          next.innerHTML = "";
          const now = new Date();
          for (const f of fires) {
            const li = document.createElement("li");
            li.innerHTML = `<span>${formatDate(f)}</span><span class="relative">${relative(f, now)}</span>`;
            next.appendChild(li);
          }
          if (fires.length === 0) {
            const li = document.createElement("li");
            li.textContent = "No fire times in the next 5 years.";
            next.appendChild(li);
          }
        }
      } catch (e) {
        if (errRow) errRow.hidden = false;
        if (err)
          err.textContent =
            e instanceof Error ? e.message : "Invalid expression.";
        if (desc) desc.textContent = "Invalid.";
        if (next) next.innerHTML = "";
      }
    }

    input?.addEventListener("input", refresh);
    presets.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (input) {
          input.value = btn.dataset.cronPreset || "";
          refresh();
        }
      });
    });

    if (tz) {
      const zone =
        Intl.DateTimeFormat().resolvedOptions().timeZone || "(unknown)";
      tz.textContent = `Browser timezone · ${zone}`;
    }

    refresh();
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>("[data-cron]").forEach(setupCron);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
