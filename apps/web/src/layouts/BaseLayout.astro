---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Analytics from "../components/Analytics.astro";
import Attribution from "../components/Attribution.astro";
import NavRail from "../components/NavRail.astro";
import MobilePill from "../components/MobilePill.astro";
import MobileSheet from "../components/MobileSheet.astro";
import StickyCTA from "../components/StickyCTA.astro";
import Footer from "../components/Footer.astro";

/**
 * The marketing site's shared chrome: 3-column receipt layout with a
 * left nav rail, a center "strip" that the page content fills, and an
 * optional right rail (marginalia, or a table-of-contents on blog
 * posts). Mobile drops both rails and floats a pill + takeover sheet.
 *
 * Pages opt into the right rail via the `rightRail` slot. Pages that
 * want a different strip width (pricing → 720, blog → 700, blog-post
 * → 660) pass `stripWidth`. Sticky CTA can be opted out via
 * `stickyCTA={false}`.
 *
 * Shared chrome behaviors (theme toggle, sticky CTA reveal, mobile
 * sheet open/close, code-block tabs) ship as one inline script at
 * the bottom of <body> so they survive Astro view transitions.
 */
export interface JsonLdGraph {
  "@context"?: string;
  "@type": string;
  [key: string]: unknown;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: JsonLdGraph[];
  ogType?: "website" | "article" | "product";
  /** Override --r-strip-w. Defaults to 640px (landing). */
  stripWidth?: number;
  /** Override mobile-pill quick links (defaults to Docs + Pricing). */
  pillLinks?: Array<{ href: string; label: string }>;
  /** Sticky CTA config; pass `false` to hide. */
  stickyCTA?: { href: string; label: string } | false;
}

const {
  title,
  description = "Open-source social media publishing API for developers and AI agents. Preflight validation, transparent errors, stable versions, idempotency by default.",
  ogImage = "/og-image.png",
  noindex = false,
  jsonLd = [],
  ogType = "website",
  stripWidth,
  pillLinks,
  stickyCTA,
} = Astro.props;

const siteName = "letmepost.dev";
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const siteUrl = Astro.site!.toString().replace(/\/$/, "");

const defaultGraphs: JsonLdGraph[] = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    name: siteName,
    url: siteUrl,
    logo: `${siteUrl}/og-image.png`,
    description:
      "Open-source social media publishing API for developers and AI agents.",
    sameAs: [
      "https://github.com/rosekamallove/letmepost.dev",
      "https://x.com/letmepostdotdev",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    name: siteName,
    url: siteUrl,
    publisher: { "@id": `${siteUrl}/#organization` },
  },
];

const allGraphs: JsonLdGraph[] = [...defaultGraphs, ...jsonLd];

const pageStyle = stripWidth ? `--r-strip-w: ${stripWidth}px;` : undefined;

const ctaConfig =
  stickyCTA === false
    ? null
    : (stickyCTA ?? { href: "https://dashboard.letmepost.dev", label: "→ START FREE" });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f7f4ea" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e0e0a" media="(prefers-color-scheme: dark)" />

    {/* Pre-paint theme bootstrap. Receipt design uses 2-state: empty
        string = light, "dark" = dark. `data-astro-rerun` re-fires on
        view transitions so soft navigations don't flash light defaults
        mid-swap. */}
    <script is:inline data-astro-rerun>
      (function () {
        try {
          var pref = localStorage.getItem("lmp-theme") || "";
          if (pref === "dark") document.documentElement.setAttribute("data-theme", "dark");
          else document.documentElement.removeAttribute("data-theme");
        } catch (e) {}
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="letmepost.dev Blog" href="/rss.xml" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="letmepost.dev. Social media publishing that fails loudly." />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@letmepostdotdev" />
    <meta name="twitter:creator" content="@letmepostdotdev" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="letmepost.dev. Social media publishing that fails loudly." />

    {allGraphs.map((graph) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
    ))}

    <ClientRouter />
    <Analytics />
    <Attribution />
  </head>
  <body>
    <div class="page" style={pageStyle}>
      <NavRail>
        <slot name="navSecondary" slot="secondary" />
        <slot name="navStatus" slot="status" />
        <slot name="navColophon" slot="colophon" />
      </NavRail>

      <main class="strip" transition:animate="fade">
        <slot />
      </main>

      <slot name="rightRail">
        <aside class="marg" aria-hidden="true"></aside>
      </slot>
    </div>

    <Footer />

    <MobilePill links={pillLinks} />
    <MobileSheet />

    {ctaConfig && <StickyCTA href={ctaConfig.href} label={ctaConfig.label} />}

    {/* Shared chrome behaviors. Defensive — pages without a feature
        don't error. Re-binds on Astro view transitions. */}
    <script>
      function setup() {
        document.querySelectorAll<HTMLElement>("[data-tabs]").forEach((block) => {
          if (block.dataset.lmpBound) return;
          block.dataset.lmpBound = "1";
          const tabs = block.querySelectorAll<HTMLElement>(".tab");
          const panes = block.querySelectorAll<HTMLElement>("[data-pane]");
          const fileEl = block.querySelector<HTMLElement>(".file");
          let files: Record<string, string> = {};
          try {
            files = JSON.parse(block.dataset.files || "null") || {};
          } catch {}
          tabs.forEach((tab) => {
            tab.addEventListener("click", () => {
              const id = tab.dataset.tab!;
              tabs.forEach((t) => t.classList.toggle("on", t === tab));
              panes.forEach((p) => {
                if (p.dataset.pane !== id) p.setAttribute("hidden", "");
                else p.removeAttribute("hidden");
              });
              if (fileEl && files[id]) fileEl.textContent = files[id];
            });
          });
        });

        const sticky = document.getElementById("sticky-cta");
        const anchor =
          document.querySelector<HTMLElement>("[data-sticky-anchor]") ||
          document.querySelector<HTMLElement>(".head") ||
          document.querySelector<HTMLElement>(".page-head");
        if (sticky && anchor) {
          const prior = (window as unknown as { __lmpStickyScroll?: () => void }).__lmpStickyScroll;
          if (prior) window.removeEventListener("scroll", prior);
          const onScroll = () => {
            const bottom = anchor.getBoundingClientRect().bottom;
            sticky.classList.toggle("show", bottom < 0);
          };
          (window as unknown as { __lmpStickyScroll?: () => void }).__lmpStickyScroll = onScroll;
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        }

        function toggleTheme() {
          const cur = document.documentElement.getAttribute("data-theme");
          const next = cur === "dark" ? "" : "dark";
          if (next) document.documentElement.setAttribute("data-theme", next);
          else document.documentElement.removeAttribute("data-theme");
          try {
            localStorage.setItem("lmp-theme", next);
          } catch {}
        }
        document
          .querySelectorAll<HTMLElement>("#theme-btn, #sheet-theme-btn, [data-theme-btn]")
          .forEach((b) => {
            if (b.dataset.lmpBound) return;
            b.dataset.lmpBound = "1";
            b.addEventListener("click", toggleTheme);
          });

        const sheet = document.getElementById("mobile-sheet");
        const openBtn = document.getElementById("open-sheet");
        const closeBtn = document.getElementById("close-sheet");
        function openSheet() {
          if (!sheet) return;
          sheet.setAttribute("data-open", "");
          document.body.classList.add("sheet-open");
          openBtn?.setAttribute("aria-expanded", "true");
        }
        function closeSheet() {
          if (!sheet) return;
          sheet.removeAttribute("data-open");
          document.body.classList.remove("sheet-open");
          openBtn?.setAttribute("aria-expanded", "false");
        }
        if (openBtn && !openBtn.dataset.lmpBound) {
          openBtn.dataset.lmpBound = "1";
          openBtn.addEventListener("click", openSheet);
        }
        if (closeBtn && !closeBtn.dataset.lmpBound) {
          closeBtn.dataset.lmpBound = "1";
          closeBtn.addEventListener("click", closeSheet);
        }
        sheet?.querySelectorAll<HTMLAnchorElement>("a").forEach((a) => {
          if (a.dataset.lmpBound) return;
          a.dataset.lmpBound = "1";
          a.addEventListener("click", () => setTimeout(closeSheet, 60));
        });
        if (!(window as unknown as { __lmpSheetEsc?: boolean }).__lmpSheetEsc) {
          (window as unknown as { __lmpSheetEsc?: boolean }).__lmpSheetEsc = true;
          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && sheet?.hasAttribute("data-open")) closeSheet();
          });
        }
      }

      setup();
      document.addEventListener("astro:page-load", setup);
    </script>
  </body>
</html>
