---
import BaseLayout, { type JsonLdGraph } from "../../layouts/BaseLayout.astro";
import { faqPageSchema } from "../../lib/seo.ts";
import { Icon } from "astro-icon/components";
import { APIS, type ApiSurface } from "../../data/platforms.ts";
import { API_CONTENT } from "../../data/api-content.ts";
import { highlight } from "../../lib/highlight.ts";

/**
 * Per-API-surface landing page — Clarity design, full marketing copy.
 * Per-surface copy lives in api-content.ts (our copy).
 *
 * Sections: hero (badge + h1 + sub + lede + CTAs + mini-code) → VS →
 * highlight → capabilities → how it works → features + cross-link →
 * code example → error reference → FAQ → other surfaces → learn more →
 * notes → final CTA.
 */

export function getStaticPaths() {
  return APIS.map((api) => ({ params: { slug: api.slug }, props: { api } }));
}

interface Props {
  api: ApiSurface;
}

const { api } = Astro.props;
const content = API_CONTENT[api.slug];

const surfaceBlurbs: Record<string, string> = {
  publishing: "Text, media, scheduled posts. The primary endpoint.",
  media: "Upload bytes once, reference by mediaId on every post.",
  webhooks: "HMAC-signed delivery for 8 lifecycle events.",
};
const surfaceBadges: Record<string, { method: string; path: string }> = {
  publishing: { method: "POST", path: "/v1/posts" },
  media: { method: "POST", path: "/v1/media" },
  webhooks: { method: "POST", path: "/v1/webhook-endpoints" },
};
const allSurfaces = APIS.map((s) => ({
  slug: s.slug,
  name: s.name,
  badge: surfaceBadges[s.slug] ?? content.badge,
  blurb: surfaceBlurbs[s.slug] ?? s.tagline,
  current: s.slug === api.slug,
}));

const learnMore = [
  { title: "API reference", body: "Full schema + examples", href: "https://docs.letmepost.dev/api-reference" },
  { title: "Quickstart", body: "90 seconds to first request", href: "https://docs.letmepost.dev/quickstart" },
  { title: "Self-host", body: "Same image, your infra", href: "https://docs.letmepost.dev/self-host" },
];

const siteUrl = Astro.site!.toString().replace(/\/$/, "");
const breadcrumbJsonLd: JsonLdGraph = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "API surfaces", item: `${siteUrl}/api/` },
    { "@type": "ListItem", position: 3, name: api.name, item: `${siteUrl}/api/${api.slug}/` },
  ],
};
---

<BaseLayout
  title={`${api.name} API`}
  description={`${api.name} on letmepost.dev. ${api.tagline}.`}
  ogType="product"
  jsonLd={[breadcrumbJsonLd, faqPageSchema(content.faqs)]}
>
  <header class="wrap page-head">
    <p class="crumb"><a href="/api">APIs</a> / {api.name}</p>
    <div class="apitabs">
      {APIS.map((s) => (
        <a class={`apitab${s.slug === api.slug ? " on" : ""}`} href={`/api/${s.slug}`}>{s.name.replace(/ API$/, "")}</a>
      ))}
    </div>
    <span class="surface-badge" style="margin-top: 22px;">
      <span class="method">{content.badge.method}</span>
      <span class="path">{content.badge.path}</span>
    </span>
    <h1 class="cl-h1" style="max-width: 16ch;">
      {content.heroH1.prefix}{" "}
      <span class="under">{content.heroH1.underlined}</span>{content.heroH1.suffix}
    </h1>
    <p class="cl-h3 acc">{content.heroSub}</p>
    <p class="sub" set:html={content.heroLede} />
    <div class="ctas" style="margin-top: 30px;">
      <a
        class="btn pri lg"
        href="https://dashboard.letmepost.dev"
        data-analytics-event="cta.clicked"
        data-analytics-props={JSON.stringify({ location: "hero", target: "dashboard", page: "api-detail", surface: api.slug })}
      >Get an API key →</a>
      <a class="btn ghost lg" href={content.finalCtaSecondaryHref}>API reference</a>
    </div>
    {content.reassurance && <p class="trust" set:html={content.reassurance} />}

    <div class="code" style="margin-top: 36px;">
      <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="file">{content.badge.method} {content.badge.path}</span></div>
      <pre set:html={highlight(content.miniCodeLang, content.miniCode)} />
    </div>
  </header>

  {/* VS COMPARISON */}
  <section class="wrap sec">
    <p class="vs-head">{content.vsHead}</p>
    <div class="compare">
      <div class="col them">
        <h3>{content.vsDirectTitle}</h3>
        <ul>{content.vsDirect.map((p) => <li set:html={p.body} />)}</ul>
      </div>
      <div class="col us">
        <h3>letmepost {api.name}</h3>
        <ul>{content.vsLetmepost.map((p) => <li set:html={p.body} />)}</ul>
      </div>
    </div>
    {content.costBanner && <div class={`cost-banner ${content.costBanner.tone}`} set:html={content.costBanner.body} />}
  </section>

  {content.highlight && (
    <section class="wrap sec" style="padding-top: 0;">
      <div class={`highlight-block ${content.highlight.tone}`}>
        <h3>{content.highlight.title}</h3>
        <p set:html={content.highlight.body} />
      </div>
    </section>
  )}

  {/* CAPABILITIES */}
  <section class="wrap sec divider">
    <p class="kicker">Capabilities</p>
    <h2 class="cl-h2">{content.capabilitiesTitle}</h2>
    <p class="lead">{content.capabilitiesSubtitle}</p>
    <div class="ctypes">
      {content.capabilities.map((ct) => (
        <div class="ctype">
          <Icon name={`ph:${ct.icon}`} width={15} height={15} />
          <b>{ct.label}</b>
          {ct.note && <span class="note">· {ct.note}</span>}
        </div>
      ))}
    </div>
  </section>

  {/* HOW IT WORKS */}
  <section class="wrap sec divider">
    <p class="kicker">How it works</p>
    <h2 class="cl-h2">{content.stepsTitle}</h2>
    <p class="lead">{content.stepsSubtitle}</p>
    <div class="steps">
      {content.steps.map((s) => (
        <div class="step">
          <div>
            <h4>{s.title}</h4>
            <p set:html={s.body} />
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* FEATURES */}
  <section class="wrap sec divider">
    <p class="kicker">Features</p>
    <h2 class="cl-h2">{content.featuresTitle}</h2>
    <p class="lead">{content.featuresSubtitle}</p>
    <div class="cards c2">
      {content.features.map((f) => (
        <div class="card">
          <div class="ic"><Icon name={`ph:${f.icon}`} width={18} height={18} /></div>
          <h3>{f.title}</h3>
          <p set:html={f.body} />
        </div>
      ))}
    </div>
    {content.alsoPill && (
      <div class="also-pill">
        <div class="l">
          <Icon name="ph:plus-circle" width={18} height={18} />
          <span set:html={content.alsoPill.body} />
        </div>
        <a class="r" href={content.alsoPill.href}>{content.alsoPill.label}</a>
      </div>
    )}
  </section>

  {/* CODE EXAMPLE */}
  <section class="wrap sec divider">
    <p class="kicker">Code example</p>
    <h2 class="cl-h2">{content.codeExample.caption}</h2>
    <div class="code">
      <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="file">{content.codeExample.file}</span></div>
      <pre set:html={highlight(content.codeExample.lang, content.codeExample.code)} />
    </div>
  </section>

  {content.errorRef && (
    <section class="wrap sec" style="padding-top: 0;">
      <div class="err-ref">
        <div>
          <h4>{content.errorRef.title}</h4>
          <p>{content.errorRef.body}</p>
        </div>
        <a href={content.errorRef.href}>View error reference →</a>
      </div>
    </section>
  )}

  {/* FAQ */}
  <section class="wrap sec divider">
    <p class="kicker">Common questions</p>
    <h2 class="cl-h2">{content.faqSubtitle}</h2>
    <div class="faq">
      {content.faqs.map((f) => (
        <div class="q-item">
          <p class="q">{f.q}</p>
          <p class="a" set:html={f.a} />
        </div>
      ))}
    </div>
  </section>

  {/* OTHER SURFACES */}
  <section class="wrap sec divider">
    <p class="kicker">Other surfaces</p>
    <h2 class="cl-h2">The rest of the API.</h2>
    <div class="cards c3">
      {allSurfaces.map((s) => (
        <a class="card" href={`/api/${s.slug}`} style={s.current ? "border-color: var(--acc);" : undefined}>
          <div style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--faint); margin-bottom: 10px;">
            <span class="acc">{s.badge.method}</span> {s.badge.path}{s.current ? " · here" : ""}
          </div>
          <h3>{s.name}</h3>
          <p>{s.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  {/* LEARN MORE */}
  <section class="wrap sec" style="padding-top: 0;">
    <p class="kicker">Learn more</p>
    <div class="cards c3">
      {learnMore.map((l) => (
        <a class="card" href={l.href}>
          <h3>{l.title}</h3>
          <div class="meta">{l.body}</div>
        </a>
      ))}
    </div>
  </section>

  {content.marg && content.marg.length > 0 && (
    <section class="wrap sec divider">
      <p class="kicker">Good to know</p>
      <h2 class="cl-h2">Notes on the contract.</h2>
      <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 32px;">
        {content.marg.map((n) => (
          <div class="callout">
            <span class="callout-tag">{n.tag}</span>
            <p set:html={n.body} />
          </div>
        ))}
      </div>
    </section>
  )}

  {/* FINAL CTA */}
  <section class="wrap">
    <div class="final">
      <h2>{content.finalCtaH2}</h2>
      <p set:html={content.finalCtaLede} />
      <div class="ctas">
        <a
          class="btn pri lg"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props={JSON.stringify({ location: "api-final", target: "dashboard", page: "api-detail", surface: api.slug })}
        >{content.finalCtaPrimaryLabel}</a>
        <a class="btn ghost lg" href={content.finalCtaSecondaryHref}>{content.finalCtaSecondaryLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
