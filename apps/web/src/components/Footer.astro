---
import { Icon } from "astro-icon/components";
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-transparent pt-10 pb-6 text-[0.85rem] mt-16">
  <div class="container">
    <div class="mb-7">
      <div class="font-extrabold tracking-[-0.02em] mb-1.5">letmepost.dev</div>
      <p class="text-text-muted">
        Open-source social media publishing API.<br />
        Fails loudly, not silently.
      </p>
    </div>

    <div class="flex flex-wrap gap-x-6 gap-y-1 mb-6">
      <a href="/#platforms" class="no-underline text-text transition-colors hover:text-accent">Platforms</a>
      <a href="/status" class="no-underline text-text transition-colors hover:text-accent">Status</a>
      <a
        class="inline-flex items-center gap-1 no-underline text-text transition-colors hover:text-accent"
        href="https://github.com/rosekamallove/letmepost.dev"
        rel="noopener"
        target="_blank"
      >
        GitHub <Icon name="ph:arrow-up-right" width={12} height={12} />
      </a>
      <a href="/privacy" class="no-underline text-text transition-colors hover:text-accent">Privacy</a>
      <a href="/terms" class="no-underline text-text transition-colors hover:text-accent">Terms</a>
      <a href="/data-deletion" class="no-underline text-text transition-colors hover:text-accent">Data deletion</a>
      <a href="/contact" class="no-underline text-text transition-colors hover:text-accent">Contact</a>
    </div>

    <div class="pt-5 border-t border-border text-text-muted">
      © {year} letmepost.dev · Apache-2.0
    </div>
  </div>
</footer>
