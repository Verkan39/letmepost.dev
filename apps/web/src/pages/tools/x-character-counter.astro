---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CharacterCounter from "../../components/CharacterCounter.astro";
import { Icon } from "astro-icon/components";

const platforms = [
  {
    slug: "x",
    name: "X (Twitter) post",
    limit: 280,
    mode: "twitter-weighted" as const,
    hint: "twitter-text weighted count",
  },
  {
    slug: "x-premium",
    name: "X Premium long-post",
    limit: 25000,
    mode: "twitter-weighted" as const,
    hint: "Premium / Verified accounts",
  },
];

const rules = [
  {
    label: "Standard post",
    value: "280 weighted characters",
    note: "Latin letters, digits, and most punctuation count as 1. CJK, Arabic, Hebrew, and emoji count as 2.",
  },
  {
    label: "X Premium / Verified long-post",
    value: "25,000 characters",
    note: "Available to subscribers; same weighting rule applies.",
  },
  {
    label: "URLs",
    value: "Always 23 characters",
    note: "X auto-shortens via t.co — the displayed URL length doesn't matter.",
  },
  {
    label: "Mentions and cashtags",
    value: "Counted as displayed",
    note: "@handle and $TICKER count their literal characters, no special weighting.",
  },
];
---

<BaseLayout
  title="X (Twitter) character counter"
  description="Free X / Twitter character counter using the official twitter-text weighted count. CJK, emoji, and URLs counted accurately. 280 default, 25,000 for Premium."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "X (Twitter) character counter",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Free X / Twitter character counter using twitter-text weighted character counting.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">X (Twitter) character counter.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        280 weighted characters for the standard post, 25,000 for X Premium.
        Uses the same range table as twitter-text — CJK and emoji count as two,
        Latin letters count as one.
      </p>
      <CharacterCounter
        platforms={platforms}
        placeholder="What's happening?"
      />
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">How X actually counts.</h2>
      <ul class="list-none p-0 mt-4">
        {
          rules.map((r) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <span class="font-bold text-[0.95rem]">{r.label}</span>
                <span class="text-accent font-mono text-[0.9rem]">
                  {r.value}
                </span>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{r.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Stop guessing at 280.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code> validates X's weighted-count rule (and every other
        platform's character cap) before the API call. Posts that would have been
        rejected fail loudly with the rule that broke — not after the wire.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="https://dashboard.letmepost.dev">
          Try the API
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/social-media-character-counter"
          >All platforms at once</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
