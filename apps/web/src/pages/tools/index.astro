---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Tape from "../../components/Tape.astro";
import Closeout from "../../components/Closeout.astro";

/**
 * Tools index — receipt design. Search/filter strip + 4 category
 * sections of 2-up tool cards. Real tool URLs that already exist
 * under /tools/*.astro; placeholder cards link to "more" pages so
 * the grid stays balanced.
 *
 * Each category has a placeholder card at the end so the 2-up grid
 * has an even count. That card uses the deep-paper background and
 * a `+` glyph instead of a normal icon.
 */

interface ToolEntry {
  href: string;
  name: string;
  desc: string;
  icon: string;
  tags: Array<{ label: string; accent?: boolean }>;
  placeholder?: boolean;
}

const counters: ToolEntry[] = [
  {
    href: "/tools/social-media-character-counter",
    name: "Multi-platform counter",
    desc: "One textarea. Every limit at once. Bluesky graphemes + bytes, X weighted, LinkedIn 3,000, Threads 500.",
    icon: "ph:list-bullets",
    tags: [
      { label: "flagship", accent: true },
      { label: "5 platforms" },
    ],
  },
  {
    href: "/tools/bluesky-grapheme-counter",
    name: "Bluesky grapheme counter",
    desc: "300 graphemes AND 3,000 UTF-8 bytes. Whichever caps first. Same rule AT Protocol enforces.",
    icon: "ph:butterfly",
    tags: [{ label: "bluesky" }, { label: "at-proto" }],
  },
  {
    href: "/tools/x-character-counter",
    name: "X (Twitter) counter",
    desc: "280 weighted characters using twitter-text's own range table. CJK and emoji counted accurately, t.co-aware URL weighting.",
    icon: "ph:x-logo",
    tags: [{ label: "x" }, { label: "twitter-text" }],
  },
  {
    href: "/tools/linkedin-character-counter",
    name: "LinkedIn counter",
    desc: "3,000-char share limit, grapheme-aware. Includes the org-comment + connection-note caps.",
    icon: "ph:linkedin-logo",
    tags: [{ label: "linkedin" }],
  },
  {
    href: "/tools/threads-character-counter",
    name: "Threads counter",
    desc: "500-character cap. Grapheme-aware so multi-codepoint emoji don't over-count.",
    icon: "ph:threads-logo",
    tags: [{ label: "threads" }],
  },
  {
    href: "https://github.com/letmepost/letmepost.dev/issues",
    name: "More platforms?",
    desc: "Pinterest, Instagram, and Facebook character rules live in our docs. Open an issue if you want them as standalone tools too.",
    icon: "ph:plus",
    tags: [{ label: "request" }],
    placeholder: true,
  },
];

const oauth: ToolEntry[] = [
  {
    href: "/tools/linkedin-oauth-scope-checker",
    name: "LinkedIn OAuth scopes",
    desc: "Pick what you want to do, get the minimum scope string. Includes the deprecated r_liteprofile / r_emailaddress mappings.",
    icon: "ph:linkedin-logo",
    tags: [{ label: "linkedin" }, { label: "oauth-2.0" }],
  },
  {
    href: "/tools/x-oauth-scope-checker",
    name: "X v2 OAuth scopes",
    desc: "tweet.write, dm.*, follows.*, offline.access. PKCE-aware example URL with the correct callback shape.",
    icon: "ph:x-logo",
    tags: [{ label: "x" }, { label: "pkce" }],
  },
  {
    href: "/tools/meta-oauth-scope-checker",
    name: "Meta (FB / IG / Threads / WhatsApp)",
    desc: "All four Meta surfaces in one place. App Review (Advanced Access) flagged on every scope.",
    icon: "ph:instagram-logo",
    tags: [
      { label: "app review", accent: true },
      { label: "meta-graph" },
    ],
  },
  {
    href: "https://github.com/letmepost/letmepost.dev/issues",
    name: "Pinterest, Bluesky?",
    desc: "Pinterest uses Standard Access (not classic OAuth scopes). Bluesky uses app passwords. Neither needs this tool.",
    icon: "ph:plus",
    tags: [{ label: "noted" }],
    placeholder: true,
  },
];

const generators: ToolEntry[] = [
  {
    href: "/tools/idempotency-key-generator",
    name: "Idempotency key generator",
    desc: "UUID v4, ULID, or nanoid. The three formats you actually want as an Idempotency-Key header.",
    icon: "ph:key",
    tags: [{ label: "uuid" }, { label: "ulid" }, { label: "nanoid" }],
  },
  {
    href: "/tools/pkce-generator",
    name: "PKCE generator",
    desc: "code_verifier + S256 code_challenge using Web Crypto. Required for X v2 OAuth and most modern flows.",
    icon: "ph:shield-check",
    tags: [{ label: "pkce" }, { label: "s256" }],
  },
  {
    href: "/tools/cron-expression-builder",
    name: "Cron expression builder",
    desc: 'Build cron expressions with a natural form. "Every weekday at 9am UTC" → 0 9 * * 1-5.',
    icon: "ph:clock",
    tags: [{ label: "cron" }, { label: "scheduling" }],
  },
  {
    href: "https://github.com/letmepost/letmepost.dev/issues",
    name: "JWT, HMAC, more?",
    desc: "Want a JWT decoder, HMAC signer, webhook signature verifier? Open an issue with the use case.",
    icon: "ph:plus",
    tags: [{ label: "request" }],
    placeholder: true,
  },
];

const calculators: ToolEntry[] = [
  {
    href: "/tools/linkedin-api-version-tracker",
    name: "LinkedIn API version tracker",
    desc: "Every version LinkedIn shipped, every sunset date, every deprecation note. Updated weekly. Five sunsets in six months from 2024-25.",
    icon: "ph:list-numbers",
    tags: [
      { label: "live data", accent: true },
      { label: "linkedin" },
    ],
  },
  {
    href: "/tools/youtube-quota-cost-calculator",
    name: "YouTube quota calculator",
    desc: "Add up the Data API v3 quota cost for your daily volume. Upload (1,600), list (1), comment (50). Plan your CASA submission.",
    icon: "ph:youtube-logo",
    tags: [{ label: "youtube" }, { label: "quota" }],
  },
  {
    href: "/tools/linkedin-urn-encoder-decoder",
    name: "LinkedIn URN encoder / decoder",
    desc: "URN-encode and percent-encode LinkedIn IDs. urn:li:share:7234… → urn%3Ali%3Ashare%3A7234… The one that bites you on day one.",
    icon: "ph:arrows-down-up",
    tags: [{ label: "linkedin" }, { label: "urn" }],
  },
  {
    href: "https://github.com/letmepost/letmepost.dev/issues",
    name: "Rate-limit calc, image-size validator?",
    desc: "Suggest a tool. Most of these started as someone tweeting \"this should exist.\"",
    icon: "ph:plus",
    tags: [{ label: "request" }],
    placeholder: true,
  },
];

const categories = [
  { id: "counters", label: "Character counters", tools: counters },
  { id: "oauth", label: "OAuth scope checkers", tools: oauth },
  { id: "generators", label: "Generators", tools: generators },
  { id: "calculators", label: "Calculators & trackers", tools: calculators },
];

// Real-tool count (placeholders don't count toward the "14 tools" total).
const totalTools = categories.reduce(
  (n, c) => n + c.tools.filter((t) => !t.placeholder).length,
  0,
);
---

<BaseLayout
  title="Tools"
  description="A toolbox for working with social platform APIs. Character counters, OAuth scope checkers, idempotency-key generators, PKCE helpers, cron builders. All free, no signup."
  stripWidth={700}
  pillLinks={[
    { href: "/tools", label: "Tools" },
    { href: "/pricing", label: "Pricing" },
  ]}
>
  <Fragment slot="navSecondary">
    <div class="nav-section">By category</div>
    <ul class="links">
      {categories.map((c) => (
        <li>
          <a href={`#${c.id}`}>{c.label}</a>
          <span class="meta">{c.tools.filter((t) => !t.placeholder).length}</span>
        </li>
      ))}
    </ul>
  </Fragment>

  <Fragment slot="navColophon">
    <div class="colophon">
      All tools are <b>free, no signup.</b><br />
      Open source under <b>Apache 2.0.</b><br />
      <a href="mailto:rose@letmepost.dev" style="color: var(--r-dim);">request a tool →</a>
    </div>
  </Fragment>

  <Tape />

  <header class="page-head" data-sticky-anchor>
    <div class="crumb"><a href="/">letmepost</a> / tools</div>
    <h1 class="page-h1">The toolbox.</h1>
    <p class="lede">
      Fourteen utilities for working with social platform APIs. Grapheme-aware character counters
      that match what the platform actually enforces. OAuth scope checkers with Advanced-Access
      flags. Idempotency-key + PKCE generators. <b>All free, no signup, runs in your browser.</b>
    </p>
  </header>

  {/* Filter / stats strip */}
  <div class="tools-strip">
    <input
      type="search"
      placeholder="Search tools — ‘bluesky’, ‘oauth’, ‘pkce’…"
      aria-label="Search tools"
    />
    <span class="stat"><b>{totalTools}</b> tools</span>
    <span class="stat"><b>0</b> kb tracking</span>
    <span class="stat"><b>$0</b> ever</span>
  </div>

  {
    categories.map((cat) => (
      <>
        <div class="cat-head" id={cat.id}>
          <span class="cat-name">{cat.label}</span>
          <span class="cat-rule" />
          <span class="cat-count">
            <b>{cat.tools.filter((t) => !t.placeholder).length}</b> tools
          </span>
        </div>
        <div class="grid">
          {cat.tools.map((t) => (
            <a
              href={t.href}
              class="tool"
              style={t.placeholder ? "background: var(--r-paper-deep);" : ""}
            >
              <span
                class="glyph"
                style={t.placeholder ? "border: 0; background: transparent;" : ""}
              >
                <Icon name={t.icon} width={16} height={16} />
              </span>
              <div class="body">
                <div
                  class="name"
                  style={t.placeholder ? "color: var(--r-very);" : ""}
                >
                  {t.name}
                </div>
                <p class="desc">{t.desc}</p>
                <div class="meta">
                  {t.tags.map((tag) => (
                    <span class={`tag ${tag.accent ? "acc" : ""}`}>{tag.label}</span>
                  ))}
                </div>
              </div>
              <span class="arrow">→</span>
            </a>
          ))}
        </div>
      </>
    ))
  }

  {/* Build-your-own card */}
  <div class="byo">
    <h3>Need a tool we don't have?</h3>
    <p>
      Every tool here started as a forty-line file in <code>apps/web/src/pages/tools/</code>.
      The source is on GitHub. Open an issue with your use case, or send a PR.
    </p>
    <div class="links">
      <a href="https://github.com/letmepost/letmepost.dev/tree/main/apps/web/src/pages/tools">
        Browse the source →
      </a>
      <a href="https://github.com/letmepost/letmepost.dev/issues/new">Open an issue →</a>
    </div>
  </div>

  <hr class="double" />

  <Closeout
    thanks="* * * MADE FOR ENGINEERS WHO SHIP * * *"
    codeLine={`000 LMP TOOLS · ${totalTools} / ${totalTools}`}
    links={[
      { href: "/", label: "home" },
      { href: "https://docs.letmepost.dev", label: "docs" },
      { href: "https://github.com/letmepost/letmepost.dev", label: "github" },
    ]}
  />
  <Tape bottom />

  {/* Right rail — tool tips */}
  <aside class="marg" aria-label="Tool notes" slot="rightRail">
    <div class="note">
      <span class="tag">Free forever</span>
      Every tool here runs in your browser. <b>No accounts, no tracking, no logs.</b> Bookmark the URL.
    </div>
    <div class="note">
      <span class="tag">Source</span>
      Apache 2.0. Lift the source, modify, redistribute. We use them ourselves on a daily basis.
    </div>
    <div class="note">
      <span class="tag">Grapheme rules</span>
      Bluesky enforces graphemes, not characters. <code>👨‍👩‍👧‍👦</code> is one grapheme even though it's seven codepoints. Our counters match what the platform actually counts.
    </div>
    <div class="note">
      <span class="tag">OAuth scope tip</span>
      Always request the <b>minimum</b> scope. App Review will reject submissions that ask for more than your stated use case justifies.
    </div>
    <div class="note">
      <span class="tag">Request a tool</span>
      Open an issue on the repo or email <b>rose@letmepost.dev</b>. About half of these started as user requests.
    </div>
  </aside>
</BaseLayout>

<script>
  // Search filter — case-insensitive substring match across the
  // tool card's full text content. Hides categories that have zero
  // visible cards so the section header doesn't dangle.
  function bindSearch() {
    const search = document.querySelector<HTMLInputElement>(
      ".tools-strip input[type='search']",
    );
    if (!search || search.dataset.lmpBound) return;
    search.dataset.lmpBound = "1";

    search.addEventListener("input", (e) => {
      const q = (e.target as HTMLInputElement).value.toLowerCase().trim();
      const cards = document.querySelectorAll<HTMLElement>(".tool");
      cards.forEach((t) => {
        const text = (t.textContent || "").toLowerCase();
        t.style.display = !q || text.includes(q) ? "" : "none";
      });
      // Hide section headers that have no visible cards.
      document.querySelectorAll<HTMLElement>(".cat-head").forEach((head) => {
        const grid = head.nextElementSibling as HTMLElement | null;
        if (!grid) return;
        const visibleCards = Array.from(grid.querySelectorAll(".tool")).filter(
          (c) => (c as HTMLElement).style.display !== "none",
        );
        head.style.display = visibleCards.length === 0 ? "none" : "";
        grid.style.display = visibleCards.length === 0 ? "none" : "";
      });
    });
  }
  bindSearch();
  document.addEventListener("astro:page-load", bindSearch);
</script>

<style is:global>
  /* ── Tools index only ─────────────────────────────────── */

  .tools-strip {
    margin: 14px 0 24px;
    padding: 14px 16px;
    background: var(--r-paper-deep);
    border: 1px solid var(--r-line);
    display: grid; grid-template-columns: 1fr auto auto auto;
    gap: 10px; align-items: center;
  }
  .tools-strip input {
    font-family: var(--r-mono); font-size: 13px;
    background: var(--r-paper); color: var(--r-fg);
    border: 1px solid var(--r-line);
    padding: 8px 12px;
    width: 100%;
  }
  .tools-strip input:focus {
    outline: 2px solid var(--r-accent);
    outline-offset: -1px;
    border-color: var(--r-accent);
  }
  .tools-strip .stat {
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--r-very); white-space: nowrap;
  }
  .tools-strip .stat b { color: var(--r-ink); font-weight: 700; font-size: 12px; }

  .grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    border: 1px solid var(--r-line);
  }
  .tool {
    padding: 18px 20px 16px;
    border-right: 1px dashed var(--r-very);
    border-bottom: 1px dashed var(--r-very);
    background: var(--r-paper);
    display: grid; grid-template-columns: 32px 1fr;
    gap: 12px;
    transition: background 100ms;
    text-decoration: none;
    color: inherit;
    position: relative;
  }
  .tool:nth-child(2n) { border-right: 0; }
  .tool:nth-last-child(-n+2) { border-bottom: 0; }
  .tool:hover { background: var(--r-accent-soft); }
  .tool .glyph {
    width: 28px; height: 28px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--r-ink);
    border: 1px solid var(--r-line);
    background: var(--r-paper-deep);
  }
  .tool .body { min-width: 0; }
  .tool .name {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 14px; line-height: 1.3; margin: 0 0 4px;
    color: var(--r-ink);
  }
  .tool .desc {
    font-size: 11.5px; line-height: 1.55;
    color: var(--r-dim); margin: 0 0 8px;
  }
  .tool .meta {
    display: flex; gap: 10px; flex-wrap: wrap;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--r-very);
  }
  .tool .meta .tag {
    padding: 2px 6px; border: 1px solid var(--r-line);
    color: var(--r-dim);
  }
  .tool .meta .tag.acc { color: var(--r-accent); border-color: var(--r-accent); }
  .tool .arrow {
    position: absolute; right: 16px; top: 18px;
    color: var(--r-very); font-size: 14px;
    transition: color 100ms, transform 100ms;
  }
  .tool:hover .arrow { color: var(--r-accent); transform: translateX(2px); }

  /* Tools index reuses .cat-head from blog/index — duplicated here so
     each page is self-contained. Identical styling on purpose. */
  .cat-head {
    display: grid; grid-template-columns: auto 1fr auto;
    gap: 12px; align-items: baseline;
    margin: 32px 0 14px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--r-ink);
  }
  .cat-head .cat-name {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 13px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--r-ink);
  }
  .cat-head .cat-rule { align-self: center; height: 0; border-bottom: 1px dotted var(--r-very); }
  .cat-head .cat-count {
    font-size: var(--r-fs-xs); letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--r-very);
  }
  .cat-head .cat-count b { color: var(--r-ink); font-weight: 700; }

  .byo {
    margin-top: 28px;
    padding: 22px 24px;
    border: 1px dashed var(--r-accent);
    background: var(--r-accent-soft);
  }
  .byo h3 {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 14px; margin: 0 0 6px;
    letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--r-ink);
  }
  .byo p { margin: 0 0 10px; color: var(--r-dim); font-size: 12px; }
  .byo p code { background: var(--r-paper); padding: 1px 5px; font-size: 0.92em; }
  .byo .links { display: flex; gap: 14px; flex-wrap: wrap; font-size: 12px; }
  .byo .links a { color: var(--r-accent); }

  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
    .tool { border-right: 0; }
    .tool:nth-last-child(2) { border-bottom: 1px dashed var(--r-very); }
    .tools-strip { grid-template-columns: 1fr; }
  }
</style>
