---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";
import { PLATFORMS, type Platform } from "../../data/platforms.ts";

export function getStaticPaths() {
  return PLATFORMS.map((platform) => ({
    params: { slug: platform.slug },
    props: { platform },
  }));
}

interface Props {
  platform: Platform;
}

const { platform } = Astro.props;

const STATUS_COPY: Record<Platform["status"], { label: string; color: string }> = {
  live: { label: "Live", color: "var(--color-success, var(--color-accent))" },
  under_review: { label: "Under review", color: "var(--color-accent)" },
  planned: { label: "Planned", color: "var(--color-text-muted)" },
};
const status = STATUS_COPY[platform.status];

// Per-platform code sample. Bluesky is the only platform shipping today
// so it uses a real example body; the others use the same shape with
// the platform's slug — accurate to the API contract, just not yet
// publishable end-to-end.
const platformValue = platform.slug === "twitter" ? "twitter" : platform.slug;
const codeSample = `// One POST. Same shape on every platform.
// Idempotency keys make retries safe; preflight runs before upstream.

await fetch("https://api.letmepost.dev/v1/posts", {
  method: "POST",
  headers: {
    Authorization: "Bearer lmp_live_…",
    "Idempotency-Key": crypto.randomUUID(),
  },
  body: JSON.stringify({
    account: { platform: "${platformValue}", id: "acc_…" },
    text: "Shipping to ${platform.name} via letmepost.dev",
${
  platform.videoSupport
    ? `    media: [{ kind: "video", mediaId: "med_…" }],\n`
    : `    media: [{ kind: "image", mediaId: "med_…", altText: "…" }],\n`
}  }),
});`;

const contentTypes: { label: string; icon: string; supported: boolean }[] = [
  { label: "Text", icon: "text-aa", supported: true },
  { label: "Images", icon: "image", supported: true },
  { label: "Video", icon: "video-camera", supported: platform.videoSupport },
  {
    label: "Carousel",
    icon: "frame-corners",
    supported: platform.carouselSupport,
  },
];

const howItWorks = [
  {
    n: "01",
    title: "Mint an API key",
    body: "Sign in to the dashboard and create a Bearer key. Per-org by default; scope to a single profile if you want extra isolation.",
  },
  {
    n: "02",
    title: `Connect a ${platform.name} account`,
    body:
      platform.slug === "bluesky"
        ? "Generate an app password at bsky.app/settings/app-passwords and submit it via /v1/accounts/connect/bluesky/complete. No OAuth review."
        : platform.slug === "facebook" || platform.slug === "instagram"
          ? "POST /v1/accounts/connect/facebook starts Facebook Login for Business. One consent grants Pages + linked IG Business in a single fan-out."
          : `POST /v1/accounts/connect/${platform.slug} returns the OAuth authorize URL. Redirect the user; the callback completes the handshake and stores the encrypted token.`,
  },
  {
    n: "03",
    title: "Send a post",
    body: "POST /v1/posts with the connected account id. Preflight rules run locally; webhooks fire on every state transition.",
  },
];

const features = [
  {
    icon: "lightning",
    title: "Preflight, not postflight",
    body: `Every documented ${platform.name} constraint runs locally before the upstream call — no opaque platform 400s.`,
  },
  {
    icon: "lock-key",
    title: "Tokens encrypted at rest",
    body: "AES-256-GCM envelope encryption with per-row data-keys. Refresh handled on the platform's schedule.",
  },
  {
    icon: "shuffle",
    title: "Idempotency by default",
    body: "Idempotency-Key on every write. Retries are safe; double-posting from a worker restart isn't a thing.",
  },
];

const siteUrl = Astro.site!.toString().replace(/\/$/, "");

/**
 * Two structured-data graphs:
 *   - BreadcrumbList lights up the breadcrumb display on Google's SERP
 *   - SoftwareApplication tells search engines this is an API integration,
 *     which can surface as a richer result for ICP-shape queries
 *     ("twitter publishing api", etc).
 */
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${siteUrl}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Platforms",
      item: `${siteUrl}/#platforms`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: platform.name,
      item: `${siteUrl}/platforms/${platform.slug}/`,
    },
  ],
};

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: `${platform.name} API via letmepost.dev`,
  description: platform.pitch,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free during alpha",
  },
  publisher: { "@id": `${siteUrl}/#organization` },
};
---

<BaseLayout
  title={`${platform.name} API`}
  description={`Publish to ${platform.name} via letmepost.dev — preflight validation, idempotency keys, transparent errors.`}
  ogType="product"
  jsonLd={[breadcrumbJsonLd, softwareJsonLd]}
>
  {/* Status marker — read by the central Analytics script so the
      `platform_page.viewed` event can attach the correct status without
      duplicating the resolver in two places. */}
  <span
    data-platform-status={platform.status === "live" ? "live" : "coming-soon"}
    hidden
  ></span>

  <!-- Hero -->
  <section class="section-hero">
    <div class="container">
      {/* Pre-headline meta line: status + tagline + back-link, all
          tiny and quiet. The platform name + icon carry the page
          via the h1 below. */}
      <div class="flex flex-wrap items-center gap-3 mb-9 text-[0.85rem] text-text-muted">
        <a
          href="/#platforms"
          class="inline-flex items-center gap-1.5 no-underline text-text-muted hover:text-accent transition-colors"
        >
          <Icon name="ph:arrow-left" width={11} height={11} />
          All platforms
        </a>
        <span class="opacity-40">·</span>
        <span class="inline-flex items-center gap-1.5">
          <span
            class="inline-block w-[7px] h-[7px]"
            style={`background: ${status.color};`}
            aria-hidden="true"
          ></span>
          {status.label}
        </span>
        <span class="opacity-40">·</span>
        <span>{platform.tagline}</span>
      </div>

      <div class="flex items-center gap-5 mb-2">
        <Icon name={`ph:${platform.icon}`} width={48} height={48} class="text-text" />
        <h1 class="!m-0">{platform.name}</h1>
      </div>

      <p class="text-[1.2rem] leading-[1.65] mt-7 mb-10 text-text-secondary">
        {platform.pitch}
      </p>

      <div class="flex gap-[0.7rem] flex-wrap">
        <a
          class="btn btn-primary"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props={JSON.stringify({
            location: "hero",
            target: "dashboard",
            page: "platform-detail",
            label: `Start building free — ${platform.name}`,
          })}
        >
          Start building free
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a
          class="btn btn-secondary"
          href="https://docs.letmepost.dev/quickstart"
          data-analytics-event="docs.link_clicked"
          data-analytics-props={JSON.stringify({
            from_page: "platform-detail",
            to_section: "quickstart",
          })}
        >
          Quickstart
        </a>
      </div>

      <p class="text-[0.85rem] mt-6 text-text-muted">
        No credit card required · Free during alpha ·
        <a
          href="https://docs.letmepost.dev/api-reference"
          class="text-accent"
          data-analytics-event="docs.link_clicked"
          data-analytics-props={JSON.stringify({
            from_page: "platform-detail",
            to_section: "api-reference",
          })}
        >API reference →</a>
      </p>
    </div>
  </section>

  <!-- Code sample -->
  <section class="section-tight">
    <div class="container">
      <div class="border border-border-strong bg-code-bg">
        <div
          class="flex items-center gap-[0.5rem] py-[0.75rem] px-[1rem] border-b border-[hsl(24_10%_16%)] text-[0.75rem] text-code-muted tracking-[0.02em]"
        >
          <span class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#ff5f57]" aria-hidden="true"></span>
          <span class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#febc2e]" aria-hidden="true"></span>
          <span class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#28c840]" aria-hidden="true"></span>
          <span class="ml-[0.7rem]">post-to-{platform.slug}.ts</span>
        </div>
        <Code code={codeSample} lang="ts" theme="github-dark-dimmed" />
      </div>
    </div>
  </section>

  <!-- Constraints + gotcha -->
  <section class="section">
    <div class="container">
      <h2 class="!mt-0">What ships on day one.</h2>
      <p class="text-text-muted">
        {platform.detail}
      </p>

      {platform.gotcha ? (
        <div
          class="border-l-4 mt-7 py-4 px-5"
          style="border-color: var(--color-accent); background: var(--color-accent-soft);"
        >
          <div class="text-[0.78rem] uppercase tracking-[0.1em] text-accent font-bold mb-2">Heads up</div>
          <p class="m-0 text-[0.98rem] text-text-secondary">{platform.gotcha}</p>
        </div>
      ) : null}
    </div>
  </section>

  <!-- Demo placeholder -->
  <section class="section">
    <div class="container">
      <div class="text-[0.78rem] uppercase tracking-[0.1em] text-text-muted mb-4 font-bold">Playground</div>
      <div
        class="border border-dashed border-border-strong p-10 text-center"
      >
        <Icon
          name="ph:play-circle"
          width={36}
          height={36}
          class="mx-auto mb-4 text-text-muted"
        />
        <h3 class="!mt-0 !mb-2 !text-[1.1rem]">Live {platform.name} demo coming soon</h3>
        <p class="text-text-muted text-[0.95rem] m-0 max-w-[36rem] mx-auto">
          Connect an account and send a real post through the API — no signup form, no credit card. Watch this space.
        </p>
      </div>
    </div>
  </section>

  <!-- Content types -->
  <section class="section">
    <div class="container">
      <div class="text-[0.78rem] uppercase tracking-[0.1em] text-text-muted mb-4 font-bold">Content types</div>
      <div class="flex gap-[0.6rem] flex-wrap">
        {contentTypes.map((ct) => (
          <span
            class={`inline-flex items-center gap-[0.55rem] py-[0.55rem] px-[0.95rem] text-[0.9rem] border ${
              ct.supported
                ? "border-border-strong text-text"
                : "border-border text-text-muted opacity-50 line-through"
            }`}
          >
            <Icon name={`ph:${ct.icon}`} width={15} height={15} />
            {ct.label}
          </span>
        ))}
      </div>
      <p class="text-[0.85rem] mt-5 text-text-muted">
        Crossed-out types aren't supported on {platform.name} in v1 — see <a href="https://docs.letmepost.dev/preflight" class="text-accent">preflight rules</a> for the exact ceilings.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="container">
      <h2 class="!mt-0">How it works.</h2>
      <p class="text-text-muted">Three steps. Minutes, not days.</p>

      <ol class="list-none p-0 mt-8 mb-4">
        {howItWorks.map((step) => (
          <li class="flex gap-[1.4rem] py-6 border-t border-border first:border-t-0">
            <div class="text-accent font-extrabold text-[0.95rem] min-w-10 pt-[0.15rem] tracking-[0.04em]">
              {step.n}
            </div>
            <div>
              <h3 class="!m-0 !mb-[0.5rem] !text-[1.1rem] !font-bold">
                {step.title}
              </h3>
              <p class="text-text-muted m-0 text-[1rem] leading-[1.65]">{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Features grid -->
  <section class="section">
    <div class="container">
      <h2 class="!mt-0">Why letmepost vs going direct.</h2>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-8">
        {features.map((feat) => (
          <div class="border border-border-strong p-7">
            <Icon name={`ph:${feat.icon}`} width={24} height={24} class="text-accent mb-4" />
            <h3 class="!m-0 !mb-3 !text-[1rem] !font-bold">{feat.title}</h3>
            <p class="text-text-muted m-0 text-[0.93rem] leading-[1.6]">{feat.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section">
    <div class="container">
      <h2 class="!mt-0">Ready to ship?</h2>
      <p class="text-text-muted">
        Star the repo. Connect a {platform.name} account. Send your first post in under 90 seconds.
      </p>
      <div class="flex gap-[0.7rem] flex-wrap mt-2">
        <a
          class="btn btn-primary"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props={JSON.stringify({
            location: "platform-page",
            target: "dashboard",
            page: "platform-detail",
            label: `Start building free — ${platform.name} final`,
          })}
        >
          Start building free
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a
          class="btn btn-secondary"
          href={`https://docs.letmepost.dev/platforms/${platform.slug === "facebook" ? "facebook" : platform.slug}`}
          data-analytics-event="docs.link_clicked"
          data-analytics-props={JSON.stringify({
            from_page: "platform-detail",
            to_section: `platforms/${platform.slug}`,
          })}
        >
          {platform.name} docs
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
