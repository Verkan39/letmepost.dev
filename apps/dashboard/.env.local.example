NEXT_PUBLIC_API_URL=http://localhost:3000

# Override the launch-state of platforms in the dashboard UI without a
# code change. Mirrors the API's `PLATFORM_STATE_OVERRIDES` env — set
# BOTH so the dashboard tile and the backend gate agree.
#
# Use case: temporarily un-grey Meta tiles while recording App Review
# demo videos, then revert. Format: comma-separated `platform:state`
# pairs. Valid states: live, trial, pending.
#
#   NEXT_PUBLIC_PLATFORM_STATE_OVERRIDES=facebook:live,instagram:live,threads:live
NEXT_PUBLIC_PLATFORM_STATE_OVERRIDES=

# PostHog product analytics. Leave blank to disable — the provider is a
# no-op when NEXT_PUBLIC_POSTHOG_KEY is unset, so local dev stays quiet
# unless you explicitly want to send events.
#
# Region hosts:
#   US:  https://us.i.posthog.com   (default)
#   EU:  https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
