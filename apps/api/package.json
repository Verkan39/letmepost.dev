    "hono": "^4.6.13",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@letmepost/config-tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "msw": "^2.6.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
