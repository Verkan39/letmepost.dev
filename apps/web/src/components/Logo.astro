---
interface Props {
  wordmark?: boolean;
  size?: number;
}

// Logo size and wordmark size were both bumped in the May-2026 design
// audit — the navbar grew taller (78px) and the body type scale moved
// up to 16px / 2.25rem h2 / 3.5rem h1. The previous 32px square + 1.6rem
// wordmark visually disappeared next to the new heading scale. Square
// stays at 32px (it's a focal mark, not subordinate to text), but the
// wordmark grows to 1.95rem to balance.
const { wordmark = true, size = 32 } = Astro.props;
---

<a
  href="/"
  aria-label="letmepost.dev"
  class="inline-flex items-center gap-[0.3rem] no-underline text-text hover:text-text leading-none"
>
  <span
    class="inline-flex items-center justify-center text-accent shrink-0"
    style={`width: ${size}px; height: ${size}px;`}
  >
    <svg
      width={size}
      height={size}
      viewBox="0 0 32 32"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="16" cy="16" r="15" fill="currentColor"></circle>
      <rect
        x="9.5"
        y="9.5"
        width="13"
        height="13"
        fill="var(--color-bg)"
        transform="rotate(16 16 16)"
      ></rect>
    </svg>
  </span>

  {
    wordmark && (
      <span class="inline-flex items-baseline">
        <span class="font-serif italic font-normal text-[1.95rem] max-[480px]:text-[1.5rem] tracking-[-0.01em] leading-none text-text">
          letmepost
        </span>
        <span class="font-serif italic font-normal text-[1.95rem] max-[480px]:text-[1.5rem] tracking-[-0.01em] leading-none text-accent">
          .dev
        </span>
        <span class="ml-[0.5rem] font-mono text-[0.62rem] font-semibold text-text-muted tracking-[0.05em] opacity-60 uppercase self-end pb-[0.2rem]">
          [alpha]
        </span>
      </span>
    )
  }
</a>
