---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

/**
 * Blog index — Clarity direction. Featured most-recent post on top,
 * then a dated list of the rest. Posts come from the Notion-backed
 * "blog" content collection.
 */

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts[0];
const rest = posts.slice(1);

function fmtDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function readingMin(post: (typeof posts)[number]): number {
  if (post.data.readingTime) return post.data.readingTime;
  const body = post.body ?? "";
  const words = body.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}
---

<BaseLayout
  title="Engineering blog: social media API deep-dives"
  description="Engineering notes from the platform-review queue. Version sunsets, async media rejections, idempotency, and the failure modes nobody else writes down."
>
  <header class="wrap page-head">
    <p class="eyebrow">Blog</p>
    <h1 class="cl-h1" style="max-width: 20ch;">
      Engineering notes from the <span class="acc">platform-review queue</span>.
    </h1>
    <p class="sub" style="max-width: 58ch;">
      The failure modes nobody else writes down: version sunsets, async media
      rejections, double-posting loops, and how a developer-grade publishing API
      handles them.
    </p>
  </header>

  {posts.length === 0 && (
    <section class="wrap sec">
      <p class="lead">No posts yet. <a class="acc" href="/rss.xml">Subscribe via RSS</a>.</p>
    </section>
  )}

  {featured && (
    <section class="wrap" style="padding-bottom: 8px;">
      <a class="feat" href={`/blog/${featured.id}`}>
        <div
          class="ph"
          data-has-image={featured.data.heroImage ? "1" : "0"}
          style={featured.data.heroImage ? `background-image: url(${featured.data.heroImage});` : ""}
        >
          {!featured.data.heroImage && <span>[ {featured.data.category} ]</span>}
        </div>
        <div class="ft">
          <div class="meta">{fmtDate(featured.data.pubDate)} · {featured.data.author} · {readingMin(featured)} min read</div>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.description}</p>
        </div>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <section class="wrap sec tight" style="padding-top: 24px;">
      <ul class="post-list">
        {rest.map((post) => (
          <li>
            <a href={`/blog/${post.id}`}>
              <span class="pl-date">{fmtDate(post.data.pubDate)}</span>
              <span>
                <span class="pl-title">{post.data.title}</span>
                <span class="pl-desc">{post.data.description}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="wrap">
    <div class="final">
      <h2>Stop reading about failure modes. Ship past them.</h2>
      <p>Free during alpha. No credit card. Send your first post in ninety seconds.</p>
      <div class="ctas">
        <a class="btn pri lg" href="https://dashboard.letmepost.dev">Start free →</a>
        <a class="btn ghost lg" href="https://docs.letmepost.dev">Read the docs ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .feat { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 0; border: 1px solid var(--line); border-radius: 18px; overflow: hidden; margin-top: 40px; text-decoration: none; color: inherit; transition: border-color 140ms; }
  .feat:hover { border-color: var(--acc); }
  .feat .ph { background: repeating-linear-gradient(135deg, var(--panel-2) 0 14px, var(--bg) 14px 28px); background-size: cover; background-position: center; border-right: 1px solid var(--line); display: flex; align-items: center; justify-content: center; min-height: 280px; }
  .feat .ph[data-has-image="1"] { background-repeat: no-repeat; }
  .feat .ph span { font-family: var(--mono); font-size: 12px; color: var(--faint); letter-spacing: 0.04em; text-transform: uppercase; }
  .feat .ft { padding: 40px 40px; display: flex; flex-direction: column; justify-content: center; }
  .feat h2 { font-family: var(--disp); font-weight: 600; font-size: 30px; line-height: 1.12; letter-spacing: -0.02em; margin: 0 0 14px; }
  .feat p { font-size: 16px; color: var(--mut); margin: 0 0 18px; line-height: 1.55; }
  .feat .meta { font-family: var(--mono); font-size: 12px; color: var(--faint); margin-bottom: 16px; }
  .post-list { list-style: none; padding: 0; margin: 40px 0 0; border-top: 1px solid var(--line); }
  .post-list li a { display: grid; grid-template-columns: 130px 1fr; gap: 28px; padding: 28px 0; border-bottom: 1px solid var(--line); text-decoration: none; color: inherit; align-items: baseline; }
  .post-list li a:hover .pl-title { color: var(--acc); }
  .pl-date { font-family: var(--mono); font-size: 12px; color: var(--faint); padding-top: 4px; }
  .pl-title { display: block; font-family: var(--disp); font-weight: 600; font-size: 22px; letter-spacing: -0.01em; margin: 0 0 6px; line-height: 1.2; }
  .pl-desc { display: block; font-size: 15px; color: var(--mut); margin: 0; line-height: 1.55; max-width: 64ch; }
  @media (max-width: 860px) {
    .feat { grid-template-columns: 1fr; }
    .feat .ph { border-right: 0; border-bottom: 1px solid var(--line); min-height: 180px; }
    .post-list li a { grid-template-columns: 1fr; gap: 6px; }
  }
</style>
