---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { APIS } from "../../data/platforms.ts";

/**
 * API index — Clarity direction. The three v1 surfaces (Publishing,
 * Media, Webhooks) as a card grid into /api/[slug], plus the shared
 * "one auth, one error shape" guarantee. Copy preserved from the
 * receipt version.
 */
---

<BaseLayout
  title="API reference: publishing, media, webhooks"
  description="The v1 API surface. Publishing, media uploads, HMAC-signed webhooks. One POST endpoint, eight platforms, idempotency by default."
>
  <header class="wrap page-head">
    <p class="crumb"><a href="/">letmepost</a> / api</p>
    <p class="eyebrow">API surface</p>
    <h1 class="cl-h1" style="max-width: 14ch;">The API surface.</h1>
    <p class="sub" style="max-width: 62ch;">
      <b>Publishing</b> is the heart of it. <b>Media</b> uploads bytes once and
      references them by id. <b>Webhooks</b> push state changes back to you. Same auth,
      same error envelope, same idempotency rules across the whole API.
    </p>
    <div class="ctas" style="margin-top: 30px;">
      <a class="btn pri lg" href="https://dashboard.letmepost.dev">Get an API key →</a>
      <a class="btn ghost lg" href="https://docs.letmepost.dev/api-reference">Full reference ↗</a>
    </div>
  </header>

  <section class="wrap sec tight" style="padding-top: 40px;">
    <div class="cards c3">
      {
        APIS.map((api) => (
          <a class="card" href={`/api/${api.slug}`}>
            <div class="ic"><Icon name={`ph:${api.icon}`} width={20} height={20} /></div>
            <h3>{api.name}</h3>
            <p>{api.pitch}</p>
            <div class="meta">{api.detail}</div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="wrap sec divider">
    <p class="kicker">Consistent by design</p>
    <h2 class="cl-h2">One auth, one error shape, one retry contract.</h2>
    <p class="lead">
      Same <code class="inl">Authorization: Bearer lmp_live_…</code> on every call. Same
      <code class="inl">Idempotency-Key</code> semantics on every write. Same failure
      envelope (stable code, the rule that fired, a remediation hint, and a request id)
      on every non-2xx. Build against one endpoint and the others feel familiar in minutes.
    </p>
    <div class="ctas" style="margin-top: 26px;">
      <a class="btn ghost lg" href="https://docs.letmepost.dev/api-reference">Full reference ↗</a>
      <a class="btn ghost lg" href="/platforms">Supported platforms →</a>
    </div>
  </section>

  <section class="wrap">
    <div class="final">
      <h2>Make your first call in minutes.</h2>
      <p>Free during alpha. No credit card. Grab a key and POST to every connected account in one request.</p>
      <div class="ctas">
        <a class="btn pri lg" href="https://dashboard.letmepost.dev">Get an API key →</a>
        <a class="btn ghost lg" href="https://docs.letmepost.dev">Read the docs ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>
