{
  "name": "@letmepost/schemas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./platform-state": {
      "types": "./dist/platform-state.d.ts",
      "default": "./dist/platform-state.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@letmepost/config-tsconfig": "workspace:*",
    "typescript": "^5.7.2"
  }
}
