---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

// YouTube Data API v3 quota cost table — official numbers from
// developers.google.com/youtube/v3/determine_quota_cost. The big ones are
// search.list (100) and videos.insert (1600); the rest are mostly 50.
type QuotaItem = { id: string; label: string; cost: number; note?: string };
type QuotaGroup = { group: string; items: QuotaItem[] };
const operations: QuotaGroup[] = [
  {
    group: "Reads (cheap)",
    items: [
      { id: "videos-list", label: "videos.list", cost: 1 },
      { id: "channels-list", label: "channels.list", cost: 1 },
      { id: "playlists-list", label: "playlists.list", cost: 1 },
      { id: "playlistItems-list", label: "playlistItems.list", cost: 1 },
      { id: "comments-list", label: "comments.list", cost: 1 },
    ],
  },
  {
    group: "Search (expensive read)",
    items: [
      {
        id: "search-list",
        label: "search.list",
        cost: 100,
        note: "Eats quota fastest of any read.",
      },
    ],
  },
  {
    group: "Writes — standard",
    items: [
      { id: "videos-update", label: "videos.update", cost: 50 },
      { id: "videos-delete", label: "videos.delete", cost: 50 },
      { id: "videos-rate", label: "videos.rate", cost: 50 },
      { id: "thumbnails-set", label: "thumbnails.set", cost: 50 },
      { id: "playlists-insert", label: "playlists.insert", cost: 50 },
      { id: "playlistItems-insert", label: "playlistItems.insert", cost: 50 },
      { id: "comments-insert", label: "comments.insert", cost: 50 },
      { id: "subscriptions-insert", label: "subscriptions.insert", cost: 50 },
      { id: "liveBroadcasts-insert", label: "liveBroadcasts.insert", cost: 50 },
    ],
  },
  {
    group: "Captions",
    items: [
      { id: "captions-insert", label: "captions.insert", cost: 400 },
      { id: "captions-update", label: "captions.update", cost: 450 },
      { id: "captions-list", label: "captions.list", cost: 50 },
    ],
  },
  {
    group: "Upload (the killer)",
    items: [
      {
        id: "videos-insert",
        label: "videos.insert",
        cost: 1600,
        note: "6 uploads exhausts the default 10,000-unit quota.",
      },
    ],
  },
];
---

<BaseLayout
  title="YouTube API quota cost calculator"
  description="Free YouTube Data API v3 quota calculator — pick operations, see daily quota burn against your 10,000-unit default. Spot videos.insert before it runs you dry."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "YouTube API quota cost calculator",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Calculate YouTube Data API v3 quota burn from a daily call profile. Includes the official cost table.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">YouTube API quota calculator.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        The default YouTube Data API v3 daily quota is 10,000 units. <code
          >videos.insert</code
        > is 1,600 each. <code>search.list</code> is 100. Most reads are 1.
        Plug in your daily call mix to see when you'd run dry.
      </p>

      <div class="lmp-yt" data-yt>
        <div class="lmp-yt-header">
          <div class="lmp-yt-quota">
            <label
              for="lmp-yt-quota-input"
              class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
              >Your daily quota</label
            >
            <input
              id="lmp-yt-quota-input"
              type="number"
              min="0"
              value="10000"
              data-yt-quota
            />
          </div>
          <div class="lmp-yt-summary">
            <div class="lmp-yt-summary-row">
              <span class="text-text-muted">Daily usage</span>
              <span class="lmp-yt-usage" data-yt-usage>0 units</span>
            </div>
            <div class="lmp-yt-track" aria-hidden="true">
              <div
                class="lmp-yt-fill"
                data-yt-fill
                style="width: 0%"
              ></div>
            </div>
            <div class="lmp-yt-summary-row">
              <span class="text-text-muted">Until quota exhausts</span>
              <span data-yt-status>—</span>
            </div>
          </div>
        </div>

        {
          operations.map((group) => (
            <div class="lmp-yt-group">
              <div class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted mb-2">
                {group.group}
              </div>
              <ul class="list-none p-0 m-0">
                {group.items.map((op) => (
                  <li class="lmp-yt-row">
                    <div class="lmp-yt-row-label">
                      <span class="font-mono">{op.label}</span>
                      {op.note ? (
                        <span class="lmp-yt-row-note">{op.note}</span>
                      ) : null}
                    </div>
                    <div class="lmp-yt-row-cost">
                      <span class="text-text-muted text-[0.78rem]">
                        {op.cost} u/call
                      </span>
                      <input
                        type="number"
                        min="0"
                        step="1"
                        value="0"
                        data-yt-input
                        data-cost={op.cost}
                        aria-label={`Calls per day for ${op.label}`}
                      />
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Why this matters.</h2>
      <p class="text-text-muted">
        YouTube's quota is the most expensive single resource in v1 of
        <code>letmepost.dev</code>. Six uploads exhausts the default quota.
        Three uploads plus a fistful of <code>search.list</code> calls also exhausts it. We surface
        per-account quota usage in the dashboard so you don't find out at the
        wire.
      </p>
      <p class="text-text-muted">
        Higher quotas are available by audit; expect ~3–6 weeks for the first
        review and one-time CASA verification.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Quota you don't have to track.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code> tracks per-account quota usage and surfaces
        a <code>token.expiring</code> / <code>quota.low</code> webhook before you'd hit the wall. One less
        thing to instrument.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="/platforms/youtube">
          YouTube on letmepost.dev
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="https://docs.letmepost.dev/webhooks"
          >Webhook docs</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-yt {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-yt-header {
    display: grid;
    grid-template-columns: minmax(160px, 200px) 1fr;
    gap: 1rem;
    align-items: stretch;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1rem;
  }
  @media (max-width: 540px) {
    .lmp-yt-header {
      grid-template-columns: 1fr;
    }
  }
  .lmp-yt-quota {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .lmp-yt-quota input,
  .lmp-yt-row-cost input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    padding: 0.45rem 0.6rem;
    width: 100%;
    outline: none;
  }
  .lmp-yt-quota input:focus,
  .lmp-yt-row-cost input:focus {
    border-color: var(--color-accent);
  }
  .lmp-yt-summary {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
  }
  .lmp-yt-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }
  .lmp-yt-usage {
    font-weight: 700;
  }
  .lmp-yt-track {
    height: 4px;
    background: var(--color-border);
    overflow: hidden;
  }
  .lmp-yt-fill {
    height: 100%;
    background: var(--color-accent);
    transition:
      width 80ms linear,
      background 120ms ease;
  }
  .lmp-yt[data-state="warn"] .lmp-yt-fill {
    background: hsl(38 75% 48%);
  }
  .lmp-yt[data-state="over"] .lmp-yt-fill {
    background: var(--color-error);
  }
  .lmp-yt-group {
    margin-bottom: 1rem;
  }
  .lmp-yt-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px dashed var(--color-border);
  }
  .lmp-yt-row:last-child {
    border-bottom: none;
  }
  .lmp-yt-row-label {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .lmp-yt-row-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  .lmp-yt-row-cost {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .lmp-yt-row-cost input {
    width: 5.5rem;
  }
</style>

<script>
  function setupYt(root: HTMLElement) {
    const inputs = Array.from(
      root.querySelectorAll<HTMLInputElement>("[data-yt-input]"),
    );
    const quotaInput = root.querySelector<HTMLInputElement>("[data-yt-quota]");
    const usageEl = root.querySelector<HTMLElement>("[data-yt-usage]");
    const fillEl = root.querySelector<HTMLElement>("[data-yt-fill]");
    const statusEl = root.querySelector<HTMLElement>("[data-yt-status]");

    function recompute() {
      let total = 0;
      for (const input of inputs) {
        const calls = parseInt(input.value || "0", 10) || 0;
        const cost = parseInt(input.dataset.cost || "0", 10) || 0;
        total += calls * cost;
      }
      const quota = parseInt(quotaInput?.value || "10000", 10) || 10000;
      const pct = quota > 0 ? (total / quota) * 100 : 0;

      if (usageEl) {
        usageEl.textContent = `${total.toLocaleString()} units`;
      }
      if (fillEl) {
        fillEl.style.width = `${Math.min(pct, 100)}%`;
      }

      let state: "ok" | "warn" | "over" = "ok";
      if (pct >= 100) state = "over";
      else if (pct >= 85) state = "warn";
      root.dataset.state = state;

      if (statusEl) {
        if (total === 0) {
          statusEl.textContent = "—";
        } else if (total > quota) {
          statusEl.textContent = "exceeded today";
        } else if (total === quota) {
          statusEl.textContent = "exactly at limit";
        } else {
          const remaining = quota - total;
          // If usage rate fits in 1 day, show how many days till exhausted
          // assuming the same rate every day. Cap at 365 for sane display.
          const days = total > 0 ? Math.floor(quota / total) : 0;
          statusEl.textContent =
            days <= 1
              ? `${remaining.toLocaleString()} units left today`
              : `${days} days at this rate`;
        }
      }
    }

    inputs.forEach((input) => input.addEventListener("input", recompute));
    quotaInput?.addEventListener("input", recompute);

    recompute();
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>("[data-yt]").forEach(setupYt);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
