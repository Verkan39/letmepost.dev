---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";

// Action -> minimum scope set. Order matters for the rendered list:
// auth/profile actions first, then write actions, then read-only,
// then ads. Each action's scopes are deduped client-side when assembled.
const actions = [
  {
    id: "signin",
    label: "Sign in via LinkedIn (OIDC)",
    scopes: ["openid"],
    note: "Returns an ID token only. No profile claims.",
  },
  {
    id: "profile",
    label: "Read user name + profile photo",
    scopes: ["openid", "profile"],
  },
  {
    id: "email",
    label: "Read user email address",
    scopes: ["openid", "profile", "email"],
  },
  {
    id: "post-personal",
    label: "Post on user's personal feed",
    scopes: ["w_member_social"],
    note: "Member-level — does not let you post for an org.",
  },
  {
    id: "post-org",
    label: "Post on a company page",
    scopes: ["w_organization_social"],
    note: "Member must be admin of the org. Often paired with rw_organization_admin.",
  },
  {
    id: "read-org-social",
    label: "Read company page posts and stats",
    scopes: ["r_organization_social"],
  },
  {
    id: "manage-org",
    label: "Manage company page (read + write)",
    scopes: ["rw_organization_admin"],
    note: "Implies r_organization_admin and r_organization_social for the orgs the user administers.",
  },
  {
    id: "ads-read",
    label: "Read ads campaigns + reporting",
    scopes: ["r_ads", "r_ads_reporting"],
  },
  {
    id: "ads-manage",
    label: "Manage ads campaigns",
    scopes: ["rw_ads", "r_ads_reporting"],
  },
  {
    id: "leadgen",
    label: "Lead Gen Forms automation",
    scopes: ["r_marketing_leadgen_automation"],
  },
];

const allScopes = [
  {
    name: "openid",
    purpose: "OIDC sign-in. Returns an ID token.",
    status: "current",
  },
  {
    name: "profile",
    purpose: "Basic profile claims (name, picture, locale).",
    status: "current",
  },
  {
    name: "email",
    purpose: "User's primary email address.",
    status: "current",
  },
  {
    name: "w_member_social",
    purpose: "Post, comment, react on the member's behalf.",
    status: "current",
  },
  {
    name: "w_organization_social",
    purpose: "Post, comment, react as a company page.",
    status: "current",
  },
  {
    name: "r_organization_social",
    purpose: "Read company page posts and engagement stats.",
    status: "current",
  },
  {
    name: "rw_organization_admin",
    purpose:
      "Full read/write on company pages the user administers. Includes posting.",
    status: "current",
  },
  {
    name: "r_organization_admin",
    purpose: "Read company page settings and admin info.",
    status: "current",
  },
  {
    name: "r_ads",
    purpose: "Read LinkedIn ads campaigns and creatives.",
    status: "current",
  },
  {
    name: "rw_ads",
    purpose: "Read + write LinkedIn ads campaigns.",
    status: "current",
  },
  {
    name: "r_ads_reporting",
    purpose: "Read campaign performance metrics.",
    status: "current",
  },
  {
    name: "r_marketing_leadgen_automation",
    purpose: "Pull Lead Gen Form submissions.",
    status: "current",
  },
  {
    name: "r_liteprofile",
    purpose: "DEPRECATED — replaced by openid + profile.",
    status: "deprecated",
  },
  {
    name: "r_emailaddress",
    purpose: "DEPRECATED — replaced by openid + profile + email.",
    status: "deprecated",
  },
  {
    name: "r_basicprofile",
    purpose: "DEPRECATED — replaced by openid + profile (with limited fields).",
    status: "deprecated",
  },
];

const exampleAuthorizeUrl = `https://www.linkedin.com/oauth/v2/authorization
  ?response_type=code
  &client_id=YOUR_CLIENT_ID
  &redirect_uri=YOUR_REDIRECT
  &state=RANDOM_STATE
  &scope=openid%20profile%20email%20w_member_social`;
---

<BaseLayout
  title="LinkedIn OAuth scope checker"
  description="Free LinkedIn OAuth scope checker. Pick what you want to do, get the minimum scope set you need to request — no over-asking, no under-asking."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "LinkedIn OAuth scope checker",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Pick LinkedIn API actions and see the minimum OAuth scope set required. Includes the deprecated r_liteprofile / r_emailaddress mappings.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">LinkedIn OAuth scope checker.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        Pick what your app needs to do. We compute the minimum scope set —
        and bonus, the <code>scope</code> param you paste straight into your
        LinkedIn authorize URL.
      </p>

      <div class="lmp-scope" data-scope>
        <ul class="list-none p-0 m-0">
          {
            actions.map((a) => (
              <li class="lmp-scope-row">
                <label class="lmp-scope-label">
                  <input
                    type="checkbox"
                    data-scope-action
                    data-scopes={JSON.stringify(a.scopes)}
                    aria-describedby={`note-${a.id}`}
                  />
                  <span class="lmp-scope-text">
                    <span class="font-bold text-[0.92rem]">{a.label}</span>
                    {a.note ? (
                      <span class="lmp-scope-note" id={`note-${a.id}`}>
                        {a.note}
                      </span>
                    ) : null}
                    <span class="lmp-scope-list">
                      {a.scopes.join(" + ")}
                    </span>
                  </span>
                </label>
              </li>
            ))
          }
        </ul>

        <div class="lmp-scope-output">
          <div class="lmp-scope-output-label">
            <span class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
              >Minimum scope param</span
            >
            <button
              type="button"
              class="lmp-counter-copy"
              data-scope-copy
              aria-label="Copy scope string"
            >
              Copy
            </button>
          </div>
          <code class="lmp-scope-out" data-scope-out>—</code>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">How it slots into your authorize URL.</h2>
      <Code code={exampleAuthorizeUrl} lang="text" theme="github-dark" />
      <p class="text-text-muted mt-4 text-[0.88rem]">
        Scope strings are space-separated and URL-encoded. LinkedIn rejects an
        authorize request that asks for a scope your app doesn't have approved
        — so request the minimum set you need.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Every LinkedIn scope, current and deprecated.</h2>
      <ul class="list-none p-0 mt-4">
        {
          allScopes.map((s) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <code class="font-mono text-[0.9rem]">{s.name}</code>
                <span
                  class={
                    s.status === "deprecated"
                      ? "text-[0.72rem] uppercase tracking-[0.08em] text-error"
                      : "text-[0.72rem] uppercase tracking-[0.08em] text-text-muted"
                  }
                >
                  {s.status}
                </span>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{s.purpose}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Or skip the scope dance entirely.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code>'s hosted OAuth wraps LinkedIn's flow with the
        right minimum scopes for whatever post types you write. Self-host
        keeps the same scope policy code, just with your own LinkedIn app.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="/platforms/linkedin">
          LinkedIn on letmepost.dev
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="https://docs.letmepost.dev/authentication"
          >Auth docs</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-scope {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-scope-row {
    border-bottom: 1px dashed var(--color-border);
    padding: 0.55rem 0;
  }
  .lmp-scope-row:last-of-type {
    border-bottom: none;
  }
  .lmp-scope-label {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    cursor: pointer;
    align-items: start;
  }
  .lmp-scope-label input {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
  }
  .lmp-scope-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .lmp-scope-note {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .lmp-scope-list {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    padding: 0.15rem 0.4rem;
    align-self: start;
  }
  .lmp-scope-output {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .lmp-scope-output-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .lmp-scope-out {
    display: block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.85rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    word-break: break-all;
    user-select: all;
  }
  /* Reuse the .lmp-counter-copy button style from CharacterCounter — same
     visual language, defined here so this page stands alone. */
  .lmp-counter-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }
  .lmp-counter-copy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

<script>
  function setupScope(root: HTMLElement) {
    const checkboxes = Array.from(
      root.querySelectorAll<HTMLInputElement>("[data-scope-action]"),
    );
    const out = root.querySelector<HTMLElement>("[data-scope-out]");
    const copy = root.querySelector<HTMLButtonElement>("[data-scope-copy]");

    function recompute() {
      const set = new Set<string>();
      for (const cb of checkboxes) {
        if (!cb.checked) continue;
        try {
          const list: string[] = JSON.parse(cb.dataset.scopes || "[]");
          for (const s of list) set.add(s);
        } catch {
          /* malformed config — skip */
        }
      }
      const scopes = Array.from(set);
      if (out) {
        out.textContent = scopes.length === 0 ? "—" : scopes.join(" ");
      }
    }

    checkboxes.forEach((cb) => cb.addEventListener("change", recompute));
    copy?.addEventListener("click", async () => {
      const text = out?.textContent || "";
      if (!text || text === "—") return;
      try {
        await navigator.clipboard.writeText(text);
        copy.textContent = "Copied";
        setTimeout(() => (copy.textContent = "Copy"), 1100);
      } catch {
        /* clipboard blocked */
      }
    });

    recompute();
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>("[data-scope]").forEach(setupScope);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
