---
interface Props {
  wordmark?: boolean;
  size?: number;
}

const { wordmark = true, size = 32 } = Astro.props;
---

<a href="/" class="logo" aria-label="letmepost.dev">
  <span class="logo-mark" style={`--mark-size: ${size}px;`}>
    <svg
      width={size}
      height={size}
      viewBox="0 0 32 32"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="16" cy="16" r="15" fill="currentColor"></circle>
      <rect
        x="9.5"
        y="9.5"
        width="13"
        height="13"
        fill="var(--bg)"
        transform="rotate(16 16 16)"
      ></rect>
    </svg>
  </span>

  {
    wordmark && (
      <span class="wordmark">
        <span class="word">letmepost</span>
        <span class="tld">.dev</span>
        <span class="tag">[alpha]</span>
      </span>
    )
  }
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
    color: var(--text);
    line-height: 1;
  }
  .logo:hover {
    color: var(--text);
  }

  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
  }

  .word,
  .tld {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    font-size: 1.6rem;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .word {
    color: var(--text);
  }

  .tld {
    color: var(--accent);
  }

  .tag {
    margin-left: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.54rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    opacity: 0.6;
    text-transform: uppercase;
    align-self: flex-end;
    padding-bottom: 0.15rem;
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
    width: var(--mark-size);
    height: var(--mark-size);
  }

  @media (max-width: 480px) {
    .word,
    .tld {
      font-size: 1.35rem;
    }
  }
</style>
