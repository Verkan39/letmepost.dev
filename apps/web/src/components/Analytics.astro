---
// Public env vars are inlined at build time. If `PUBLIC_POSTHOG_KEY` is
// unset we render nothing — local dev stays quiet by default.
const key = import.meta.env.PUBLIC_POSTHOG_KEY;
const host = import.meta.env.PUBLIC_POSTHOG_HOST ?? "https://us.i.posthog.com";
---

{/* Step 1: PostHog snippet. Inline because it needs `define:vars` to
    inject the publishable key at build time. Defines `window.posthog`
    synchronously (as a stub that queues calls) and async-loads the
    real library from PostHog's CDN. Conditionally rendered: when
    PUBLIC_POSTHOG_KEY is unset (local dev) nothing is emitted. */}
{
  key && (
    <script
      is:inline
      define:vars={{ POSTHOG_KEY: key, POSTHOG_HOST: host }}
    >
      {`
      !(function () {
        if (window.__lmpPosthogInit) return;
        window.__lmpPosthogInit = true;
        !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init Ce As Ws Ks register register_once register_for_session unregister unregister_for_session Ye getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSurveysLoaded onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey canRenderSurveyAsync identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty Ge $s createPersonProfile Ms opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing Ss debug I getPageViewId captureTraceFeedback captureTraceMetric".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
        posthog.init(POSTHOG_KEY, {
          api_host: POSTHOG_HOST,
          person_profiles: "identified_only",
          capture_pageview: false,
          capture_pageleave: true,
          autocapture: true,
        });
      })();
      `}
    </script>
  )
}

{/* Step 2: Bundled module — pageview + click handlers. MUST live at the
    template top level (not inside a JSX conditional fragment) so Astro's
    hoister picks it up; conditional <script> tags get silently dropped
    from the production bundle. The handlers themselves no-op when
    `window.posthog` is unavailable, so it's safe to ship them on every
    page including local-dev builds that lack the init snippet above. */}
<script>
  import { track, pageFromPathname } from "../lib/analytics";

  function getDataAttr(selector: string, attr: string): string | null {
    const el = document.querySelector(selector);
    return el ? el.getAttribute(attr) : null;
  }

  // Fires on every Astro navigation (including initial hard load).
  // $pageview is the catch-all; the typed page-viewed events drive
  // per-page funnels.
  function onPageLoad() {
    if (typeof window === "undefined" || !window.posthog) return;
    window.posthog.capture("$pageview");

    const page = pageFromPathname(window.location.pathname);
    switch (page) {
      case "pricing":
        track({ name: "pricing.viewed", properties: {} });
        break;
      case "platform-detail": {
        const slug = window.location.pathname
          .replace(/^\/platforms\//, "")
          .replace(/\/$/, "");
        const status = getDataAttr(
          "[data-platform-status]",
          "data-platform-status",
        );
        track({
          name: "platform_page.viewed",
          properties: {
            platform: slug,
            status: status === "live" ? "live" : "coming-soon",
          },
        });
        break;
      }
      case "api-detail": {
        const surface = window.location.pathname
          .replace(/^\/api\//, "")
          .replace(/\/$/, "");
        track({ name: "api_page.viewed", properties: { surface } });
        break;
      }
      case "blog-post": {
        const slug = window.location.pathname
          .replace(/^\/blog\//, "")
          .replace(/\/$/, "");
        const tagsRaw =
          getDataAttr("[data-blog-tags]", "data-blog-tags") ?? "";
        const tags = tagsRaw ? tagsRaw.split(",").filter(Boolean) : [];
        const publishedAt = getDataAttr(
          "[data-blog-published-at]",
          "data-blog-published-at",
        );
        track({
          name: "blog_post.viewed",
          properties: {
            slug,
            tags,
            published_at: publishedAt ?? undefined,
          },
        });
        break;
      }
    }
  }
  document.addEventListener("astro:page-load", onPageLoad);

  // Delegated click handler. Elements opt in via:
  //   data-analytics-event="<event_name>"
  //   data-analytics-props='{...}'  (optional)
  // Attached at document level so it survives ClientRouter swaps.
  // The HTML boundary trusts strings to match a WebEvent union
  // member — keep them in sync.
  function onAnyClick(e: MouseEvent) {
    const t = e.target;
    if (!t || !(t instanceof Element)) return;
    const el = t.closest("[data-analytics-event]");
    if (!el) return;
    const name = el.getAttribute("data-analytics-event");
    if (!name) return;
    const raw = el.getAttribute("data-analytics-props");
    let props: Record<string, unknown> = {};
    if (raw) {
      try {
        props = JSON.parse(raw);
      } catch {
        props = {};
      }
    }
    if (window.posthog && typeof window.posthog.capture === "function") {
      window.posthog.capture(name, props);
    }
  }
  document.addEventListener("click", onAnyClick, { capture: true });
</script>

{/* Vercel Analytics — no-op outside Vercel deployments; safe in local dev. */}
<script>
  import { inject } from "@vercel/analytics";
  inject();
</script>
