# letmepost.dev — apps/api environment variables
# Copy to .env (git-ignored) and fill in real values.
#
# Sections:
#   1. Core (required to boot)
#   2. Queue / Redis
#   3. Auth (better-auth + social sign-in providers)
#   4. Platform OAuth credentials (LinkedIn, Twitter/X, Pinterest, Meta, TikTok)
#
# When you register the developer app for each platform, the redirect URI
# you must configure on the platform's portal is listed under each section.
# In production swap `http://localhost:3000` for your real API base URL.

# ─── 1. Core ────────────────────────────────────────────────────────────────

# Postgres connection string. NeonDB pooler URL recommended for hosted use.
# Local Postgres also works — the driver is selected automatically.
#
# NeonDB example:   postgres://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require
# Local example:    postgres://postgres:postgres@localhost:5432/letmepost
DATABASE_URL=

# AES-256-GCM master key for the token envelope. Base64 of exactly 32 bytes.
# Generate with:  openssl rand -base64 32
# Must be rotated via re-wrap, not replacement — see apps/api/src/encryption/envelope.ts.
KEK_MASTER=

# HTTP port the API listens on. Default 3000.
# PORT=3000

# Public origin where the API is reachable from the outside world. Used by
# platform providers to build their OAuth redirect URIs at runtime — must
# match exactly what each platform's developer portal has on file. Defaults
# to http://localhost:3000 if unset (fine for dev).
# Prod: https://api.letmepost.dev (or wherever the API is mounted)
PUBLIC_API_BASE_URL=http://localhost:3000

# Extra CORS origins, comma-separated. The dashboard at http://localhost:3001
# is always allowed. Add your prod dashboard origin here.
# Example: https://app.letmepost.dev,https://staging.letmepost.dev
CORS_ORIGINS=

# Optional. Postgres connection string used by the repository test suite (per-test
# transaction rollback). If unset, those tests are skipped — the encryption tests
# and existing Bluesky / preflight / health tests still run. Point at a disposable
# local Postgres or a NeonDB preview branch.
TEST_DATABASE_URL=

# ─── 2. Queue / Redis ───────────────────────────────────────────────────────

# Upstash Redis connection string used by BullMQ for publish / validate /
# refresh-token / webhook-deliver queues. Local Redis works for dev:
#   redis://localhost:6379
# Upstash example:
#   rediss://default:<password>@<region>.upstash.io:6379
REDIS_URL=

# ─── 3. Auth ────────────────────────────────────────────────────────────────

# better-auth signing secret. 32 bytes minimum.
# Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public origin where better-auth callbacks land. Must match the URL the
# dashboard hits at runtime.
# Dev: http://localhost:3000
# Prod: https://api.letmepost.dev (or wherever the API is mounted)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated list of dashboard origins better-auth should trust for
# cross-origin auth flows. Local :3001 is always allowed; add the prod
# dashboard origin here.
# Prod: https://dashboard.letmepost.dev
TRUSTED_ORIGINS=

# Set in production when the API and dashboard live on different subdomains
# of the same parent domain. Configures the session cookie with
# `Domain=<value>; SameSite=None; Secure` so dashboard.letmepost.dev can
# read the cookie set by api.letmepost.dev. Leave blank in dev.
# Prod example: .letmepost.dev   (note the leading dot)
COOKIE_DOMAIN=

# ── Optional: social sign-in providers for the dashboard (better-auth)
# Set both ID + SECRET to enable; leaving them blank disables that provider.

# Google OAuth (Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (Settings → Developer settings → OAuth Apps).
# Authorization callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── 4. Platform OAuth credentials ──────────────────────────────────────────
#
# Each platform follows the same pattern: register a developer app, configure
# the redirect URI listed below, paste the client id + secret here. The scope
# strings letmepost requests are listed verbatim — paste them into the
# platform's "permissions" / "products" / "scopes" form when verification asks.

# ── LinkedIn ────────────────────────────────────────────────────────────────
# Portal:        https://www.linkedin.com/developers/apps
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/linkedin/callback
# Products to enable on the app:
#   • "Sign In with LinkedIn using OpenID Connect"  (gives openid, profile)
#   • "Share on LinkedIn"                            (gives w_member_social)
# Scopes letmepost requests:
#   write     openid, profile, w_member_social
#   extended  email, r_organization_social, w_organization_social
# Notes: org / Company-Page posting (`w_organization_social`) requires the
# Marketing Developer Platform (MDP) review — separate, slower process. The
# personal-posting MVP works without it.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Twitter / X ─────────────────────────────────────────────────────────────
# Portal:        https://developer.x.com/en/portal/dashboard
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/twitter/callback
# OAuth 2.0 settings:
#   • Type of App:       "Web App, Automated App or Bot"
#   • Authentication:    OAuth 2.0 with PKCE (Confidential client)
#   • Scopes (write):    tweet.read, tweet.write, users.read, offline.access
#   • Scopes (extended): like.read, follows.read
# Notes: as of Feb 2026 X killed tiered pricing for new signups — Basic/Pro
# tiers are closed; pay-per-use is the only option for new developers.
# Posting requires write access on the paid tier.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Pinterest ───────────────────────────────────────────────────────────────
# Portal:        https://developers.pinterest.com/apps/
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/pinterest/callback
# Scopes letmepost requests:
#   write     boards:read, pins:read, pins:write
#   extended  user_accounts:read, pins:read_secret
# Notes: new apps start in Trial Access — all endpoints work, pins are
# private to the creator until Pinterest approves Standard Access (requires
# a video walkthrough of the OAuth flow + pin creation).
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# ── Meta — Facebook + Instagram + Threads ──────────────────────────────────
# Portal:        https://developers.facebook.com/apps/
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/meta/callback
# Products to add on the app:
#   • Facebook Login for Business
#   • Instagram (Business)
#   • Threads
# Scopes letmepost requests (write):
#   pages_manage_posts, pages_read_engagement, pages_show_list,
#   business_management, instagram_basic, instagram_content_publish,
#   threads_basic, threads_content_publish
# Notes: Meta App Review takes 2–8 weeks per cycle and rejections are normal.
# Build against Development Mode + Tester accounts during the wait — same
# Graph API endpoints, same response shapes; review just lifts the
# testers-only gate. Business verification is required before submission.
META_APP_ID=
META_APP_SECRET=
# Pin the Graph API version. Default lives in the Meta provider; bump on
# each platform version cut and run the contract test suite.
# META_GRAPH_VERSION=v23.0

# ── TikTok ──────────────────────────────────────────────────────────────────
# Portal:        https://developers.tiktok.com/apps/
# Redirect URI:  ${BETTER_AUTH_URL}/v1/accounts/oauth/tiktok/callback
# Scopes letmepost requests (write):
#   user.info.basic, video.publish, video.upload
# Notes: Content Posting API is review-gated. Sandbox Mode lets you build
# end-to-end before approval, but posts are restricted to SELF_ONLY privacy
# until the audit clears — letmepost surfaces SELF_ONLY as a non-fatal
# `post.validated` warning. "Direct Post" approval is separate from "Upload"
# approval; both are needed for the full v1 surface.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
