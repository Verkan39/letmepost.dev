---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CharacterCounter from "../../components/CharacterCounter.astro";
import { Icon } from "astro-icon/components";

const platforms = [
  {
    slug: "threads",
    name: "Threads post",
    limit: 500,
    mode: "graphemes" as const,
    hint: "single Threads post",
  },
];

const rules = [
  {
    label: "Single post",
    value: "500 characters",
    note: "Counted as grapheme clusters — multi-codepoint emoji (👨‍👩‍👧‍👦) count as one.",
  },
  {
    label: "Thread chain",
    value: "Up to 20 posts",
    note: "Each linked post can hit the full 500-character cap independently.",
  },
  {
    label: "Hashtags and mentions",
    value: "Counted as displayed",
    note: "@handles and #tags count their literal characters.",
  },
  {
    label: "Image alt text",
    value: "1,000 characters",
    note: "Per attached image, separate from the post text.",
  },
];
---

<BaseLayout
  title="Threads character counter"
  description="Free Threads character counter — 500-character cap, grapheme-aware so multi-codepoint emoji don't over-count. The same rule letmepost.dev preflights against."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Threads character counter",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Free Threads character counter with a 500-character grapheme-aware cap.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">Threads character counter.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        Threads caps a single post at 500 characters, counted as graphemes —
        the user-perceived character. Multi-codepoint emoji and accented
        letters count once, the way the platform does it.
      </p>
      <CharacterCounter
        platforms={platforms}
        placeholder="Start a thread…"
      />
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Threads' actual limits.</h2>
      <ul class="list-none p-0 mt-4">
        {
          rules.map((r) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <span class="font-bold text-[0.95rem]">{r.label}</span>
                <span class="text-accent font-mono text-[0.9rem]">
                  {r.value}
                </span>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{r.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Don't ship Threads chains blind.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code> validates the 500-character cap on every
        post in a chain before any of them go upstream. If post 7 of your
        thread is over, you find out before posts 1–6 publish.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="https://dashboard.letmepost.dev">
          Try the API
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/social-media-character-counter"
          >All platforms at once</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
