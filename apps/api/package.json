{
  "name": "@letmepost/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "predev": "node scripts/copy-openapi.mjs",
    "dev": "tsx watch src/server.ts",
    "worker": "tsx src/queue/worker.ts",
    "prebuild": "node scripts/copy-openapi.mjs",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-openapi.mjs",
    "start": "node dist/server.js",
    "start:api": "node dist/db/migrate.js && node dist/server.js",
    "start:worker": "node dist/queue/worker.js",
    "migrate": "node dist/db/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "node scripts/copy-openapi.mjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:demo": "tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/lib-storage": "^3.1038.0",
    "@better-auth/core": "^1.6.11",
    "@better-auth/oauth-provider": "^1.6.11",
    "@better-auth/utils": "0.4.0",
    "@better-fetch/fetch": "1.1.21",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "@letmepost/mcp": "workspace:*",
    "@letmepost/schemas": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.11",
    "better-call": "1.3.5",
    "bullmq": "^5.76.1",
    "busboy": "^1.6.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.13",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.9",
    "rate-limiter-flexible": "^11.0.1",
    "ws": "^8.20.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@letmepost/config-tsconfig": "workspace:*",
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.6.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
