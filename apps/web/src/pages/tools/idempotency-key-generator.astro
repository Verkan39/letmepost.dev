---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";

const formats = [
  {
    id: "uuid",
    label: "UUID v4",
    body: "RFC 4122 random UUID. The default everyone reaches for. 36 characters with hyphens.",
    when: "When you don't have a strong reason to pick anything else.",
  },
  {
    id: "ulid",
    label: "ULID",
    body: "Time-prefixed, lexicographically sortable. 26 chars Crockford base-32, no hyphens, URL-safe.",
    when: "When you want to grep or sort logs by request creation time.",
  },
  {
    id: "nanoid",
    label: "nanoid",
    body: "URL-safe, customizable length. 21 chars by default with 64-char alphabet.",
    when: "When you want shorter keys or need to embed them in URLs.",
  },
];

const curlSample = `curl -X POST https://api.letmepost.dev/v1/posts \\
  -H "Authorization: Bearer lmp_live_…" \\
  -H "Idempotency-Key: 01HQEFG4MZ8K9CSXRJ3VYBTWKQ" \\
  -H "Content-Type: application/json" \\
  -d '{
    "account": { "platform": "bluesky", "id": "acc_…" },
    "text": "Retries are safe."
  }'`;
---

<BaseLayout
  title="Idempotency key generator"
  description="Free idempotency-key generator — UUID v4, ULID, or nanoid. The keys you actually want for an Idempotency-Key header on a POST that mustn't double-fire."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Idempotency key generator",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Generate UUID v4, ULID, or nanoid idempotency keys — entirely client-side, suitable for the Idempotency-Key HTTP header.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">Idempotency key generator.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        UUID v4, ULID, or nanoid — the three formats you actually want as an
        <code>Idempotency-Key</code> header. Generated entirely in your
        browser; nothing leaves the page.
      </p>

      <div class="lmp-idem" data-idem>
        <div class="lmp-idem-tabs" role="tablist">
          <button
            type="button"
            class="lmp-idem-tab"
            data-tab="uuid"
            role="tab"
            aria-selected="true">UUID v4</button
          >
          <button
            type="button"
            class="lmp-idem-tab"
            data-tab="ulid"
            role="tab"
            aria-selected="false">ULID</button
          >
          <button
            type="button"
            class="lmp-idem-tab"
            data-tab="nanoid"
            role="tab"
            aria-selected="false">nanoid</button
          >
        </div>

        <output class="lmp-idem-output" data-idem-output>—</output>

        <div class="lmp-idem-actions">
          <button
            type="button"
            class="btn btn-primary"
            data-idem-generate
          >
            <Icon name="ph:arrows-clockwise" width={13} height={13} />
            Generate
          </button>
          <button
            type="button"
            class="btn btn-secondary"
            data-idem-copy
          >
            Copy
          </button>
          <button
            type="button"
            class="btn btn-secondary"
            data-idem-batch
          >
            Generate 10
          </button>
        </div>

        <details class="lmp-idem-batch" data-idem-details>
          <summary>Batch output</summary>
          <pre class="lmp-idem-batchout" data-idem-batchout></pre>
        </details>
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Three formats. Pick the one that fits.</h2>
      <ul class="list-none p-0 mt-4">
        {
          formats.map((f) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline mb-1">
                <span class="font-bold text-[0.95rem]">{f.label}</span>
                <span class="text-text-muted text-[0.85rem]">{f.when}</span>
              </div>
              <p class="text-text-muted m-0 text-[0.88rem]">{f.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">How to use it.</h2>
      <p class="text-text-muted">
        Send the same key on every retry of a write. The server stores the
        first response under that key and replays it on retry — no
        double-posting if your worker restarts mid-flight.
      </p>
      <Code code={curlSample} lang="bash" theme="github-dark" />
      <p class="text-text-muted mt-4 text-[0.88rem]">
        <code>letmepost.dev</code> accepts any of these three formats. Keys are scoped
        per API key and retained for 24 hours.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Why this matters.</h2>
      <p class="text-text-muted">
        Idempotency keys solve the worst class of bugs in social media
        publishing — the double-post from a retry storm. Postiz issue #1321
        was the public version of this; the maintainer's own recommended fix
        was idempotency keys. <code>letmepost.dev</code> ships them on by default,
        on every <code>POST /v1/posts</code>, with a 24-hour replay window.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="https://docs.letmepost.dev/idempotency">
          Read the docs
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="https://dashboard.letmepost.dev"
          >Try the API</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-idem {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-idem-tabs {
    display: inline-flex;
    border: 1px solid var(--color-border);
    margin-bottom: 0.85rem;
  }
  .lmp-idem-tab {
    background: transparent;
    border: none;
    border-right: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.45rem 0.95rem;
    cursor: pointer;
    transition:
      background 120ms ease,
      color 120ms ease;
  }
  .lmp-idem-tab:last-child {
    border-right: none;
  }
  .lmp-idem-tab[aria-selected="true"] {
    background: var(--color-accent);
    color: var(--color-accent-text);
  }
  .lmp-idem-output {
    display: block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.1rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 1.05rem;
    word-break: break-all;
    line-height: 1.4;
    min-height: 3.4rem;
    user-select: all;
  }
  .lmp-idem-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.85rem;
    flex-wrap: wrap;
  }
  .lmp-idem-batch {
    margin-top: 1rem;
  }
  .lmp-idem-batch summary {
    cursor: pointer;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    padding: 0.3rem 0;
  }
  .lmp-idem-batchout {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.85rem 1rem;
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0.5rem 0 0;
    white-space: pre-wrap;
    word-break: break-all;
  }
</style>

<script>
  // Crockford base-32 alphabet (no I, L, O, U) — the spec ULID uses.
  const CROCKFORD = "0123456789ABCDEFGHJKMNPQRSTVWXYZ";
  // nanoid v3 default 64-char URL-safe alphabet.
  const NANOID_ALPHABET =
    "_-0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";

  function uuid(): string {
    return crypto.randomUUID();
  }

  function ulid(): string {
    // 48-bit timestamp (ms since epoch) -> 10 base-32 chars.
    let t = Date.now();
    let timeStr = "";
    for (let i = 0; i < 10; i++) {
      timeStr = CROCKFORD[t % 32] + timeStr;
      t = Math.floor(t / 32);
    }
    // 80 random bits -> 16 base-32 chars. BigInt because >53-bit math.
    const bytes = new Uint8Array(10);
    crypto.getRandomValues(bytes);
    let bn = 0n;
    for (let i = 0; i < 10; i++) bn = (bn << 8n) | BigInt(bytes[i]);
    let randStr = "";
    for (let i = 0; i < 16; i++) {
      randStr = CROCKFORD[Number(bn & 31n)] + randStr;
      bn >>= 5n;
    }
    return timeStr + randStr;
  }

  function nanoid(size = 21): string {
    const bytes = new Uint8Array(size);
    crypto.getRandomValues(bytes);
    let id = "";
    for (let i = 0; i < size; i++) {
      id += NANOID_ALPHABET[bytes[i] & 63];
    }
    return id;
  }

  function generate(format: string): string {
    switch (format) {
      case "ulid":
        return ulid();
      case "nanoid":
        return nanoid();
      default:
        return uuid();
    }
  }

  function setupIdem(root: HTMLElement) {
    const tabs = Array.from(
      root.querySelectorAll<HTMLButtonElement>(".lmp-idem-tab"),
    );
    const output = root.querySelector<HTMLElement>("[data-idem-output]");
    const generateBtn = root.querySelector<HTMLButtonElement>(
      "[data-idem-generate]",
    );
    const copyBtn = root.querySelector<HTMLButtonElement>("[data-idem-copy]");
    const batchBtn = root.querySelector<HTMLButtonElement>("[data-idem-batch]");
    const batchOut = root.querySelector<HTMLElement>("[data-idem-batchout]");
    const batchDetails = root.querySelector<HTMLDetailsElement>(
      "[data-idem-details]",
    );

    let active = "uuid";

    function refresh() {
      if (output) output.textContent = generate(active);
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.setAttribute("aria-selected", "false"));
        tab.setAttribute("aria-selected", "true");
        active = tab.dataset.tab || "uuid";
        refresh();
      });
    });

    generateBtn?.addEventListener("click", refresh);

    copyBtn?.addEventListener("click", async () => {
      const text = output?.textContent || "";
      if (!text || text === "—") return;
      try {
        await navigator.clipboard.writeText(text);
        copyBtn.textContent = "Copied";
        setTimeout(() => (copyBtn.textContent = "Copy"), 1100);
      } catch {
        /* clipboard blocked */
      }
    });

    batchBtn?.addEventListener("click", () => {
      const ids: string[] = [];
      for (let i = 0; i < 10; i++) ids.push(generate(active));
      if (batchOut) batchOut.textContent = ids.join("\n");
      if (batchDetails) batchDetails.open = true;
    });

    refresh();
  }

  function bootAll() {
    document
      .querySelectorAll<HTMLElement>("[data-idem]")
      .forEach(setupIdem);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
