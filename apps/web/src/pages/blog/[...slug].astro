---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout, { type JsonLdGraph } from "../../layouts/BaseLayout.astro";
import Tape from "../../components/Tape.astro";
import Closeout from "../../components/Closeout.astro";

/**
 * Static post pages, one per MDX entry. `getStaticPaths` is the source
 * of truth for what gets built — drafts are excluded in production.
 *
 * Post layout is the receipt design's blog-post template: centered
 * post head, TL;DR card, .prose body with § headings + pullquote +
 * figure + blockquote, next-up card, sticky right-rail TOC.
 */
export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const sortedPosts = [...allPosts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const currentIdx = sortedPosts.findIndex((p) => p.id === post.id);
const nextPost = currentIdx > 0 ? sortedPosts[currentIdx - 1] : null;

function fmtISO(d: Date): string {
  return d.toISOString().slice(0, 10);
}

function readingMin(p: CollectionEntry<"blog">): number {
  if (p.data.readingTime) return p.data.readingTime;
  const body = p.body ?? "";
  const words = body.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const categoryLabel: Record<string, string> = {
  engineering: "ENGINEERING",
  philosophy: "PHILOSOPHY",
  "release-notes": "RELEASE NOTES",
};

// Dispatch number = position in the published series (newest first
// = highest number). Stable across rebuilds as long as pubDate stays.
const totalPosts = sortedPosts.length;
const dispatchNum = String(totalPosts - currentIdx).padStart(2, "0");

// Build TOC from rendered h2/h3 headings. h2 gets §N, h3 gets ·
// (matches the design's two-level indent).
let h2Count = 0;
const toc = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => {
    if (h.depth === 2) h2Count += 1;
    return {
      depth: h.depth,
      text: h.text,
      slug: h.slug,
      num: h.depth === 2 ? `§${h2Count}` : "·",
    };
  });

const siteUrl = Astro.site!.toString().replace(/\/$/, "");

const articleJsonLd: JsonLdGraph = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    "@type": "Organization",
    name: post.data.author,
    url: siteUrl,
  },
  publisher: { "@id": `${siteUrl}/#organization` },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${post.id}/`,
  },
  ...(post.data.heroImage
    ? {
        image: post.data.heroImage.startsWith("http")
          ? post.data.heroImage
          : new URL(post.data.heroImage, siteUrl).toString(),
      }
    : {}),
  keywords: post.data.tags.join(", "),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${siteUrl}/blog/` },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: `${siteUrl}/blog/${post.id}/`,
    },
  ],
};

const ogImage = post.data.heroImage ?? "/og-image.png";
const minutes = readingMin(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImage}
  ogType="article"
  stripWidth={660}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <Tape />

  <span
    data-blog-tags={post.data.tags.join(",")}
    data-blog-published-at={post.data.pubDate.toISOString()}
    hidden
  ></span>

  <header class="post-head" data-sticky-anchor>
    <div class="kicker">
      DISPATCH №{dispatchNum}
      <span class="dot"></span>
      {categoryLabel[post.data.category]}
      <span class="dot"></span>
      {fmtISO(post.data.pubDate)}
    </div>
    <h1>{post.data.title}</h1>
    <p class="dek">{post.data.description}</p>
    <div class="byline">
      <span>by <b>{post.data.author}</b></span>
      <span>· {minutes} min read</span>
      {post.data.tags.length > 0 && <span>· {post.data.tags.join(", ")}</span>}
    </div>
  </header>

  <article class="prose">
    <Content />
  </article>

  {
    nextPost && (
      <>
        <hr class="dash" style="margin-top: 48px;" />
        <div class="next-up">
          <div>
            <div class="lbl">Next dispatch</div>
            <h3>
              <a href={`/blog/${nextPost.id}`}>{nextPost.data.title}</a>
            </h3>
            <p>{nextPost.data.description}</p>
          </div>
          <div class="arrow">→</div>
        </div>
      </>
    )
  }

  <hr class="double" />

  <Closeout
    thanks="* * * THANK YOU FOR READING * * *"
    codeLine={`DISPATCH ${dispatchNum} · ${fmtISO(post.data.pubDate)} · ${minutes} MIN`}
    links={[
      { href: "/blog", label: "all dispatches" },
      { href: "/rss.xml", label: "rss" },
      { href: "https://bsky.app/profile/rosekamallove.dev", label: "bluesky" },
      { href: "mailto:rose@letmepost.dev", label: "email" },
    ]}
  />
  <Tape bottom />

  {/* Right rail — table of contents */}
  <aside class="toc" aria-label="Table of contents" slot="rightRail">
    <div class="lbl">Contents</div>
    {
      toc.length > 0 ? (
        <ol>
          {toc.map((h) => (
            <li>
              <a href={`#${h.slug}`}>
                <span class="num">{h.num}</span>
                <span>{h.text}</span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p style="font-size: 11px; color: var(--r-very);">No headings yet.</p>
      )
    }
    <div class="read">
      Reading time <b>{minutes} min</b><br />
      Filed {fmtISO(post.data.pubDate)}<br />
      Bangalore, India
    </div>
  </aside>
</BaseLayout>

<style is:global>
  /* ── Single blog post only ─────────────────────────────── */

  .post-head { padding: 36px 0 8px; text-align: center; }
  .post-head .kicker {
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--r-accent); margin-bottom: 14px;
  }
  .post-head .kicker .dot {
    display: inline-block; width: 4px; height: 4px;
    background: var(--r-very); margin: 0 8px 2px; vertical-align: middle;
  }
  .post-head h1 {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 30px; line-height: 1.18; letter-spacing: -0.02em;
    margin: 0 0 16px; text-wrap: balance; color: var(--r-ink);
  }
  .post-head h1 .acc { color: var(--r-accent); }
  .post-head .dek {
    font-size: 15px; line-height: 1.55; color: var(--r-dim);
    max-width: 560px; margin: 0 auto 22px; text-wrap: balance;
  }
  .post-head .byline {
    display: inline-flex; gap: 14px; flex-wrap: wrap;
    font-size: var(--r-fs-xs); letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--r-very); justify-content: center;
  }
  .post-head .byline b { color: var(--r-ink); font-weight: 700; }

  .prose {
    font-family: var(--r-mono);
    color: var(--r-fg);
    font-size: 14px; line-height: 1.75;
    max-width: 580px; margin: 0 auto;
  }
  .prose > * + * { margin-top: 1.1em; }
  .prose p { margin: 0; }
  .prose p + p { margin-top: 1.1em; }
  .prose p > b, .prose p > strong { color: var(--r-ink); font-weight: 700; }
  .prose h2 {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 18px; letter-spacing: -0.005em;
    margin-top: 2em; margin-bottom: 0.6em;
    padding-bottom: 6px; border-bottom: 1px dashed var(--r-very);
    color: var(--r-ink);
  }
  .prose h2::before { content: '§ '; color: var(--r-accent); }
  .prose h3 {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 15px; letter-spacing: 0;
    margin-top: 1.6em; margin-bottom: 0.4em;
    color: var(--r-ink);
  }
  .prose ul, .prose ol { padding-left: 1.2em; margin: 0; }
  .prose li { margin-bottom: 0.4em; }
  .prose li::marker { color: var(--r-accent); }
  .prose a {
    color: var(--r-accent);
    text-decoration: underline; text-decoration-thickness: 1px;
    text-decoration-style: dotted; text-underline-offset: 3px;
  }
  .prose a:hover { color: var(--r-ink); }
  .prose code:not(pre code) {
    background: var(--r-accent-soft); padding: 1px 6px;
    font-size: 0.92em;
  }
  .prose pre {
    background: var(--r-code-bg); color: var(--r-code-fg);
    padding: 14px 16px; overflow-x: auto;
    font-size: 11.5px; line-height: 1.6;
    border: 1px solid var(--r-line);
  }
  .prose pre code { background: transparent; padding: 0; }
  .prose blockquote {
    margin: 1.4em 0;
    padding: 12px 18px;
    border-left: 3px solid var(--r-accent);
    background: var(--r-paper-deep);
    color: var(--r-fg);
    font-style: italic;
  }
  .prose blockquote p { margin: 0; }
  .prose blockquote cite {
    display: block; margin-top: 8px;
    font-size: 11px; letter-spacing: 0.06em;
    color: var(--r-very); font-style: normal;
  }
  .prose hr {
    border: 0; height: 28px; margin: 28px 0;
    background:
      radial-gradient(circle, var(--r-very) 1.5px, transparent 2px) center / 12px 12px no-repeat,
      radial-gradient(circle, var(--r-very) 1.5px, transparent 2px) calc(50% - 18px) / 12px 12px no-repeat,
      radial-gradient(circle, var(--r-very) 1.5px, transparent 2px) calc(50% + 18px) / 12px 12px no-repeat;
  }
  .prose img {
    max-width: 100%; height: auto;
    border: 1px solid var(--r-line);
  }
  .prose table {
    width: 100%; border-collapse: collapse;
    font-size: 0.92em;
  }
  .prose th, .prose td {
    padding: 6px 10px; border: 1px solid var(--r-line);
    text-align: left;
  }
  .prose th { background: var(--r-accent-soft); font-weight: 700; color: var(--r-ink); }

  .pullquote {
    margin: 2em -10px;
    padding: 18px 24px;
    border-top: 2px solid var(--r-ink); border-bottom: 2px solid var(--r-ink);
    font-family: var(--r-mono); font-weight: 700;
    font-size: 18px; line-height: 1.35; letter-spacing: -0.005em;
    text-align: center;
    color: var(--r-ink);
  }
  .pullquote .acc { color: var(--r-accent); }

  .figure {
    margin: 1.5em 0;
    padding: 12px 14px;
    border: 1px solid var(--r-line); background: var(--r-paper-deep);
    font-size: 12.5px; line-height: 1.6;
  }
  .figure pre {
    background: var(--r-code-bg); color: var(--r-code-fg);
    padding: 12px 14px; margin: 0;
    overflow-x: auto; font-size: 11.5px;
  }
  .figure figcaption {
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--r-very); margin-top: 8px;
  }

  .tldr {
    margin: 18px auto 28px;
    max-width: 580px;
    padding: 16px 20px;
    border: 1px dashed var(--r-accent);
    background: var(--r-accent-soft);
    font-size: 13px; line-height: 1.6; color: var(--r-fg);
  }
  .tldr .lbl {
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--r-accent); font-weight: 700; margin-bottom: 6px;
  }
  .tldr p { margin: 0; }

  .next-up {
    margin: 36px 0 6px;
    padding: 22px 24px;
    border: 1px solid var(--r-line);
    background: var(--r-paper);
    display: grid; grid-template-columns: 1fr auto;
    gap: 16px; align-items: center;
  }
  .next-up .lbl {
    font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--r-accent); margin-bottom: 8px;
  }
  .next-up h3 {
    font-family: var(--r-mono); font-weight: 700;
    font-size: 16px; margin: 0 0 4px; line-height: 1.3; color: var(--r-ink);
  }
  .next-up h3 a { text-decoration: none; color: var(--r-ink); }
  .next-up h3 a:hover { color: var(--r-accent); }
  .next-up p { margin: 0; font-size: 12px; color: var(--r-dim); }
  .next-up .arrow {
    font-size: 22px; color: var(--r-accent); font-weight: 700;
  }

  @media (max-width: 700px) {
    .post-head h1 { font-size: 24px; }
    .pullquote { font-size: 15px; margin: 1.6em 0; }
    .next-up { grid-template-columns: 1fr; }
  }
</style>
