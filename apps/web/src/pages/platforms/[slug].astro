---
import BaseLayout, { type JsonLdGraph } from "../../layouts/BaseLayout.astro";
import { faqPageSchema } from "../../lib/seo.ts";
import { Icon } from "astro-icon/components";
import PlatformIcon from "../../components/PlatformIcon.astro";
import { PLATFORMS, type Platform } from "../../data/platforms.ts";
import { PLATFORM_CONTENT } from "../../data/platform-content.ts";
import { highlight } from "../../lib/highlight.ts";

/**
 * Per-platform landing page — Clarity design, full marketing copy.
 * Content per platform comes from data/platform-content.ts (our copy);
 * canonical status comes from PLATFORMS (mirrors PLATFORM_STATE).
 *
 * Sections: hero (h1 + lede + CTAs + mini-code) → VS comparison →
 * highlight → playground → content types → how it works → features →
 * code example → error reference → FAQ → cross-sell → notes → final CTA.
 */

// platforms.ts lists TikTok twice — dedupe by slug.
function dedupe(list: readonly Platform[]): Platform[] {
  const seen = new Set<string>();
  return list.filter((p) => (seen.has(p.slug) ? false : (seen.add(p.slug), true)));
}

export function getStaticPaths() {
  const seen = new Set<string>();
  return PLATFORMS.filter((p) => (seen.has(p.slug) ? false : (seen.add(p.slug), true))).map(
    (platform) => ({ params: { slug: platform.slug }, props: { platform } }),
  );
}

interface Props {
  platform: Platform;
}

const { platform } = Astro.props;
const content = PLATFORM_CONTENT[platform.slug];
const firstWord = platform.name.split(" ")[0];

const STATUS_LABEL: Record<string, string> = {
  live: "Live",
  pending: "In review",
  trial: "Trial",
  planned: "Planned",
};
const STATUS_PILL: Record<string, string> = {
  live: "live",
  pending: "in-review",
  trial: "trial",
  planned: "planned",
};

const allPlatforms = dedupe(PLATFORMS).map((p) => ({
  slug: p.slug,
  name: p.name,
  current: p.slug === platform.slug,
}));

const learnMore = [
  { title: "Pricing", body: "Per-org flat rate", href: "/pricing" },
  { title: `${platform.name} guide`, body: "Complete dev guide", href: `https://docs.letmepost.dev/platforms/${platform.slug}` },
  { title: "API reference", body: "OpenAPI 3.1 spec", href: "https://docs.letmepost.dev/api-reference" },
];

const siteUrl = Astro.site!.toString().replace(/\/$/, "");

const breadcrumbJsonLd: JsonLdGraph = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Platforms", item: `${siteUrl}/platforms/` },
    { "@type": "ListItem", position: 3, name: platform.name, item: `${siteUrl}/platforms/${platform.slug}/` },
  ],
};
const softwareJsonLd: JsonLdGraph = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: `${platform.name} API via letmepost.dev`,
  description: platform.pitch,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Flat-rate per org" },
  publisher: { "@id": `${siteUrl}/#organization` },
};
---

<BaseLayout
  title={`${platform.name} API for developers`}
  description={`Publish to ${platform.name} via letmepost.dev. ${platform.tagline}.`}
  ogType="product"
  jsonLd={[breadcrumbJsonLd, softwareJsonLd, faqPageSchema(content.faqs)]}
>
  {/* Analytics marker for Analytics.astro's platform_page.viewed event */}
  <span data-platform-status={platform.status === "live" || platform.status === "trial" ? "live" : "coming-soon"} hidden></span>

  <header class="wrap page-head">
    <p class="crumb"><a href="/platforms">Platforms</a> / {platform.name}</p>
    <p class="eyebrow eyebrow-status">
      <span class={`pill ${STATUS_PILL[platform.status] ?? "planned"}`}>
        {STATUS_LABEL[platform.status] ?? "Planned"}
      </span>
      Platform integration
    </p>
    <h1 class="cl-h1" style="max-width: 22ch;">
      {content.heroH1.before}{" "}
      <PlatformIcon platform={platform.slug} size={36} class="h1-icon" />{" "}
      {content.heroH1.after}
      <br />
      <span class="acc">{content.heroH1.emphasize}</span>
    </h1>
    <p class="sub" set:html={content.heroLede} />
    <div class="ctas" style="margin-top: 30px;">
      <a
        class="btn pri lg"
        href="https://dashboard.letmepost.dev"
        data-analytics-event="cta.clicked"
        data-analytics-props={JSON.stringify({ location: "hero", target: "dashboard", page: "platform-detail", platform: platform.slug })}
      >Connect {firstWord} →</a>
      <a class="btn ghost lg" href={`https://docs.letmepost.dev/platforms/${platform.slug}`}>View API docs</a>
    </div>
    {content.reassurance && <p class="trust" set:html={content.reassurance} />}

    <div class="code" style="margin-top: 36px;">
      <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="file">POST /v1/posts</span></div>
      <pre set:html={highlight("json", content.miniCode)} />
    </div>
  </header>

  {/* VS COMPARISON */}
  <section class="wrap sec">
    <p class="vs-head">{content.vsHead}</p>
    <div class="compare">
      <div class="col them">
        <h3>{platform.name} Direct</h3>
        <ul>{content.vsDirect.map((p) => <li set:html={p.body} />)}</ul>
      </div>
      <div class="col us">
        <h3>letmepost API</h3>
        <ul>{content.vsLetmepost.map((p) => <li set:html={p.body} />)}</ul>
      </div>
    </div>
    {content.costBanner && <div class={`cost-banner ${content.costBanner.tone}`} set:html={content.costBanner.body} />}
  </section>

  {content.highlight && (
    <section class="wrap sec" style="padding-top: 0;">
      <div class={`highlight-block ${content.highlight.tone}`}>
        <h3>{content.highlight.title}</h3>
        <p set:html={content.highlight.body} />
      </div>
    </section>
  )}

  {/* PLAYGROUND */}
  <section class="wrap sec divider">
    <p class="kicker">Playground</p>
    <h2 class="cl-h2">Connect, configure, post.</h2>
    <div class="playground">
      <div class="pg-hd">
        {content.playground.steps.map((s, i) => <span class={`step ${i === 0 ? "on" : ""}`}>▸ {s}</span>)}
      </div>
      <div class="pg-body">
        <p set:html={content.playground.body} />
        <a
          class="btn pri"
          href={content.playground.cta.href}
          data-analytics-event="cta.clicked"
          data-analytics-props={JSON.stringify({ location: "playground", target: "dashboard-connect", page: "platform-detail", platform: platform.slug })}
        >{content.playground.cta.label}</a>
        <div class="pg-result">
          <span class="check">✓</span>
          <b>{content.playground.result}</b>
          <span class="cf">{content.playground.resultCaption}</span>
        </div>
      </div>
    </div>
  </section>

  {/* CONTENT TYPES */}
  <section class="wrap sec divider">
    <p class="kicker">Content types</p>
    <h2 class="cl-h2">Every {firstWord} surface, one shape.</h2>
    <div class="ctypes">
      {content.contentTypes.map((ct) => (
        <div class="ctype">
          <Icon name={`ph:${ct.icon}`} width={15} height={15} />
          <b>{ct.label}</b>
          {ct.note && <span class="note">· {ct.note}</span>}
        </div>
      ))}
    </div>
  </section>

  {/* HOW IT WORKS */}
  <section class="wrap sec divider">
    <p class="kicker">How it works</p>
    <h2 class="cl-h2">Three steps, under two minutes.</h2>
    <div class="steps">
      {content.steps.map((s) => (
        <div class="step">
          <div>
            <h4>{s.title}</h4>
            <p set:html={s.body} />
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* FEATURES */}
  <section class="wrap sec divider">
    <p class="kicker">Features</p>
    <h2 class="cl-h2">What we built so you don't.</h2>
    <div class="cards c2">
      {content.features.map((f) => (
        <div class="card">
          <div class="ic"><Icon name={`ph:${f.icon}`} width={18} height={18} /></div>
          <h3>{f.title}</h3>
          <p set:html={f.body} />
        </div>
      ))}
    </div>
  </section>

  {/* CODE EXAMPLE */}
  <section class="wrap sec divider">
    <p class="kicker">Code example</p>
    <h2 class="cl-h2">{content.codeExample.caption}</h2>
    <div class="code">
      <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="file">{content.codeExample.file}</span></div>
      <pre set:html={highlight("ts", content.codeExample.code)} />
    </div>
  </section>

  {content.errorRef && (
    <section class="wrap sec" style="padding-top: 0;">
      <div class="err-ref">
        <div>
          <h4>{content.errorRef.title}</h4>
          <p>{content.errorRef.body}</p>
        </div>
        <a href={content.errorRef.href}>View error reference →</a>
      </div>
    </section>
  )}

  {/* FAQ */}
  <section class="wrap sec divider">
    <p class="kicker">Common questions</p>
    <h2 class="cl-h2">{content.faqSubtitle}</h2>
    <div class="faq">
      {content.faqs.map((f) => (
        <div class="q-item">
          <p class="q">{f.q}</p>
          <p class="a" set:html={f.a} />
        </div>
      ))}
    </div>
  </section>

  {/* ONE API · N PLATFORMS */}
  <section class="wrap sec divider">
    <p class="kicker">One API · {allPlatforms.length} platforms</p>
    <h2 class="cl-h2">{firstWord} is just one of them.</h2>
    <div class="all-plats">
      {allPlatforms.map((p) => (
        <a href={`/platforms/${p.slug}`} class={p.current ? "current" : undefined}>
          <PlatformIcon platform={p.slug} size={16} />
          {p.name}
        </a>
      ))}
    </div>
  </section>

  {/* LEARN MORE */}
  <section class="wrap sec" style="padding-top: 0;">
    <p class="kicker">Learn more</p>
    <div class="cards c3">
      {learnMore.map((l) => (
        <a class="card" href={l.href}>
          <h3>{l.title}</h3>
          <div class="meta">{l.body}</div>
        </a>
      ))}
    </div>
  </section>

  {content.marg && content.marg.length > 0 && (
    <section class="wrap sec divider">
      <p class="kicker">Good to know</p>
      <h2 class="cl-h2">Notes from the integration.</h2>
      <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 32px;">
        {content.marg.map((n) => (
          <div class="callout">
            <span class="callout-tag">{n.tag}</span>
            <p set:html={n.body} />
          </div>
        ))}
      </div>
    </section>
  )}

  {/* FINAL CTA */}
  <section class="wrap">
    <div class="final">
      <h2>{content.finalCtaH2}</h2>
      <p set:html={content.finalCtaLede} />
      <div class="ctas">
        <a
          class="btn pri lg"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props={JSON.stringify({ location: "platform-final", target: "dashboard", page: "platform-detail", platform: platform.slug })}
        >{content.finalCtaPrimaryLabel}</a>
        <a class="btn ghost lg" href={content.finalCtaSecondaryHref}>{content.finalCtaSecondaryLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
