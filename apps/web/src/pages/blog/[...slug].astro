---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout, { type JsonLdGraph } from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

/**
 * Static post pages, one per MDX entry. `getStaticPaths` is the source
 * of truth for what gets built — drafts are excluded in production so
 * a `draft: true` post is never reachable via direct URL on prod, even
 * if someone guessed the slug.
 */
export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

function fmtDate(d: Date) {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const siteUrl = Astro.site!.toString().replace(/\/$/, "");

/**
 * Article structured data + BreadcrumbList. Article fields map directly
 * to the schema.org spec — Google uses these to render byline + date in
 * the search snippet, plus enables Top Stories carousel inclusion if
 * the content matches a topic Google's tracking. Image URL is absolute
 * (Google rejects relative paths in JSON-LD).
 */
const articleJsonLd: JsonLdGraph = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate
    ? { dateModified: post.data.updatedDate.toISOString() }
    : { dateModified: post.data.pubDate.toISOString() }),
  author: {
    "@type": "Organization",
    name: post.data.author,
    url: siteUrl,
  },
  publisher: { "@id": `${siteUrl}/#organization` },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${post.id}/`,
  },
  ...(post.data.heroImage
    ? {
        image: post.data.heroImage.startsWith("http")
          ? post.data.heroImage
          : new URL(post.data.heroImage, siteUrl).toString(),
      }
    : {}),
  keywords: post.data.tags.join(", "),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${siteUrl}/blog/`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: `${siteUrl}/blog/${post.id}/`,
    },
  ],
};

// Cross-posted content: respect the author's canonical so Google
// attributes the original source. Otherwise we're the canonical.
const ogImage = post.data.heroImage ?? "/og-image.png";
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImage}
  ogType="article"
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  {/* If the post has its own canonical (cross-posted), override the
      one BaseLayout emits via a slot. We can't easily slot into <head>
      from the layout, so instead we surface a visible note at the top
      of the post when applicable. The schema canonical lives in the
      JSON-LD `mainEntityOfPage` already. */}

  {/* Analytics data attributes — picked up by the central pageview
      script in Analytics.astro so we don't duplicate the tag/date
      resolver per page. Hidden marker so layout is unaffected. */}
  <span
    data-blog-tags={post.data.tags.join(",")}
    data-blog-published-at={post.data.pubDate.toISOString()}
    hidden
  ></span>

  <article class="pt-18 pb-18 max-[640px]:pt-12">
    <div class="container">
      <a
        href="/blog"
        class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted no-underline hover:text-accent inline-flex items-center gap-1 mb-6"
      >
        <Icon name="ph:arrow-left" width={11} height={11} />
        All posts
      </a>

      <header class="mb-8">
        {post.data.tags.length > 0 ? (
          <div class="flex gap-2 flex-wrap mb-4 text-[0.7rem] uppercase tracking-[0.08em] text-text-muted">
            {post.data.tags.map((t) => (
              <span>{t}</span>
            ))}
          </div>
        ) : null}

        <h1 class="!m-0">{post.data.title}</h1>

        <p class="text-[1.05rem] leading-[1.6] mt-4 mb-5 text-text-secondary">
          {post.data.description}
        </p>

        <div class="flex flex-wrap items-center gap-3 text-[0.82rem] text-text-muted">
          <span>{post.data.author}</span>
          <span class="opacity-50">·</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {fmtDate(post.data.pubDate)}
          </time>
          {post.data.updatedDate ? (
            <>
              <span class="opacity-50">·</span>
              <span>
                Updated {fmtDate(post.data.updatedDate)}
              </span>
            </>
          ) : null}
          {post.data.canonicalUrl ? (
            <>
              <span class="opacity-50">·</span>
              <a
                href={post.data.canonicalUrl}
                class="text-accent"
                target="_blank"
                rel="canonical noopener"
              >
                Originally published elsewhere
                <Icon name="ph:arrow-up-right" width={11} height={11} class="inline" />
              </a>
            </>
          ) : null}
        </div>
      </header>

      {post.data.heroImage ? (
        <img
          src={post.data.heroImage}
          alt=""
          class="w-full h-auto mb-8 border border-border"
        />
      ) : null}

      <div class="prose-blog">
        <Content />
      </div>

      <hr class="my-12 border-border" />

      <div class="flex flex-wrap gap-3 items-center">
        <a
          class="btn btn-primary"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props='{"location":"blog-cta","target":"dashboard","page":"blog-post","label":"Try letmepost free"}'
        >
          Try letmepost free
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/blog">More posts</a>
        <a
          class="text-[0.85rem] text-text-muted hover:text-accent ml-auto"
          href="/rss.xml"
          data-analytics-event="rss.subscribed"
          data-analytics-props='{"from_page":"blog-post"}'
        >
          RSS
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Scoped post-body styling — keeps Tailwind's reset out of the post
     content but doesn't leak into the rest of the site. The class
     wrapping the <Content /> block is what activates these rules. */

  .prose-blog {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .prose-blog > * + * {
    margin-top: 1.1rem;
  }

  .prose-blog h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 2.4rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .prose-blog h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-top: 1.8rem;
    margin-bottom: 0.4rem;
    line-height: 1.35;
  }

  .prose-blog h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-top: 1.4rem;
    margin-bottom: 0.3rem;
  }

  .prose-blog p {
    margin: 0;
  }

  .prose-blog a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }

  .prose-blog a:hover {
    color: var(--color-accent-hover);
  }

  .prose-blog ul,
  .prose-blog ol {
    padding-left: 1.4rem;
    margin: 0;
  }

  .prose-blog li {
    margin: 0.3rem 0;
  }

  .prose-blog code:not(pre code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 0.1rem 0.35rem;
    border-radius: 0;
  }

  .prose-blog pre {
    background: var(--color-code-bg);
    color: var(--color-code-text, var(--color-text));
    padding: 1rem 1.1rem;
    overflow-x: auto;
    font-size: 0.85rem;
    border: 1px solid var(--color-border);
  }

  .prose-blog pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }

  .prose-blog blockquote {
    margin: 0;
    padding: 0.6rem 1.1rem;
    border-left: 3px solid var(--color-accent);
    background: var(--color-accent-soft);
    color: var(--color-text-secondary);
    font-style: normal;
  }

  .prose-blog hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .prose-blog img {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
  }

  .prose-blog table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .prose-blog th,
  .prose-blog td {
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .prose-blog th {
    background: var(--color-accent-soft);
    font-weight: 700;
  }
</style>
