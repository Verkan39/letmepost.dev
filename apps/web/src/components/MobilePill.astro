---
interface Props {
  links?: Array<{ href: string; label: string }>;
}

const {
  links = [
    { href: "https://docs.letmepost.dev", label: "Docs" },
    { href: "/pricing", label: "Pricing" },
  ],
} = Astro.props;
---

<nav class="mobile-pill" aria-label="Primary mobile">
  <a href="/" class="pill-brand">
    <span class="r-stamp sm" aria-hidden="true"></span>
    LETMEPOST
  </a>
  <span class="pill-sep" aria-hidden="true"></span>
  {links.map((l) => <a href={l.href} class="pill-link">{l.label}</a>)}
  <span class="pill-sep" aria-hidden="true"></span>
  <button
    type="button"
    class="pill-menu"
    id="open-sheet"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-sheet"
  >≡</button>
</nav>
