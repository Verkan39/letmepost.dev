---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";
import PlatformIcon from "../components/PlatformIcon.astro";

const platforms = [
  { name: "Bluesky", slug: "bluesky", status: "live" },
  { name: "Pinterest", slug: "pinterest", status: "under_review" },
  { name: "Twitter / X", slug: "x", status: "under_review" },
  { name: "LinkedIn", slug: "linkedin", status: "under_review" },
  { name: "Instagram", slug: "instagram", status: "under_review" },
  { name: "Facebook", slug: "facebook", status: "under_review" },
  { name: "Threads", slug: "threads", status: "under_review" },
  { name: "YouTube", slug: "youtube", status: "under_review" },
] as const;

const statusLabel: Record<string, string> = {
  live: "live",
  under_review: "under review",
};

const codeSample = `// Idempotency keys make retries safe.
// Preflight rules run before we hit the platform.

await fetch("https://api.letmepost.dev/v1/posts", {
  method: "POST",
  headers: {
    Authorization: "Bearer lmp_live_…",
    "Idempotency-Key": crypto.randomUUID(),
  },
  body: JSON.stringify({
    account: { platform: "bluesky", id: "acc_…" },
    text: "Shipping letmepost.dev",
  }),
});`;

const errorSample = `{
  "error": {
    "code": "preflight_failed",
    "rule": "bluesky.text.max_graphemes",
    "platform": "bluesky",
    "platform_version": "atproto-2026-04",
    "message": "Post text is 312 graphemes; Bluesky allows at most 300.",
    "remediation": "Shorten the post to 300 graphemes or fewer.",
    "request_id": "req_01HY6X4AWBJM2K9F2PTQMRD9JQ"
  }
}`;

const endpoints = [
  {
    method: "POST",
    path: "/v1/posts",
    desc: "One call. Seven platforms at v1. Text, images, video, carousels — scheduled or now.",
  },
  {
    method: "POST",
    path: "/v1/media",
    desc: "Multipart upload once, reference by mediaId on every post. Bytes stay on our CDN.",
  },
  {
    method: "POST",
    path: "/v1/accounts/connect/:platform",
    desc: "One OAuth flow, scoped narrowly. Tokens encrypted at rest. Refresh handled for you.",
  },
  {
    method: "GET",
    path: "/v1/platform-versions",
    desc: "Public. See which upstream API version we pin per platform and what's deprecating.",
  },
  {
    method: "POST",
    path: "/v1/webhook-endpoints",
    desc: "HMAC-signed deliveries for queued, published, failed, token.expiring, version.deprecated.",
  },
  {
    method: "GET",
    path: "/v1/posts/:id",
    desc: "Full post record with every attempt, every upstream response, every status transition.",
  },
];

const methodClasses: Record<string, string> = {
  POST: "text-http-post bg-http-post/10",
  GET: "text-http-get bg-http-get/10",
  PUT: "text-http-put bg-http-put/10",
  DELETE: "text-http-delete bg-http-delete/10",
};

const faqs = [
  {
    q: "What actually works today?",
    a: 'Bluesky is live end-to-end — connect an account, send a post, get a webhook back, attach images or video (videos route through the dedicated transcoding service, transparently). Pinterest and Twitter/X publishers are built and tested but waiting on platform review (Pinterest Standard access; X is on the Pay Per Use tier). Meta (Instagram / Facebook / Threads), LinkedIn, and YouTube are review-gated and typically clear 3–12 weeks from submission (YouTube via the CASA verification track). See the <a href="https://github.com/rosekamallove/letmepost.dev/blob/main/plan.md">plan</a> for dates.',
  },
  {
    q: "Why another social media API?",
    a: 'Because every existing one fails silently and charges per-profile. 2025–26 research across 150+ citations: LinkedIn sunset five API versions in six months; Postiz shipped infinite double-posting bugs; Ayrshare\'s own docs admit error 138 "masks multiple underlying causes." We fix all three. <a href="https://github.com/rosekamallove/letmepost.dev/blob/main/PRODUCT.md">Read the brief</a>.',
  },
  {
    q: "How much does it cost?",
    a: "Free during alpha. When hosted billing turns on, it's flat-rate with a real free tier — no per-profile tax, no per-seat lock-in. Self-host stays free forever.",
  },
  {
    q: "Is it really open source?",
    a: "Apache 2.0 from day one. Same code runs the hosted SaaS and the self-host Docker Compose. No feature gate, no open-core trick.",
  },
  {
    q: "Postiz, Zernio, Ayrshare — what's the difference?",
    a: "Postiz is OSS but known for silent-failure bugs. Zernio is closed-source (rebranded from Late in late 2025). Ayrshare charges per-profile and returns opaque errors. We ship OSS + transparent errors + flat pricing — nobody else has all three.",
  },
  {
    q: "Can I self-host it?",
    a: "Yes, first-class. Docker Compose, BYO Postgres and Redis, BYO platform credentials. Same API, same behavior as hosted.",
  },
];

function glyphClasses(status: string): string {
  if (status === "live") return "bg-success opacity-100";
  if (status === "under_review") return "bg-accent opacity-100";
  return "bg-text-muted opacity-50";
}

const liveGlyphShadow =
  "box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-success) 18%, transparent);";

/**
 * FAQPage structured data — Google renders these as expandable rich
 * results on the SERP. The `name` strings must match the visible
 * question text on the page (Google penalizes mismatch). Answers
 * are HTML-stripped to plain prose so the SERP card stays legible
 * without our anchor formatting.
 */
const stripHtml = (html: string) => html.replace(/<[^>]+>/g, "");

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: stripHtml(f.a),
    },
  })),
};
---

<BaseLayout title="letmepost.dev" jsonLd={[faqJsonLd]}>
  <!-- Hero -->
  <section class="section-hero">
    <div class="container">
      {/* Pre-headline meta — deliberately quiet. The headline should
          carry the page, not a chunky status pill. The arrow link
          gives it just enough character to read as a designed
          element instead of a stranded label. */}
      <div class="flex items-center gap-3 mb-8 text-[0.85rem] text-text-muted">
        <a
          href="https://github.com/rosekamallove/letmepost.dev"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 no-underline text-text hover:text-accent transition-colors"
        >
          <span
            class="inline-block w-[7px] h-[7px] bg-success"
            style={liveGlyphShadow}
            aria-hidden="true"
          ></span>
          v0 alpha is live
          <Icon name="ph:arrow-up-right" width={11} height={11} />
        </a>
        <span class="opacity-50">·</span>
        <span>open source from day one</span>
      </div>

      <h1>
        Eight social platforms. One API.
        <span class="text-accent">Loud errors.</span>
      </h1>

      <p class="text-[1.2rem] leading-[1.65] mt-7 mb-11 text-text-secondary">
        Bluesky, X, LinkedIn, Threads, Pinterest, Instagram, Facebook, YouTube —
        through one POST endpoint. When a post breaks, you get the rule that
        failed, the raw platform response, and a remediation. Never an empty body.
      </p>

      <div class="flex gap-[0.7rem] flex-wrap">
        <a class="btn btn-primary" href="https://dashboard.letmepost.dev">
          Start building free
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="#request">
          See the request
          <Icon name="ph:arrow-down" width={13} height={13} />
        </a>
      </div>

      <p class="text-[0.85rem] mt-6 text-text-muted">
        No credit card · Free during alpha · Self-host stays free forever ·
        <a href="https://docs.letmepost.dev/quickstart" class="text-accent">90-second quickstart →</a>
      </p>
    </div>
  </section>

  <!-- Request -->
  <section
    id="request"
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">One endpoint. Any platform.</h2>
      <p class="text-text-muted">
        <code>POST /v1/posts</code> routes to the right platform and runs every
        documented rule locally before the upstream call. One request shape,
        one error shape, same contract whether you&apos;re posting to Bluesky
        today or LinkedIn next month.
      </p>

      <div class="border border-border my-6 bg-code-bg">
        <div
          class="flex items-center gap-[0.45rem] py-[0.65rem] px-[0.9rem] border-b border-[hsl(24_10%_16%)] text-[0.7rem] text-code-muted tracking-[0.02em]"
        >
          <span
            class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#ff5f57]"
            aria-hidden="true"></span>
          <span
            class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#febc2e]"
            aria-hidden="true"></span>
          <span
            class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#28c840]"
            aria-hidden="true"></span>
          <span class="ml-[0.6rem]">schedule-post.ts</span>
        </div>
        <Code code={codeSample} lang="ts" theme="github-dark-dimmed" />
      </div>
    </div>
  </section>

  <!-- Error -->
  <section
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">When it fails, you get something you can act on.</h2>
      <p class="text-text-muted">
        Every failure response is the same shape. Stable code, the rule that
        fired, the upstream platform version we tried, a remediation hint, a
        request id you can grep.
      </p>

      <div class="border border-border my-6 bg-code-bg">
        <div
          class="flex items-center gap-[0.45rem] py-[0.65rem] px-[0.9rem] border-b border-[hsl(24_10%_16%)] text-[0.7rem] text-code-muted tracking-[0.02em]"
        >
          <span
            class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#ff5f57]"
            aria-hidden="true"></span>
          <span
            class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#febc2e]"
            aria-hidden="true"></span>
          <span
            class="w-[11px] h-[11px] rounded-full inline-block shrink-0 bg-[#28c840]"
            aria-hidden="true"></span>
          <span class="ml-[0.6rem]">error-response.json</span>
        </div>
        <Code code={errorSample} lang="json" theme="github-dark-dimmed" />
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section
    id="how-it-works"
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">How it works.</h2>
      <p class="text-text-muted">Three steps. Minutes, not days.</p>

      <ol class="list-none p-0 mt-6 mb-4">
        <li class="flex gap-[1.1rem] py-5">
          <div
            class="text-accent font-extrabold text-[0.85rem] min-w-9 pt-[0.1rem] tracking-[0.04em]"
          >
            01
          </div>
          <div>
            <h3 class="!m-0 !mb-[0.35rem] !text-base !font-bold">
              Connect an account
            </h3>
            <p class="text-text-muted m-0 text-[0.92rem]">
              One OAuth flow per platform, or an app-password submit for
              Bluesky. Tokens get AES-256-GCM encrypted at rest. We refresh on
              the right schedule per platform.
            </p>
          </div>
        </li>
        <li class="flex gap-[1.1rem] py-5">
          <div
            class="text-accent font-extrabold text-[0.85rem] min-w-9 pt-[0.1rem] tracking-[0.04em]"
          >
            02
          </div>
          <div>
            <h3 class="!m-0 !mb-[0.35rem] !text-base !font-bold">
              Send a post
            </h3>
            <p class="text-text-muted m-0 text-[0.92rem]">
              <code>POST /v1/posts</code> with an Idempotency-Key. Preflight rules
              run locally before the upstream call. If anything fails, you get
              a rule id and a remediation hint — not a <code
                >body:&nbsp;{}</code
              >.
            </p>
          </div>
        </li>
        <li class="flex gap-[1.1rem] py-5">
          <div
            class="text-accent font-extrabold text-[0.85rem] min-w-9 pt-[0.1rem] tracking-[0.04em]"
          >
            03
          </div>
          <div>
            <h3 class="!m-0 !mb-[0.35rem] !text-base !font-bold">
              Subscribe to events
            </h3>
            <p class="text-text-muted m-0 text-[0.92rem]">
              HMAC-signed webhooks for <code>post.queued</code>, <code
                >post.published</code
              >, <code>post.failed</code>, <code>token.expiring</code>, and <code
                >version.deprecated</code
              >. No polling.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Principles -->
  <section
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">Four principles, no exceptions.</h2>

      <div class="py-5">
        <div
          class="text-accent text-[0.78rem] tracking-[0.04em] mb-[0.4rem] font-extrabold"
        >
          01 · Preflight, not postflight
        </div>
        <p class="text-text-muted m-0">
          Every documented rule — character counts, media formats, audit states,
          URN patterns — runs locally before the platform sees the request.
        </p>
      </div>

      <div class="py-5">
        <div
          class="text-accent text-[0.78rem] tracking-[0.04em] mb-[0.4rem] font-extrabold"
        >
          02 · Transparent errors
        </div>
        <p class="text-text-muted m-0">
          No empty <code>{"{ body: {}, message: \"\" }"}</code>. Every failure
          ships with a stable code, the specific rule that failed, the raw
          upstream body, and a remediation hint.
        </p>
      </div>

      <div class="py-5">
        <div
          class="text-accent text-[0.78rem] tracking-[0.04em] mb-[0.4rem] font-extrabold"
        >
          03 · Versions we pin for you
        </div>
        <p class="text-text-muted m-0">
          LinkedIn sunset five API versions in six months. We pin the header,
          track upcoming deprecations, and upgrade internally. Your workflow
          doesn&apos;t break at 2&nbsp;a.m.
        </p>
      </div>

      <div class="py-5">
        <div
          class="text-accent text-[0.78rem] tracking-[0.04em] mb-[0.4rem] font-extrabold"
        >
          04 · Idempotency by default
        </div>
        <p class="text-text-muted m-0">
          Every write accepts an <code>Idempotency-Key</code>. Retries are
          safe. No double-posting loops when a worker restarts mid-publish.
        </p>
      </div>
    </div>
  </section>

  <!-- Endpoints -->
  <section
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">What you can do.</h2>
      <p class="text-text-muted">
        The v1 API surface. Small on purpose — one primitive, done well.
      </p>

      <ul class="list-none p-0 mt-6 mb-4">
        {
          endpoints.map((e) => (
            <li class="py-[1.15rem]">
              <div class="flex items-center gap-3 mb-[0.4rem]">
                <span
                  class={`text-[0.68rem] font-bold tracking-[0.08em] py-[0.2rem] px-[0.55rem] border border-current leading-none uppercase min-w-[3.5rem] text-center ${methodClasses[e.method]}`}
                >
                  {e.method}
                </span>
                <code class="font-semibold text-[0.95rem] !bg-transparent !p-0 !text-text">
                  {e.path}
                </code>
              </div>
              <p class="text-text-muted m-0 text-[0.9rem] pl-[4.25rem] max-[520px]:pl-0">
                {e.desc}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Platforms -->
  <section
    id="platforms"
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">Platform support.</h2>
      <p class="text-text-muted">
        Bluesky is live. Everything else is either built and awaiting platform
        approval, or approvals are in flight while we build. We'll flip each
        row to live the moment review clears.
      </p>

      <ul class="list-none p-0 mt-6 mb-5">
        {
          platforms.map((p) => (
            <li class="group flex items-center gap-3 py-2 text-[0.95rem]">
              <span class="inline-flex items-center gap-[0.55rem] text-text">
                <PlatformIcon
                  platform={p.slug}
                  class="group-hover:text-text"
                />
                <span class="font-semibold whitespace-nowrap">{p.name}</span>
              </span>
              <span
                class="flex-1 self-center h-0 border-b border-dotted border-border-strong"
                aria-hidden="true"
              />
              <span class="text-[0.72rem] uppercase tracking-[0.08em] text-text-muted whitespace-nowrap inline-flex items-center gap-[0.4rem]">
                <span
                  class={`inline-block w-[6px] h-[6px] ${glyphClasses(p.status)}`}
                  style={p.status === "live" ? liveGlyphShadow : ""}
                  aria-hidden="true"
                />
                {statusLabel[p.status]}
              </span>
            </li>
          ))
        }
      </ul>
      <p class="text-[0.8rem] mt-4 text-text-muted">
        TikTok is deferred to v2 — DB enum + schemas keep it reserved for an
        additive add later. Reddit, Telegram, Discord, Snapchat, Google
        Business, and WhatsApp are deliberately cut from v1. See the roadmap
        for the reasoning.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section
    id="faq"
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">FAQs.</h2>

      <dl class="m-0 mt-6 mb-4 p-0">
        {
          faqs.map((f) => (
            <div class="py-[1.15rem]">
              <dt class="flex gap-[0.6rem] font-bold text-text m-0 mb-2 text-[0.95rem] before:content-['Q'] before:text-accent before:font-extrabold">
                {f.q}
              </dt>
              <dd
                class="flex gap-[0.6rem] text-text-muted m-0 text-[0.9rem] before:content-['A'] before:text-accent before:font-extrabold"
              >
                <span set:html={f.a} />
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Final CTA -->
  <section
    class="section"
  >
    <div class="container">
      <h2 class="!mt-0">Kick the tires.</h2>
      <p class="text-text-muted">
        Star the repo. Send your first Bluesky post. File an issue when
        something&apos;s weird. We&apos;re building in the open.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap">
        <a
          class="btn btn-primary"
          href="https://github.com/rosekamallove/letmepost.dev"
          target="_blank"
          rel="noopener">Star on GitHub <Icon name="ph:arrow-up-right" width={13} height={13} /></a
        >
        <a class="btn btn-secondary" href="/contact">Get in touch</a>
      </div>
    </div>
  </section>
</BaseLayout>
