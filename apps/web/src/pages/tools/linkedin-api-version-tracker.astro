---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";

/**
 * LinkedIn API versions are YYYYMM strings sent in the
 * `LinkedIn-Version` header. Each version is supported for 12 months
 * from its release date — that's the rule the table below applies.
 *
 * This list is hand-curated from LinkedIn's public versioning page
 * (learn.microsoft.com/linkedin/marketing/versioning) and the dates
 * referenced in our research corpus. We re-verify roughly quarterly;
 * the build-time `LAST_VERIFIED` constant below is shown to readers so
 * they can judge freshness.
 *
 * If you spot a missing or wrong row, send a PR — single source of
 * truth lives right here.
 */
type LinkedInVersion = {
  /** YYYYMM identifier, used in the LinkedIn-Version request header. */
  version: string;
  /** ISO release date — typically the 1st of the version month. */
  released: string;
  /** ISO sunset date — release + 12 months. */
  sunset: string;
  /** Optional callout (notable breaking change, deprecation note, etc.). */
  notes?: string;
};

const LAST_VERIFIED = "2026-05-08";

const VERSIONS: LinkedInVersion[] = [
  { version: "202307", released: "2023-07-01", sunset: "2024-07-01" },
  { version: "202310", released: "2023-10-01", sunset: "2024-10-01" },
  { version: "202401", released: "2024-01-01", sunset: "2025-01-01" },
  {
    version: "202404",
    released: "2024-04-01",
    sunset: "2025-04-01",
    notes: "First version cited in our wedge incident — n8n / Zapier / Make / Postiz all broke at sunset.",
  },
  { version: "202407", released: "2024-07-01", sunset: "2025-07-01" },
  { version: "202410", released: "2024-10-01", sunset: "2025-10-01" },
  {
    version: "202411",
    released: "2024-11-01",
    sunset: "2025-11-01",
    notes: "Off-cadence release. Sunset hit during peak Q4 — most automations failed.",
  },
  { version: "202501", released: "2025-01-01", sunset: "2026-01-01" },
  { version: "202504", released: "2025-04-01", sunset: "2026-04-01" },
  { version: "202507", released: "2025-07-01", sunset: "2026-07-01" },
  { version: "202510", released: "2025-10-01", sunset: "2026-10-01" },
  { version: "202601", released: "2026-01-01", sunset: "2027-01-01" },
  {
    version: "202604",
    released: "2026-04-01",
    sunset: "2027-04-01",
    notes: "Latest stable at last verification.",
  },
];

const headerSnippet = `// Pin a specific version on every LinkedIn API call.
// If you don't, LinkedIn picks the oldest supported version
// (which silently rolls forward when that one sunsets).

await fetch("https://api.linkedin.com/rest/posts", {
  method: "POST",
  headers: {
    "Authorization": "Bearer " + ACCESS_TOKEN,
    "LinkedIn-Version": "202604",
    "X-Restli-Protocol-Version": "2.0.0",
    "Content-Type": "application/json",
  },
  body: JSON.stringify(post),
});`;
---

<BaseLayout
  title="LinkedIn API version tracker — release dates, sunsets, days remaining"
  description="Live LinkedIn API version status. Release dates, 12-month sunset countdown, deprecation flags. Pin the right version before LinkedIn deprecates it under your automation."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "LinkedIn API version tracker",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "LinkedIn API version status with live days-until-sunset countdown for every active and historical version.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">LinkedIn API version tracker.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        LinkedIn supports each version for 12 months from release. After
        that it returns <code>410 Gone</code>. This page tracks every version,
        its sunset date, and how many days you have left to migrate.
      </p>

      <div class="lmp-version-meta">
        <span class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
          >Last verified</span
        >
        <span class="lmp-version-date">{LAST_VERIFIED}</span>
        <span class="text-text-muted text-[0.78rem] ml-2"
          >· countdowns refresh on page load</span
        >
      </div>

      <div class="lmp-version-table" data-version-tracker>
        <div class="lmp-version-head">
          <div>Version</div>
          <div>Released</div>
          <div>Sunsets</div>
          <div>Status</div>
        </div>
        {
          VERSIONS.map((v) => (
            <div
              class="lmp-version-row"
              data-version-row
              data-released={v.released}
              data-sunset={v.sunset}
            >
              <div class="lmp-version-name">
                <code>{v.version}</code>
                {v.notes ? (
                  <span class="lmp-version-note">{v.notes}</span>
                ) : null}
              </div>
              <div class="lmp-version-cell">{v.released}</div>
              <div class="lmp-version-cell">
                {v.sunset}
                <span class="lmp-version-days" data-version-days>
                  —
                </span>
              </div>
              <div class="lmp-version-status" data-version-status>
                —
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Why pinning matters.</h2>
      <p class="text-text-muted">
        If you don't send <code>LinkedIn-Version</code>, LinkedIn picks <em>the
        oldest version your app is allowed to call</em> — which silently
        rolls forward when that version sunsets. The first sign of trouble is
        a <code>410 Gone</code> on production traffic.
      </p>
      <Code code={headerSnippet} lang="javascript" theme="github-dark" />
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">The 2024–2025 sunset incident.</h2>
      <p class="text-text-muted">
        LinkedIn sunset five API versions in six months —
        <code>202404</code>, <code>202410</code>, <code>202411</code>,
        <code>202501</code>, <code>202504</code>. Each sunset broke n8n
        Cloud, Zapier, Make, Pabbly, and Postiz simultaneously. The fix in
        every case was a single header swap.
      </p>
      <p class="text-text-muted">
        <code>letmepost.dev</code> pins per request internally and upgrades the
        pin centrally — your workflows don't see the version churn.
        <a href="/blog/linkedin-api-version-history" class="text-accent">Read
        the full incident</a>.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Stop tracking versions yourself.</h2>
      <p class="text-text-muted">
        We track LinkedIn (and every other platform's) API version internally
        and emit a <code>version.deprecated</code> webhook on every account
        before LinkedIn would sunset under it. One less spreadsheet.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="/platforms/linkedin">
          LinkedIn on letmepost.dev
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="https://docs.letmepost.dev/webhooks"
          >Webhook docs</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-version-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    background: var(--color-accent-soft);
    padding: 0.35rem 0.7rem;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }
  .lmp-version-date {
    font-size: 0.92rem;
    font-weight: 700;
  }

  .lmp-version-table {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
  }
  .lmp-version-head,
  .lmp-version-row {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.4fr 1fr;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    align-items: start;
  }
  .lmp-version-head {
    background: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border-strong);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }
  .lmp-version-row {
    border-bottom: 1px dashed var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
  }
  .lmp-version-row:last-of-type {
    border-bottom: none;
  }
  .lmp-version-name {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .lmp-version-name code {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .lmp-version-note {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-text-muted);
  }
  .lmp-version-cell {
    color: var(--color-text-secondary);
  }
  .lmp-version-days {
    display: block;
    font-size: 0.74rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }
  .lmp-version-status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .lmp-version-status[data-status="active"] {
    color: var(--color-success);
  }
  .lmp-version-status[data-status="deprecating"] {
    color: hsl(38 75% 38%);
  }
  .lmp-version-status[data-status="critical"] {
    color: var(--color-error);
  }
  .lmp-version-status[data-status="sunset"] {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .lmp-version-head,
    .lmp-version-row {
      grid-template-columns: 1fr 1fr;
    }
    .lmp-version-head > div:nth-child(2),
    .lmp-version-head > div:nth-child(3),
    .lmp-version-row > .lmp-version-cell:nth-child(2) {
      display: none;
    }
  }
</style>

<script>
  function setupTracker(root: HTMLElement) {
    const rows = Array.from(
      root.querySelectorAll<HTMLElement>("[data-version-row]"),
    );
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    function classify(daysToSunset: number) {
      if (daysToSunset < 0) return { status: "sunset", label: "Sunset" };
      if (daysToSunset <= 30)
        return { status: "critical", label: "Sunsets <30d" };
      if (daysToSunset <= 90)
        return { status: "deprecating", label: "Deprecating" };
      return { status: "active", label: "Active" };
    }

    for (const row of rows) {
      const sunsetIso = row.dataset.sunset || "";
      const sunsetDate = new Date(sunsetIso);
      // Days remaining = ceil((sunset - today) / 1d). Past dates → negative.
      const days = Math.ceil(
        (sunsetDate.getTime() - today.getTime()) / 86400000,
      );

      const daysEl = row.querySelector<HTMLElement>("[data-version-days]");
      const statusEl = row.querySelector<HTMLElement>("[data-version-status]");

      if (daysEl) {
        if (days < 0) {
          daysEl.textContent = `${Math.abs(days)} days ago`;
        } else if (days === 0) {
          daysEl.textContent = "Today";
        } else {
          daysEl.textContent = `in ${days} days`;
        }
      }

      const cls = classify(days);
      if (statusEl) {
        statusEl.dataset.status = cls.status;
        statusEl.textContent = cls.label;
      }
    }
  }

  function bootAll() {
    document
      .querySelectorAll<HTMLElement>("[data-version-tracker]")
      .forEach(setupTracker);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
