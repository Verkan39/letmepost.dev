---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

type Tier = {
  name: string;
  tagline: string;
  price: string;
  priceSuffix?: string;
  highlight?: boolean;
  features: string[];
  cta: {
    label: string;
    href: string;
    external?: boolean;
    analyticsTarget: string;
  };
};

const mainTiers: Tier[] = [
  {
    name: "Free",
    tagline: "Indefinite, not a trial.",
    price: "$0",
    priceSuffix: "/mo",
    features: [
      "50 posts / month",
      "All 7 platforms, all API surface",
      "MCP server + CLI",
      "Community Discord support",
    ],
    cta: {
      label: "Get started",
      href: "https://dashboard.letmepost.dev",
      analyticsTarget: "dashboard",
    },
  },
  {
    name: "Pro",
    tagline: "For a SaaS or a side project.",
    price: "$79",
    priceSuffix: "/mo",
    highlight: true,
    features: [
      "5,000 posts / month",
      "All 7 platforms, all API surface",
      "MCP server + CLI",
      "All webhook events",
      "30-day publish logs",
      "Email support, 24h response",
    ],
    cta: {
      label: "Get started",
      href: "https://dashboard.letmepost.dev",
      analyticsTarget: "dashboard",
    },
  },
  {
    name: "Business",
    tagline: "For real SaaS + agency workflows.",
    price: "$299",
    priceSuffix: "/mo",
    features: [
      "25,000 posts / month",
      "All 7 platforms, all API surface",
      "MCP server + CLI",
      "White-label OAuth (your brand)",
      "99.9% uptime SLA",
      "180-day publish logs",
      "Priority Slack + email, 4h response",
    ],
    cta: {
      label: "Get started",
      href: "https://dashboard.letmepost.dev",
      analyticsTarget: "dashboard",
    },
  },
];
---

<BaseLayout
  title="Pricing"
  description="Two tiers. Free for evaluation, Pro at $79/mo for real workloads. Self-host always free under Apache 2.0. No per-profile or per-seat tax."
>
  <section class="pt-22 pb-18 max-[640px]:pt-14 max-[640px]:pb-12">
    <div class="container-wide">
      <h1 class="!m-0 !text-[2rem] !leading-tight mb-16 max-[640px]:!text-[1.5rem] max-[640px]:mb-10">Pricing.</h1>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {mainTiers.map((tier) => (
          <div
            class={
              tier.highlight
                ? "border border-border-strong p-5 flex flex-col"
                : "border border-border p-5 flex flex-col"
            }
            style={tier.highlight ? "background: var(--color-accent-soft);" : undefined}
          >
            <div class="flex items-center justify-between mb-2 gap-2">
              <div class={
                tier.highlight
                  ? "text-[0.72rem] uppercase tracking-[0.1em] text-accent"
                  : "text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
              }>
                {tier.name}
              </div>
              {tier.highlight ? (
                <div class="text-[0.62rem] uppercase tracking-[0.08em] text-accent border border-accent px-[0.35rem] py-[0.1rem]">
                  Recommended
                </div>
              ) : null}
            </div>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-2xl font-extrabold">{tier.price}</span>
              {tier.priceSuffix ? (
                <span class="text-[0.8rem] text-text-muted">{tier.priceSuffix}</span>
              ) : null}
            </div>
            <p class="text-text-muted m-0 text-[0.86rem] mb-3">{tier.tagline}</p>
            <ul class="list-none p-0 m-0 text-[0.86rem] text-text-secondary flex-1">
              {tier.features.map((f) => (
                <li class="py-[0.3rem] flex gap-[0.5rem] items-start">
                  <Icon
                    name="ph:check"
                    width={13}
                    height={13}
                    class="text-accent shrink-0 mt-[0.25rem]"
                  />
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              class={tier.highlight ? "btn btn-primary mt-5 w-full justify-center" : "btn btn-secondary mt-5 w-full justify-center"}
              href={tier.cta.href}
              {...(tier.cta.external ? { target: "_blank", rel: "noopener" } : {})}
              data-analytics-event="cta.clicked"
              data-analytics-props={`{"location":"pricing-card","target":"${tier.cta.analyticsTarget}","page":"pricing","tier":"${tier.name}","label":"${tier.cta.label}"}`}
            >
              {tier.cta.label}
              <Icon name="ph:arrow-up-right" width={13} height={13} />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
