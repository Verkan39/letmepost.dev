---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Analytics from "../components/Analytics.astro";
import Attribution from "../components/Attribution.astro";
import Footer from "../components/Footer.astro";

/**
 * Editorial layout used by /blog and /blog/[slug]. Strips the marketing
 * nav rail and sticky CTA from BaseLayout but reuses the brand mark and
 * the receipt-themed Footer so the blog still reads as part of the same
 * product.
 */
export interface JsonLdGraph {
  "@context"?: string;
  "@type": string;
  [key: string]: unknown;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: JsonLdGraph[];
  ogType?: "website" | "article" | "product";
}

const {
  title,
  description = "Open-source social media publishing API for developers and AI agents. Preflight validation, transparent errors, stable versions, idempotency by default.",
  ogImage = "/og-image.png",
  noindex = false,
  jsonLd = [],
  ogType = "website",
} = Astro.props;

const siteName = "letmepost.dev";
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f7f4ea" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e0e0a" media="(prefers-color-scheme: dark)" />

    <script is:inline data-astro-rerun>
      (function () {
        try {
          var pref = localStorage.getItem("lmp-theme") || "";
          if (pref === "dark") document.documentElement.setAttribute("data-theme", "dark");
          else document.documentElement.removeAttribute("data-theme");
        } catch (e) {}
      })();
    </script>


    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />

    {jsonLd.map((graph) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
    ))}

    <ClientRouter />
    <Analytics />
    <Attribution />
  </head>
  <body class="bp">
    <header class="bp-nav">
      <div class="bp-nav-inner">
        <a href="/" class="bp-brand">
          <span class="r-stamp" aria-hidden="true"></span>
          LETMEPOST
        </a>
        <nav class="bp-links">
          <a href="https://docs.letmepost.dev">Docs</a>
          <a href="/pricing">Pricing</a>
          <a href="/platforms">Platforms</a>
          <a href="/api">APIs</a>
          <a href="/agents">Agents</a>
          <a href="https://dashboard.letmepost.dev" class="bp-cta">→ Start free</a>
        </nav>
      </div>
    </header>

    <main class="bp-main">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  /* ── /blog layout scaffolding ───────────────────────────── */

  :root {
    --bp-serif: "Iowan Old Style", "Apple Garamond", Charter, Georgia,
      "Times New Roman", serif;
    --bp-rail: 1080px;
    --bp-gutter: 32px;
  }

  html, body { background: var(--r-bg); color: var(--r-fg); }

  body.bp {
    font-family: var(--r-mono);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .bp-nav {
    background: transparent;
  }
  .bp-nav-inner {
    max-width: var(--bp-rail);
    margin: 0 auto;
    padding: 14px var(--bp-gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .bp-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--r-mono);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.32em;
    color: var(--r-ink);
    text-decoration: none;
    padding-left: 0.32em;
  }
  .bp-links {
    display: flex;
    align-items: center;
    gap: 22px;
    font-family: var(--r-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bp-links a {
    color: var(--r-dim);
    text-decoration: none;
    transition: color 0.15s;
  }
  .bp-links a:hover { color: var(--r-ink); }
  .bp-links .bp-cta {
    padding: 8px 14px;
    border: 1px solid var(--r-ink);
    color: var(--r-ink);
    transition: background 0.15s, color 0.15s;
  }
  .bp-links .bp-cta:hover { background: var(--r-ink); color: var(--r-bg); }

  .bp-main { flex: 1; width: 100%; }

  @media (max-width: 720px) {
    .bp-nav-inner { padding: 12px 18px; }
    .bp-links { gap: 14px; }
    .bp-links a:not(.bp-cta) { display: none; }
  }
</style>
