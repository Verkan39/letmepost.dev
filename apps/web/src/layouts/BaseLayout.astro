---
import "../styles/global.css";
import "../styles/clarity.css";
import { ClientRouter } from "astro:transitions";
import Analytics from "../components/Analytics.astro";
import Attribution from "../components/Attribution.astro";
import ClarityHeader from "../components/ClarityHeader.astro";
import ClarityFooter from "../components/ClarityFooter.astro";

/**
 * The marketing site's shared chrome — "Clarity" direction. A sticky,
 * blurred top nav, a centered single-column content area that each page
 * fills with its own `.wrap` sections, and a shared footer. Mobile
 * collapses the nav into a burger + dropdown menu.
 *
 * `clarity.css` is imported *after* the legacy receipt `global.css` so
 * its base typography/colors win on every page; pages not yet migrated
 * to Clarity components keep their receipt body styling but inherit the
 * new nav/footer.
 *
 * Shared chrome behaviors (theme toggle, code-block tabs, mobile burger)
 * ship as one inline script at the bottom of <body> so they survive
 * Astro view transitions.
 *
 * `stripWidth` (legacy prop) maps to a `--maxw` override on <main> so
 * narrower pages (pricing, blog) keep a sane content width. `pillLinks`
 * and `stickyCTA` are retained on the interface for backwards-compat but
 * are no-ops in the Clarity chrome.
 */
export interface JsonLdGraph {
  "@context"?: string;
  "@type": string;
  [key: string]: unknown;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: JsonLdGraph[];
  ogType?: "website" | "article" | "product";
  /** Override the content max-width (defaults to clarity's 1080px). */
  stripWidth?: number;
  /** Legacy: mobile-pill quick links. No-op in the Clarity chrome. */
  pillLinks?: Array<{ href: string; label: string }>;
  /** Legacy: sticky CTA config. No-op in the Clarity chrome. */
  stickyCTA?: { href: string; label: string } | false;
}

const {
  title,
  description = "Open-source social media publishing API for developers and AI agents. Preflight validation, transparent errors, stable versions, idempotency by default.",
  ogImage = "/og-image.png",
  noindex = false,
  jsonLd = [],
  ogType = "website",
  stripWidth,
} = Astro.props;

const siteName = "letmepost.dev";
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const siteUrl = Astro.site!.toString().replace(/\/$/, "");

const defaultGraphs: JsonLdGraph[] = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    name: siteName,
    url: siteUrl,
    logo: `${siteUrl}/og-image.png`,
    description:
      "Open-source social media publishing API for developers and AI agents.",
    sameAs: [
      "https://github.com/rosekamallove/letmepost.dev",
      "https://x.com/letmepostdotdev",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    name: siteName,
    url: siteUrl,
    publisher: { "@id": `${siteUrl}/#organization` },
  },
];

const allGraphs: JsonLdGraph[] = [...defaultGraphs, ...jsonLd];

const mainStyle = stripWidth ? `--maxw: ${stripWidth}px;` : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fbfaf6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e0f0c" media="(prefers-color-scheme: dark)" />

    {/* Theme follows the OS preference (no manual switcher). Applied
        pre-paint and kept live via a matchMedia listener bound once.
        `data-astro-rerun` re-fires on view transitions so soft
        navigations don't flash the wrong theme mid-swap. */}
    <script is:inline data-astro-rerun>
      (function () {
        try {
          var mq = window.matchMedia("(prefers-color-scheme: dark)");
          var apply = function () {
            if (mq.matches) document.documentElement.setAttribute("data-theme", "dark");
            else document.documentElement.removeAttribute("data-theme");
          };
          apply();
          if (!window.__lmpThemeBound) {
            window.__lmpThemeBound = true;
            mq.addEventListener("change", apply);
          }
        } catch (e) {}
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="letmepost.dev Blog" href="/rss.xml" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="letmepost.dev. Social media publishing that fails loudly." />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@letmepostdotdev" />
    <meta name="twitter:creator" content="@letmepostdotdev" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="letmepost.dev. Social media publishing that fails loudly." />

    {allGraphs.map((graph) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
    ))}

    <ClientRouter />
    <Analytics />
    <Attribution />
  </head>
  <body>
    <ClarityHeader />

    <main class="cl-main" style={mainStyle} transition:animate="fade">
      <slot />
    </main>

    <ClarityFooter />

    {/* Shared chrome behaviors. Defensive — pages without a feature
        don't error. Re-binds on Astro view transitions. */}
    <script>
      function setup() {
        // Code-block tabs (curl / ts / py …).
        document.querySelectorAll<HTMLElement>("[data-tabs]").forEach((block) => {
          if (block.dataset.lmpBound) return;
          block.dataset.lmpBound = "1";
          const tabs = block.querySelectorAll<HTMLElement>(".tab");
          const panes = block.querySelectorAll<HTMLElement>("[data-pane]");
          const fileEl = block.querySelector<HTMLElement>(".file");
          let files: Record<string, string> = {};
          try {
            files = JSON.parse(block.dataset.files || "null") || {};
          } catch {}
          tabs.forEach((tab) => {
            tab.addEventListener("click", () => {
              const id = tab.dataset.tab!;
              tabs.forEach((t) => t.classList.toggle("on", t === tab));
              panes.forEach((p) => {
                if (p.dataset.pane !== id) p.setAttribute("hidden", "");
                else p.removeAttribute("hidden");
              });
              if (fileEl && files[id]) fileEl.textContent = files[id];
            });
          });
        });

        // Mobile nav burger → toggles #cl-mobile.
        const burger = document.querySelector<HTMLElement>("[data-burger]");
        const mobile = document.getElementById("cl-mobile");
        if (burger && mobile && !burger.dataset.lmpBound) {
          burger.dataset.lmpBound = "1";
          burger.addEventListener("click", () => {
            const open = mobile.classList.toggle("open");
            burger.setAttribute("aria-expanded", String(open));
          });
          mobile.querySelectorAll("a").forEach((a) => {
            a.addEventListener("click", () => {
              mobile.classList.remove("open");
              burger.setAttribute("aria-expanded", "false");
            });
          });
        }
      }

      setup();
      document.addEventListener("astro:page-load", setup);
    </script>
  </body>
</html>
