---
interface Props {
  wordmark?: boolean;
  size?: number;
}

const { wordmark = true, size = 32 } = Astro.props;
---

<a
  href="/"
  aria-label="letmepost.dev"
  class="inline-flex items-center gap-[0.3rem] no-underline text-text hover:text-text leading-none"
>
  <span
    class="inline-flex items-center justify-center text-accent shrink-0"
    style={`width: ${size}px; height: ${size}px;`}
  >
    <svg
      width={size}
      height={size}
      viewBox="0 0 32 32"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="16" cy="16" r="15" fill="currentColor"></circle>
      <rect
        x="9.5"
        y="9.5"
        width="13"
        height="13"
        fill="var(--color-bg)"
        transform="rotate(16 16 16)"
      ></rect>
    </svg>
  </span>

  {
    wordmark && (
      <span class="inline-flex items-baseline">
        <span class="font-serif italic font-normal text-[1.6rem] max-[480px]:text-[1.35rem] tracking-[-0.01em] leading-none text-text">
          letmepost
        </span>
        <span class="font-serif italic font-normal text-[1.6rem] max-[480px]:text-[1.35rem] tracking-[-0.01em] leading-none text-accent">
          .dev
        </span>
        <span class="ml-[0.4rem] font-mono text-[0.54rem] font-semibold text-text-muted tracking-[0.04em] opacity-60 uppercase self-end pb-[0.15rem]">
          [alpha]
        </span>
      </span>
    )
  }
</a>
