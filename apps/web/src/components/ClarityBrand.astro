---
/**
 * Brand lockup for the Clarity chrome: the letmepost mark (circle with a
 * rotated-square cutout — same geometry as Logo.astro / mark.png) next to
 * the wordmark, rendered in Clarity tokens so it tracks light/dark. Used
 * by ClarityHeader + ClarityFooter in place of the old placeholder dot.
 */
interface Props {
  size?: number;
}
const { size = 22 } = Astro.props;
---

<a href="/" class="cl-brand" aria-label="letmepost.dev">
  <svg
    width={size}
    height={size}
    viewBox="0 0 32 32"
    xmlns="http://www.w3.org/2000/svg"
    class="cl-mark"
    aria-hidden="true"
  >
    <circle cx="16" cy="16" r="15" fill="var(--acc)"></circle>
    <rect
      x="9.5"
      y="9.5"
      width="13"
      height="13"
      fill="var(--bg)"
      transform="rotate(16 16 16)"
    ></rect>
  </svg>
  letmepost
</a>
