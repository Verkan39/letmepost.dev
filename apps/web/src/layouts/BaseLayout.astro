---
import "@fontsource/commit-mono/400.css";
import "@fontsource/commit-mono/600.css";
import "@fontsource/commit-mono/700.css";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";

/**
 * `jsonLd` lets a page contribute additional structured-data graphs on
 * top of the default Organization + WebSite ones we always emit.
 * Common shapes:
 *
 *   - FAQPage         — for the home FAQ section
 *   - BreadcrumbList  — for /platforms/[slug] and /api/[slug]
 *   - SoftwareApplication / Product — for per-platform marketing pages
 *
 * Each entry renders as its own <script type="application/ld+json">
 * tag — Google parses each block independently.
 */
interface JsonLdGraph {
  "@context"?: string;
  "@type": string;
  [key: string]: unknown;
}

interface Props {
  title: string;
  description?: string;
  /** Override the OG image (absolute path or full URL). Defaults to /og-image.png (generated at build time from og-image.svg). */
  ogImage?: string;
  noindex?: boolean;
  /** Additional JSON-LD graphs to emit alongside the default Organization + WebSite. */
  jsonLd?: JsonLdGraph[];
  /** og:type — defaults to website. Override per page when applicable. */
  ogType?: "website" | "article" | "product";
}

const {
  title,
  description = "Open-source social media publishing API for developers and AI agents. Preflight validation, transparent errors, stable versions, idempotency by default.",
  ogImage = "/og-image.png",
  noindex = false,
  jsonLd = [],
  ogType = "website",
} = Astro.props;

const siteName = "letmepost.dev";
// Match the dashboard's title template: `<page> · letmepost.dev`. The
// dashboard uses Next.js metadata's `template: "%s · letmepost.dev"`;
// this is the Astro mirror of the same convention so a user moving
// between marketing tabs and dashboard tabs sees identical formatting.
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const siteUrl = Astro.site!.toString().replace(/\/$/, "");

/**
 * Default structured-data graphs every page emits. `Organization`
 * establishes the brand entity (logo, sameAs links to social profiles)
 * so Google can render a knowledge panel. `WebSite` enables the
 * sitelinks-search-box on Google SERPs once docs is indexed.
 *
 * Both graphs use stable `@id` URIs so additional graphs on per-page
 * `jsonLd` reference the SAME entity instead of fragmenting it across
 * the index.
 */
const defaultGraphs: JsonLdGraph[] = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    name: siteName,
    url: siteUrl,
    logo: `${siteUrl}/og-image.png`,
    description:
      "Open-source social media publishing API for developers and AI agents.",
    sameAs: [
      "https://github.com/rosekamallove/letmepost.dev",
      "https://x.com/letmepostdotdev",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    name: siteName,
    url: siteUrl,
    publisher: { "@id": `${siteUrl}/#organization` },
  },
];

const allGraphs: JsonLdGraph[] = [...defaultGraphs, ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#F2EDE3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171411" media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content="#F2EDE3" />

    <!-- Pre-paint theme bootstrap — runs synchronously before <body> renders
         to avoid a flash of the wrong theme. Reads stored preference (or
         falls back to system) and sets data-theme on <html>.
         `data-astro-rerun` re-executes this on every ClientRouter view
         transition. Without it, soft navigations between pages drop the
         `data-theme` attribute mid-swap and the light-mode defaults flash
         in until the next interaction. -->
    <script is:inline data-astro-rerun>
      (function () {
        try {
          var pref = localStorage.getItem("lmp-theme") || "system";
          var resolved =
            pref === "system"
              ? window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light"
              : pref;
          document.documentElement.setAttribute("data-theme", resolved);
          document.documentElement.dataset.themePref = pref;
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Favicons + platform icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="letmepost.dev — Blog"
      href="/rss.xml"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="letmepost.dev — social media publishing that fails loudly."
    />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@letmepostdotdev" />
    <meta name="twitter:creator" content="@letmepostdotdev" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta
      name="twitter:image:alt"
      content="letmepost.dev — social media publishing that fails loudly."
    />

    {/*
      JSON-LD structured data. Default graphs (Organization + WebSite)
      are always emitted; per-page graphs (FAQPage on home,
      BreadcrumbList on platform pages, etc.) layer on via the `jsonLd`
      prop. Each block is its own <script> so Google parses them
      independently — broken JSON in one doesn't taint the rest.
    */}
    {allGraphs.map((graph) => (
      <script type="application/ld+json" set:html={JSON.stringify(graph)} />
    ))}

    <ClientRouter />
    <Analytics />
  </head>
  <body>
    <Header />
    <main transition:animate="fade"><slot /></main>
    <Footer />
  </body>
</html>
