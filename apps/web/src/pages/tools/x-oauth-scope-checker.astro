---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";

// Action -> minimum scope set for X (Twitter) v2 OAuth 2.0.
// Notes on the rules baked in:
//  - users.read is the universal sign-in claim — everything else stacks on
//    top of it.
//  - offline.access grants a refresh token; without it tokens die in 2h
//    and your app has to re-prompt the user.
//  - DM, follow, like, bookmark, block, mute scopes split read/write —
//    request only the half you need.
const actions = [
  {
    id: "signin",
    label: "Sign in / read user profile",
    scopes: ["users.read", "tweet.read"],
    note: "Minimum X v2 sign-in set — both are required even for read-only.",
  },
  {
    id: "refresh",
    label: "Keep tokens alive (refresh tokens)",
    scopes: ["offline.access"],
    note: "Add this to any flow if you don't want to re-prompt every 2h.",
  },
  {
    id: "post",
    label: "Post tweets on user's behalf",
    scopes: ["tweet.read", "tweet.write", "users.read", "offline.access"],
  },
  {
    id: "media",
    label: "Upload media for tweets",
    scopes: ["media.write", "tweet.write", "tweet.read", "users.read", "offline.access"],
    note: "Required for image/video posts via v2 media upload.",
  },
  {
    id: "moderate",
    label: "Hide / unhide replies on user's tweets",
    scopes: ["tweet.moderate.write", "tweet.read", "users.read"],
  },
  {
    id: "follows",
    label: "Read who the user follows",
    scopes: ["follows.read", "users.read", "tweet.read"],
  },
  {
    id: "follow-write",
    label: "Follow / unfollow on user's behalf",
    scopes: ["follows.write", "follows.read", "users.read", "tweet.read"],
  },
  {
    id: "likes-read",
    label: "Read user's likes",
    scopes: ["like.read", "users.read", "tweet.read"],
  },
  {
    id: "likes-write",
    label: "Like / unlike on user's behalf",
    scopes: ["like.write", "like.read", "users.read", "tweet.read"],
  },
  {
    id: "bookmarks",
    label: "Read user's bookmarks",
    scopes: ["bookmark.read", "users.read", "tweet.read"],
  },
  {
    id: "bookmarks-write",
    label: "Bookmark / unbookmark",
    scopes: ["bookmark.write", "bookmark.read", "users.read", "tweet.read"],
  },
  {
    id: "lists",
    label: "Read lists",
    scopes: ["list.read", "users.read", "tweet.read"],
  },
  {
    id: "lists-write",
    label: "Create / edit lists",
    scopes: ["list.write", "list.read", "users.read", "tweet.read"],
  },
  {
    id: "blocks",
    label: "Manage blocks",
    scopes: ["block.write", "block.read", "users.read", "tweet.read"],
  },
  {
    id: "mutes",
    label: "Manage mutes",
    scopes: ["mute.write", "mute.read", "users.read", "tweet.read"],
  },
  {
    id: "spaces",
    label: "Read Spaces metadata",
    scopes: ["space.read", "users.read", "tweet.read"],
  },
  {
    id: "dm-read",
    label: "Read DMs",
    scopes: ["dm.read", "users.read", "tweet.read", "offline.access"],
    note: "Restricted scope — your app must be approved by X before users can grant it.",
  },
  {
    id: "dm-write",
    label: "Send DMs",
    scopes: ["dm.write", "dm.read", "users.read", "tweet.read", "offline.access"],
    note: "Restricted scope — needs X review.",
  },
];

const allScopes = [
  { name: "tweet.read", purpose: "Read tweets, including the user's own." },
  { name: "tweet.write", purpose: "Post and delete tweets on the user's behalf." },
  { name: "tweet.moderate.write", purpose: "Hide / unhide replies to the user's tweets." },
  { name: "users.read", purpose: "Read user profile (name, handle, id)." },
  { name: "follows.read", purpose: "Read who the user follows / who follows them." },
  { name: "follows.write", purpose: "Follow and unfollow on the user's behalf." },
  { name: "offline.access", purpose: "Get a refresh token. Required to keep access past 2 hours." },
  { name: "space.read", purpose: "Read Spaces metadata." },
  { name: "mute.read", purpose: "Read who the user mutes." },
  { name: "mute.write", purpose: "Mute / unmute on the user's behalf." },
  { name: "like.read", purpose: "Read tweets the user liked." },
  { name: "like.write", purpose: "Like / unlike tweets." },
  { name: "list.read", purpose: "Read lists the user is part of or owns." },
  { name: "list.write", purpose: "Create, update, delete lists." },
  { name: "block.read", purpose: "Read users the account blocks." },
  { name: "block.write", purpose: "Block / unblock on the user's behalf." },
  { name: "bookmark.read", purpose: "Read user's bookmarks." },
  { name: "bookmark.write", purpose: "Bookmark / unbookmark." },
  { name: "media.write", purpose: "Upload media for use in tweets." },
  { name: "dm.read", purpose: "Read direct messages. Restricted — needs app review." },
  { name: "dm.write", purpose: "Send direct messages. Restricted — needs app review." },
];

const exampleAuthorizeUrl = `https://twitter.com/i/oauth2/authorize
  ?response_type=code
  &client_id=YOUR_CLIENT_ID
  &redirect_uri=YOUR_REDIRECT
  &scope=tweet.read%20tweet.write%20users.read%20offline.access
  &state=RANDOM_STATE
  &code_challenge=YOUR_CODE_CHALLENGE
  &code_challenge_method=S256`;
---

<BaseLayout
  title="X (Twitter) OAuth scope checker"
  description="Free X / Twitter v2 OAuth 2.0 scope checker. Pick what your app needs — get the minimum scope string you can paste into the authorize URL."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "X (Twitter) OAuth scope checker",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Pick X / Twitter v2 OAuth 2.0 actions and see the minimum scope set required, with PKCE-aware authorize-URL example.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">X (Twitter) OAuth scope checker.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        Pick what your app needs. We compute the minimum scope set — the exact
        string you paste into the OAuth 2.0 authorize URL. Includes the
        2-hour-token quirk and the restricted-scope flags.
      </p>

      <div class="lmp-scope" data-scope>
        <ul class="list-none p-0 m-0">
          {
            actions.map((a) => (
              <li class="lmp-scope-row">
                <label class="lmp-scope-label">
                  <input
                    type="checkbox"
                    data-scope-action
                    data-scopes={JSON.stringify(a.scopes)}
                    aria-describedby={`note-${a.id}`}
                  />
                  <span class="lmp-scope-text">
                    <span class="font-bold text-[0.92rem]">{a.label}</span>
                    {a.note ? (
                      <span class="lmp-scope-note" id={`note-${a.id}`}>
                        {a.note}
                      </span>
                    ) : null}
                    <span class="lmp-scope-list">{a.scopes.join(" + ")}</span>
                  </span>
                </label>
              </li>
            ))
          }
        </ul>

        <div class="lmp-scope-output">
          <div class="lmp-scope-output-label">
            <span class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted"
              >Minimum scope param</span
            >
            <button
              type="button"
              class="lmp-counter-copy"
              data-scope-copy
              aria-label="Copy scope string">Copy</button
            >
          </div>
          <code class="lmp-scope-out" data-scope-out>—</code>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">In your authorize URL.</h2>
      <Code code={exampleAuthorizeUrl} lang="text" theme="github-dark" />
      <p class="text-text-muted mt-4 text-[0.88rem]">
        Scopes are space-separated and URL-encoded. X v2 requires PKCE — pair
        this checker with the
        <a class="text-accent" href="/tools/pkce-generator">PKCE generator</a> to
        get a working authorize URL.
      </p>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Every X v2 OAuth 2.0 scope.</h2>
      <ul class="list-none p-0 mt-4">
        {
          allScopes.map((s) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <code class="font-mono text-[0.9rem]">{s.name}</code>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{s.purpose}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Or skip the OAuth dance.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code>'s hosted OAuth handles X's PKCE +
        signed-state-survives-redirect quirk + 2-hour token refresh out of the
        box. Self-host runs the same code with your own X app.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="/platforms/twitter">
          X on letmepost.dev
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/pkce-generator">PKCE generator</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-scope {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-scope-row {
    border-bottom: 1px dashed var(--color-border);
    padding: 0.55rem 0;
  }
  .lmp-scope-row:last-of-type {
    border-bottom: none;
  }
  .lmp-scope-label {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    cursor: pointer;
    align-items: start;
  }
  .lmp-scope-label input {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
  }
  .lmp-scope-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .lmp-scope-note {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .lmp-scope-list {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    padding: 0.15rem 0.4rem;
    align-self: start;
  }
  .lmp-scope-output {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .lmp-scope-output-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .lmp-scope-out {
    display: block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.85rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    word-break: break-all;
    user-select: all;
  }
  .lmp-counter-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }
  .lmp-counter-copy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

<script>
  function setupScope(root: HTMLElement) {
    const checkboxes = Array.from(
      root.querySelectorAll<HTMLInputElement>("[data-scope-action]"),
    );
    const out = root.querySelector<HTMLElement>("[data-scope-out]");
    const copy = root.querySelector<HTMLButtonElement>("[data-scope-copy]");

    function recompute() {
      const set = new Set<string>();
      for (const cb of checkboxes) {
        if (!cb.checked) continue;
        try {
          const list: string[] = JSON.parse(cb.dataset.scopes || "[]");
          for (const s of list) set.add(s);
        } catch {
          /* malformed — skip */
        }
      }
      const scopes = Array.from(set);
      if (out) out.textContent = scopes.length === 0 ? "—" : scopes.join(" ");
    }

    checkboxes.forEach((cb) => cb.addEventListener("change", recompute));
    copy?.addEventListener("click", async () => {
      const text = out?.textContent || "";
      if (!text || text === "—") return;
      try {
        await navigator.clipboard.writeText(text);
        copy.textContent = "Copied";
        setTimeout(() => (copy.textContent = "Copy"), 1100);
      } catch {
        /* clipboard blocked */
      }
    });

    recompute();
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>("[data-scope]").forEach(setupScope);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
