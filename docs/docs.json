          "webhooks/post-queued",
          "webhooks/post-validated",
          "webhooks/post-published",
          "webhooks/post-rejected",
          "webhooks/post-failed",
          "webhooks/post-canceled",
          "webhooks/post-rescheduled",
          "webhooks/token-expiring",
          "webhooks/token-revoked",
          "webhooks/version-deprecated"
