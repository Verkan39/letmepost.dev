---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const principles = [
  {
    icon: "ph:check-circle",
    title: "Free during alpha",
    body: "Every API surface, every platform, every webhook. No card required. No per-profile tax.",
  },
  {
    icon: "ph:check-circle",
    title: "Flat-rate when billing turns on",
    body: "One number for the whole org. No per-channel multiplier, no per-seat ladder, no per-profile tax. The pricing is the flat number on the page.",
  },
  {
    icon: "ph:check-circle",
    title: "A real free tier — not a trial",
    body: "Persistent, indefinite. Sized big enough that an indie dev or a hobby project never has to upgrade. Bigger orgs hit a paid tier; their pricing pays for the free tier.",
  },
  {
    icon: "ph:check-circle",
    title: "Self-host stays free forever",
    body: "Apache 2.0 OSS, Docker Compose, BYO Postgres + Redis. Same code as the hosted SaaS, no feature-gate, no open-core trick.",
  },
];

const faqs = [
  {
    q: "Why hasn't pricing landed yet?",
    a: "We're in alpha. Pricing locks the moment the publisher surface is stable across all v1 platforms and the launch window is set. Until then, every customer-shaped data point is signal we want to read before naming the number.",
  },
  {
    q: "What about per-post or per-platform pricing?",
    a: "Not happening. Per-profile and per-platform pricing are the universally hated patterns we're explicitly building around — a single flat tier with sane quotas is the entire commercial wedge.",
  },
  {
    q: "Will the alpha pricing apply to existing accounts?",
    a: "Yes. Anyone who connected during alpha gets a defined grace window when paid tiers launch — at minimum 60 days, locked at announcement. We won't surprise-bill.",
  },
  {
    q: "How does self-host work?",
    a: "Apache-2.0 from day one. `docker compose up` against your own Postgres + Redis. BYO platform credentials. Same API responses, same behavior as hosted. No license servers, no telemetry checks, no feature flags off.",
  },
  {
    q: "What's a fair tier shape?",
    a: "TBD — but the constraint is: every flat tier has to be honest about quotas and rate limits up front. No 'unlimited*' with a footnote. We'd rather list the cap and let you decide than hide it.",
  },
];
---

<BaseLayout
  title="Pricing"
  description="Pricing for letmepost.dev — flat-rate when it lands, free during alpha, self-host always free."
>
  <!-- Hero -->
  <section class="pt-22 pb-12 max-[640px]:pt-14 max-[640px]:pb-8">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-7 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"
        ></span>
        Pricing · TBD
      </div>

      <h1 class="!m-0">
        Free during alpha. <br class="max-[640px]:hidden" />
        <span class="text-accent">Flat-rate when it lands.</span>
      </h1>

      <p
        class="text-[1.2rem] leading-[1.65] mt-7 mb-10 text-text-secondary"
      >
        We're locking pricing the moment the publisher surface stabilizes across all v1 platforms. Until then, every API, every platform, every webhook is free — and self-host stays free forever.
      </p>

      <div class="flex gap-[0.6rem] flex-wrap">
        <a
          class="btn btn-primary"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props='{"location":"hero","target":"dashboard","page":"pricing","label":"Start building free"}'
        >
          Start building free
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a
          class="btn btn-secondary"
          href="/contact"
          data-analytics-event="cta.clicked"
          data-analytics-props='{"location":"hero-secondary","target":"contact","page":"pricing","label":"Email us when pricing lands"}'
        >Email us when pricing lands</a>
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="pt-8 pb-12 max-[640px]:pt-6">
    <div class="container">
      <h2 class="!mt-0">What we're committing to.</h2>
      <p class="text-text-muted">
        These principles are the contract. Tiers and dollar amounts ship later; the shape doesn't change.
      </p>

      <ul class="list-none p-0 mt-6 mb-4">
        {principles.map((p) => (
          <li class="flex gap-[1.1rem] py-5">
            <Icon name={p.icon} width={20} height={20} class="text-accent shrink-0 mt-[0.15rem]" />
            <div>
              <h3 class="!m-0 !mb-[0.35rem] !text-base !font-bold">{p.title}</h3>
              <p class="text-text-muted m-0 text-[0.92rem]">{p.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Tier preview -->
  <section class="pt-8 pb-12">
    <div class="container">
      <h2 class="!mt-0">Tier shape (work in progress).</h2>
      <p class="text-text-muted">
        Not final. Numbers will be public the moment they're locked.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
        <div class="border border-border p-5">
          <div class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted mb-2">Free</div>
          <div class="text-2xl font-extrabold mb-1">$0</div>
          <p class="text-text-muted m-0 text-[0.86rem] mb-3">Indefinite, not a trial.</p>
          <ul class="list-none p-0 m-0 text-[0.86rem] text-text-secondary">
            <li class="py-1">Every platform</li>
            <li class="py-1">Every API surface</li>
            <li class="py-1">Webhooks + idempotency</li>
            <li class="py-1">Sized for indie dev / hobby</li>
          </ul>
        </div>

        <div class="border border-border-strong p-5" style="background: var(--color-accent-soft);">
          <div class="text-[0.72rem] uppercase tracking-[0.1em] text-accent mb-2">Pro</div>
          <div class="text-2xl font-extrabold mb-1">TBD</div>
          <p class="text-text-muted m-0 text-[0.86rem] mb-3">One flat number per org.</p>
          <ul class="list-none p-0 m-0 text-[0.86rem] text-text-secondary">
            <li class="py-1">No per-profile tax</li>
            <li class="py-1">No per-seat ladder</li>
            <li class="py-1">No per-platform multiplier</li>
            <li class="py-1">Honest quotas, no asterisks</li>
          </ul>
        </div>

        <div class="border border-border p-5">
          <div class="text-[0.72rem] uppercase tracking-[0.1em] text-text-muted mb-2">Self-host</div>
          <div class="text-2xl font-extrabold mb-1">$0</div>
          <p class="text-text-muted m-0 text-[0.86rem] mb-3">Apache 2.0, forever.</p>
          <ul class="list-none p-0 m-0 text-[0.86rem] text-text-secondary">
            <li class="py-1">Same code as hosted</li>
            <li class="py-1">BYO Postgres + Redis</li>
            <li class="py-1">BYO platform credentials</li>
            <li class="py-1">No telemetry checks</li>
          </ul>
        </div>
      </div>

      <p class="text-[0.78rem] mt-4 text-text-muted">
        The Pro number isn't trying to be cute — it'll be public when locked.
        Watch the <a class="text-accent" href="/changelog">changelog</a> or
        <a class="text-accent" href="/contact">drop us a line</a> to be told the moment it ships.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="pt-8 pb-12">
    <div class="container">
      <h2 class="!mt-0">FAQs.</h2>

      <dl class="m-0 mt-6 mb-4 p-0">
        {faqs.map((f) => (
          <div class="py-[1.15rem]">
            <dt class="flex gap-[0.6rem] font-bold text-text m-0 mb-2 text-[0.95rem] before:content-['Q'] before:text-accent before:font-extrabold">
              {f.q}
            </dt>
            <dd class="flex gap-[0.6rem] text-text-muted m-0 text-[0.9rem] before:content-['A'] before:text-accent before:font-extrabold">
              <span>{f.a}</span>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="pt-8 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Build now. Pay later, maybe.</h2>
      <p class="text-text-muted">
        Alpha access is free, complete, and not a trial. The pricing page will fill in over time — meanwhile, you're not gated on anything.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap">
        <a
          class="btn btn-primary"
          href="https://dashboard.letmepost.dev"
          data-analytics-event="cta.clicked"
          data-analytics-props='{"location":"pricing-final","target":"dashboard","page":"pricing","label":"Start building free"}'
        >
          Start building free
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a
          class="btn btn-secondary"
          href="https://github.com/rosekamallove/letmepost.dev"
          target="_blank"
          rel="noopener"
          data-analytics-event="external.github_clicked"
          data-analytics-props='{"from_page":"pricing","location":"pricing-final"}'
        >
          Self-host on GitHub
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
