---
import { Icon } from "astro-icon/components";
import { PLATFORMS, APIS } from "../data/platforms.ts";

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

function isCurrent(href: string): boolean {
  const norm = (s: string) => s.replace(/\/$/, "") || "/";
  return norm(currentPath) === norm(href);
}

const platformCount = PLATFORMS.length;
const apiCount = APIS.length;

const primaryLinks = [
  { href: "/", label: "Home" },
  { href: "https://docs.letmepost.dev", label: "Docs" },
  { href: "/pricing", label: "Pricing" },
  { href: "/platforms", label: "Platforms", meta: String(platformCount) },
  { href: "/api", label: "APIs", meta: String(apiCount) },
  { href: "/blog", label: "Blog" },
  { href: "/agents", label: "For agents" },
  { href: "https://docs.letmepost.dev/changelog", label: "Changelog" },
];
---

<div
  class="mobile-sheet"
  id="mobile-sheet"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
>
  <div class="sheet-hd">
    <a href="/" class="brand">
      <span class="r-stamp" aria-hidden="true"></span>
      LETMEPOST
    </a>
    <button type="button" class="close-btn" id="close-sheet" aria-label="Close menu">✕</button>
  </div>

  <div class="sheet-section">Navigate</div>
  <ul class="links">
    {
      primaryLinks.map((l) => (
        <li class={isCurrent(l.href) ? "current" : ""}>
          <a href={l.href}>{l.label}</a>
          {l.meta && <span class="meta">{l.meta}</span>}
        </li>
      ))
    }
  </ul>

  <div class="sheet-section">By platform</div>
  <ul class="links">
    {
      PLATFORMS.map((p) => (
        <li class={isCurrent(`/platforms/${p.slug}`) ? "current" : ""}>
          <a href={`/platforms/${p.slug}`}>{p.name}</a>
        </li>
      ))
    }
  </ul>

  <div class="sheet-section">By surface</div>
  <ul class="links">
    {
      APIS.map((api) => (
        <li class={isCurrent(`/api/${api.slug}`) ? "current" : ""}>
          <a href={`/api/${api.slug}`}>{api.name}</a>
        </li>
      ))
    }
  </ul>

  <div class="sheet-section">Quick links</div>
  <ul class="links">
    <li><a href="https://dashboard.letmepost.dev">Dashboard ↗</a></li>
    <li><a href="https://docs.letmepost.dev/quickstart">Quickstart</a></li>
    <li><a href="https://docs.letmepost.dev/self-host">Self-host</a></li>
    <li><a href="https://status.letmepost.dev">Status</a></li>
  </ul>

  <div class="sheet-section">Live</div>
  <div class="status-card">
    <div class="row">
      <span class="k"><span class="pulse" aria-hidden="true"></span> Build</span>
      <span class="v ok">v0.4.2</span>
    </div>
    <div class="row"><span class="k">API</span><span class="v ok">200 OK · 41ms</span></div>
    <div class="row"><span class="k">Posts/24h</span><span class="v">12,418</span></div>
    <div class="row"><span class="k">Preflight</span><span class="v">80 rules</span></div>
    <div class="row"><span class="k">Licence</span><span class="v">Apache-2.0</span></div>
  </div>

  <div class="colophon">
    Built by <b>Rose Kamal Love.</b><br />
    4 weeks old, alpha. India.<br />
    <a href="mailto:rose@letmepost.dev" style="color: var(--r-dim);">rose@letmepost.dev</a>
  </div>

  <button class="theme-btn" id="sheet-theme-btn" type="button" aria-label="Toggle theme">
    <Icon name="ph:sun" width={12} height={12} />
    Toggle theme
  </button>
</div>
