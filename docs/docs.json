{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "letmepost.dev",
  "description": "Open-source social media publishing API. Preflight validation, transparent errors, idempotency, stable platform versions.",
  "colors": {
    "primary": "#2D7652",
    "light": "#53C68C",
    "dark": "#185838"
  },
  "favicon": "/favicon.ico",
  "styling": {
    "codeblocks": "system"
  },
  "appearance": {
    "default": "system"
  },
  "css": "/style.css",
  "logo": {
    "light": "https://letmepost.dev/logo.png",
    "dark": "https://letmepost.dev/logo-dark.png",
    "href": "https://letmepost.dev"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "letmepost.dev",
      "og:image": "https://letmepost.dev/og-image.png",
      "og:type": "website",
      "twitter:card": "summary_large_image",
      "twitter:site": "@letmepostdotdev",
      "twitter:creator": "@letmepostdotdev",
      "twitter:image": "https://letmepost.dev/og-image.png"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Quickstart",
        "icon": "rocket",
        "groups": [
          {
            "group": "Get started",
            "pages": ["quickstart", "authentication", "idempotency", "errors/index", "preflight/index"]
          },
          {
            "group": "Agents",
            "pages": ["agents/mcp", "agents/cli"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/connect-account",
              "guides/publish-post",
              "guides/schedule-post",
              "guides/upload-media"
            ]
          },
          {
            "group": "Self-host",
            "pages": [
              "self-host/quick-start",
              "self-host/environment",
              "self-host/platform-credentials",
              "self-host/deploying",
              "self-host/troubleshooting"
            ]
          },
          {
            "group": "Migrate from",
            "pages": [
              "guides/migrate-from-postiz",
              "guides/migrate-from-ayrshare",
              "guides/migrate-from-buffer"
            ]
          },
          {
            "group": "Reference",
            "pages": ["pricing", "changelog"]
          }
        ]
      },
      {
        "tab": "Platforms",
        "icon": "layer-group",
        "pages": [
          "platforms-overview",
          "platforms/twitter",
          "platforms/instagram",
          "platforms/linkedin",
          "platforms/facebook",
          "platforms/threads",
          "platforms/pinterest",
