---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import { Icon } from "astro-icon/components";

const exampleUrl = `https://twitter.com/i/oauth2/authorize
  ?response_type=code
  &client_id=YOUR_CLIENT_ID
  &redirect_uri=YOUR_REDIRECT
  &scope=tweet.read%20tweet.write%20users.read%20offline.access
  &state=RANDOM_STATE
  &code_challenge=YOUR_CODE_CHALLENGE
  &code_challenge_method=S256`;

const exchangeSnippet = `// Token exchange — send the verifier the same flow generated.
const res = await fetch("https://api.twitter.com/2/oauth2/token", {
  method: "POST",
  headers: { "Content-Type": "application/x-www-form-urlencoded" },
  body: new URLSearchParams({
    grant_type: "authorization_code",
    code,
    redirect_uri: REDIRECT_URI,
    client_id: CLIENT_ID,
    code_verifier: VERIFIER, // <- the long string from this tool
  }),
});`;
---

<BaseLayout
  title="PKCE generator (code_verifier + code_challenge)"
  description="Free PKCE code_verifier + code_challenge (S256) generator. RFC 7636 compliant, generated entirely in your browser via Web Crypto. Required for X / Twitter OAuth 2.0 and most modern OAuth flows."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "PKCE generator",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Generate RFC 7636 PKCE code_verifier and S256 code_challenge in the browser. For X / Twitter OAuth 2.0, Google, Microsoft, and any OAuth flow requiring PKCE.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">PKCE generator.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        <code>code_verifier</code> + <code>code_challenge</code> using SHA-256 (S256), RFC 7636
        compliant. Required for X / Twitter OAuth 2.0 and the safer default
        for every modern OAuth flow. Generated entirely in your browser via
        Web Crypto — nothing leaves the page.
      </p>

      <div class="lmp-pkce" data-pkce>
        <div class="lmp-pkce-row">
          <div class="lmp-pkce-row-head">
            <span class="lmp-pkce-name">code_verifier</span>
            <button
              type="button"
              class="lmp-counter-copy"
              data-pkce-copy="verifier">Copy</button
            >
          </div>
          <code class="lmp-pkce-out" data-pkce-verifier>—</code>
          <span class="lmp-pkce-meta">Random 43–128 char URL-safe string. Save this — you'll need it on the token-exchange step.</span>
        </div>

        <div class="lmp-pkce-row">
          <div class="lmp-pkce-row-head">
            <span class="lmp-pkce-name">code_challenge</span>
            <button
              type="button"
              class="lmp-counter-copy"
              data-pkce-copy="challenge">Copy</button
            >
          </div>
          <code class="lmp-pkce-out" data-pkce-challenge>—</code>
          <span class="lmp-pkce-meta">SHA-256 of the verifier, base64url-encoded. Send this on the authorize URL.</span>
        </div>

        <div class="lmp-pkce-row">
          <div class="lmp-pkce-row-head">
            <span class="lmp-pkce-name">code_challenge_method</span>
          </div>
          <code class="lmp-pkce-out">S256</code>
          <span class="lmp-pkce-meta">Always S256. Don't use <code>plain</code> — every modern provider rejects it.</span>
        </div>

        <div class="lmp-pkce-row">
          <div class="lmp-pkce-row-head">
            <span class="lmp-pkce-name">state (bonus)</span>
            <button
              type="button"
              class="lmp-counter-copy"
              data-pkce-copy="state">Copy</button
            >
          </div>
          <code class="lmp-pkce-out" data-pkce-state>—</code>
          <span class="lmp-pkce-meta">Optional, but you should always send one. CSRF defense — verify it's the same value on the callback.</span>
        </div>

        <div class="lmp-pkce-actions">
          <button type="button" class="btn btn-primary" data-pkce-regen>
            <Icon name="ph:arrows-clockwise" width={13} height={13} />
            Regenerate
          </button>
          <span class="lmp-pkce-note text-text-muted text-[0.78rem]">Each click rotates the verifier, challenge, and state.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">How to use it.</h2>
      <p class="text-text-muted">
        1. Paste the <code>code_challenge</code> into the authorize URL. 2. Store the
        <code>code_verifier</code> server-side (or in a signed cookie / encrypted state). 3.
        On callback, send the verifier on the token-exchange call.
      </p>
      <Code code={exampleUrl} lang="text" theme="github-dark" />
      <p class="text-text-muted mt-4 text-[0.88rem]">
        And on the token exchange:
      </p>
      <Code code={exchangeSnippet} lang="javascript" theme="github-dark" />
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">Why PKCE.</h2>
      <p class="text-text-muted">
        OAuth 2.0 authorization-code flow assumes the client can keep a
        secret. SPAs, mobile apps, and CLI tools can't — so PKCE replaces the
        client-secret check with a one-time challenge bound to a per-request
        verifier. X / Twitter OAuth 2.0 requires it. Google, Microsoft, and
        most providers either require or recommend it.
      </p>
      <p class="text-text-muted">
        <code>letmepost.dev</code>'s hosted OAuth handles all of this — verifier
        generation, signed-state survival across redirects, code exchange — so
        you don't have to. Self-host runs the same code.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="https://docs.letmepost.dev/authentication">
          Auth docs
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/x-oauth-scope-checker"
          >X OAuth scope checker</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lmp-pkce {
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elev);
    padding: 1rem;
  }
  .lmp-pkce-row {
    padding: 0.7rem 0;
    border-bottom: 1px dashed var(--color-border);
  }
  .lmp-pkce-row:last-of-type {
    border-bottom: none;
  }
  .lmp-pkce-row-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .lmp-pkce-name {
    font-weight: 700;
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }
  .lmp-pkce-out {
    display: block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.65rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    word-break: break-all;
    user-select: all;
  }
  .lmp-pkce-meta {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.35rem;
  }
  .lmp-pkce-actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  /* shared with character counter / scope checker */
  .lmp-counter-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease;
  }
  .lmp-counter-copy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

<script>
  // Generate a cryptographically-random URL-safe string of `length` chars.
  // Drawing 1.5x bytes covers base64-padding loss; trim to exact length.
  function randomString(length: number): string {
    const bytes = new Uint8Array(Math.ceil(length * 1.5));
    crypto.getRandomValues(bytes);
    return base64url(bytes).slice(0, length);
  }

  function base64url(bytes: Uint8Array): string {
    let bin = "";
    for (const b of bytes) bin += String.fromCharCode(b);
    return btoa(bin)
      .replaceAll("+", "-")
      .replaceAll("/", "_")
      .replace(/=+$/, "");
  }

  async function sha256(input: string): Promise<Uint8Array> {
    const data = new TextEncoder().encode(input);
    const hash = await crypto.subtle.digest("SHA-256", data);
    return new Uint8Array(hash);
  }

  async function generate(): Promise<{
    verifier: string;
    challenge: string;
    state: string;
  }> {
    // 64 chars sits comfortably inside the RFC 7636 [43, 128] range.
    const verifier = randomString(64);
    const hash = await sha256(verifier);
    const challenge = base64url(hash);
    const state = randomString(32);
    return { verifier, challenge, state };
  }

  function setupPkce(root: HTMLElement) {
    const v = root.querySelector<HTMLElement>("[data-pkce-verifier]");
    const c = root.querySelector<HTMLElement>("[data-pkce-challenge]");
    const s = root.querySelector<HTMLElement>("[data-pkce-state]");
    const regen = root.querySelector<HTMLButtonElement>("[data-pkce-regen]");
    const copyBtns = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-pkce-copy]"),
    );

    let current = { verifier: "", challenge: "", state: "" };

    async function refresh() {
      current = await generate();
      if (v) v.textContent = current.verifier;
      if (c) c.textContent = current.challenge;
      if (s) s.textContent = current.state;
    }

    regen?.addEventListener("click", refresh);
    copyBtns.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const which = btn.dataset.pkceCopy as "verifier" | "challenge" | "state";
        const text = current[which];
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
          const original = btn.textContent;
          btn.textContent = "Copied";
          setTimeout(() => (btn.textContent = original), 1100);
        } catch {
          /* clipboard blocked */
        }
      });
    });

    refresh();
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>("[data-pkce]").forEach(setupPkce);
  }

  bootAll();
  document.addEventListener("astro:after-swap", bootAll);
</script>
