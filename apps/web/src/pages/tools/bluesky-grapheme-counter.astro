---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CharacterCounter from "../../components/CharacterCounter.astro";
import { Icon } from "astro-icon/components";

const platforms = [
  {
    slug: "bluesky",
    name: "Bluesky post",
    limit: 300,
    byteLimit: 3000,
    mode: "graphemes" as const,
    hint: "graphemes AND UTF-8 bytes",
  },
];

const rules = [
  {
    label: "Grapheme limit",
    value: "300",
    note: "AT Protocol counts user-perceived characters. Multi-codepoint emoji count as one.",
  },
  {
    label: "UTF-8 byte limit",
    value: "3,000 bytes",
    note: "A separate hard cap. Latin text is 1 byte/char; CJK is 3; most emoji are 4 — heavy-emoji posts can hit the byte cap before the grapheme cap.",
  },
  {
    label: "Reply, mention, hashtag",
    value: "Counted as displayed",
    note: "Bluesky's facet system (@handles, #tags, links) counts literal characters, not just the resolved DID.",
  },
  {
    label: "Image alt text",
    value: "1,000 graphemes",
    note: "Per image, separate from the post text.",
  },
];
---

<BaseLayout
  title="Bluesky character / grapheme counter"
  description="Free Bluesky post counter — 300 graphemes AND 3,000 UTF-8 bytes, the exact rule the AT Protocol enforces. Includes alt-text limit."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Bluesky grapheme counter",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description:
        "Free Bluesky post counter — 300 graphemes plus a 3,000 UTF-8 byte cap, the AT Protocol's actual rule.",
    },
  ]}
>
  <section class="pt-22 pb-10 max-[640px]:pt-14 max-[640px]:pb-6">
    <div class="container">
      <div
        class="inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.1em] mb-5 py-[0.3rem] px-[0.6rem] border border-border-strong"
      >
        <span
          class="w-[7px] h-[7px] inline-block bg-accent"
          aria-hidden="true"></span>
        Tool · Free
      </div>
      <h1 class="!m-0">Bluesky grapheme counter.</h1>
      <p
        class="text-[1.05rem] leading-[1.6] max-w-[42rem] mt-4 mb-8 text-text-secondary"
      >
        Bluesky's AT Protocol enforces both a 300-grapheme cap and a 3,000-byte
        UTF-8 cap — whichever fills first. This counter shows both in real
        time, so heavy-emoji posts don't surprise you at <code>com.atproto.repo.createRecord</code>.
      </p>
      <CharacterCounter
        platforms={platforms}
        placeholder="Type a skeet…"
      />
    </div>
  </section>

  <section class="pt-6 pb-10">
    <div class="container">
      <h2 class="!mt-0">The AT Protocol rule.</h2>
      <ul class="list-none p-0 mt-4">
        {
          rules.map((r) => (
            <li class="border border-border p-4 mb-2">
              <div class="flex justify-between gap-3 flex-wrap items-baseline">
                <span class="font-bold text-[0.95rem]">{r.label}</span>
                <span class="text-accent font-mono text-[0.9rem]">
                  {r.value}
                </span>
              </div>
              <p class="text-text-muted m-0 mt-1 text-[0.85rem]">{r.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pt-6 pb-18 max-[640px]:pb-12">
    <div class="container">
      <h2 class="!mt-0">Bluesky is shipping today.</h2>
      <p class="text-text-muted">
        <code>letmepost.dev</code> ships with Bluesky live in v1. App-password
        connect, no OAuth review, this exact preflight rule, and a public webhook
        feed for every state change.
      </p>
      <div class="flex gap-[0.6rem] flex-wrap mt-6">
        <a class="btn btn-primary" href="/platforms/bluesky">
          Bluesky on letmepost.dev
          <Icon name="ph:arrow-up-right" width={13} height={13} />
        </a>
        <a class="btn btn-secondary" href="/tools/social-media-character-counter"
          >All platforms at once</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
