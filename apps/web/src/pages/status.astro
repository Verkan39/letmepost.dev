---
import BaseLayout from "../layouts/BaseLayout.astro";
import Tape from "../components/Tape.astro";
import Closeout from "../components/Closeout.astro";
---

<BaseLayout
  title="Status"
  description="letmepost.dev service status and recent incidents."
>
  <Tape />

  <header class="page-head" data-sticky-anchor>
    <div class="crumb"><a href="/">letmepost</a> / status</div>
    <h1 class="page-h1">Status.</h1>
  </header>

  <hr class="dash" />

  <div
    style="display: flex; gap: 12px; align-items: center; padding: 14px 18px; border-top: 2px solid var(--r-ink); border-bottom: 2px solid var(--r-ink); margin: 16px 0 28px;"
  >
    <span
      class="pulse"
      style="width: 10px; height: 10px; flex-shrink: 0;"
      aria-hidden="true"></span>
    <div>
      <div style="font-weight: 700; color: var(--r-ink);">All systems operational</div>
      <div style="color: var(--r-dim); font-size: 12px; margin-top: 2px;">
        Pre-launch. This page will surface real uptime and incident history once the API is live.
      </div>
    </div>
  </div>

  <div class="prose">
    <h2>Monitored surfaces</h2>
    <ul>
      <li>API gateway (<code>api.letmepost.dev</code>)</li>
      <li>OAuth connect flows per platform</li>
      <li>Webhook delivery pipeline</li>
      <li>Background publishing workers</li>
      <li>Per-platform upstream health (Bluesky, LinkedIn, X, Meta, …)</li>
    </ul>

    <h2>Subscribing</h2>
    <p>
      Once the status endpoints are wired, you'll be able to subscribe via RSS, email, or a webhook.
      Until then,
      <a href="https://github.com/rosekamallove/letmepost.dev" rel="noopener" target="_blank">the GitHub repo</a>
      is the source of truth.
    </p>
  </div>

  <hr class="double" />

  <Closeout codeLine="000 LMP STATUS · 2026-05-23" />
  <Tape bottom />
</BaseLayout>
