# letmepost.dev — apps/web environment variables
# Copy to .env (git-ignored) and fill in real values.

# PostHog product analytics. Leave blank to disable — apps/web renders
# nothing when PUBLIC_POSTHOG_KEY is missing, so local dev stays quiet
# unless you explicitly want to send events.
#
# Region hosts:
#   US:  https://us.i.posthog.com   (default)
#   EU:  https://eu.i.posthog.com
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Notion-backed blog. The Astro content loader queries this database at
# build time and renders each row as a /blog/<slug> page. Outrank writes
# articles into the same DB so publishing = inserting a Notion row.
#
#   - NOTION_TOKEN: internal Notion integration token. Create at
#     https://www.notion.so/profile/integrations and share the DB with it.
#   - NOTION_BLOG_DATABASE_ID: the DB id (not a page id). For
#     "Outrank <> LMP" it's 36c951fba59980b48e84df4eabb7a476.
NOTION_TOKEN=
NOTION_BLOG_DATABASE_ID=36c951fba59980b48e84df4eabb7a476

# Vercel cron → deploy hook. Set on Vercel, not in local .env (local dev
# never triggers a redeploy).
#   - CRON_SECRET: Vercel auto-generates this when you enable Cron Jobs.
#   - BLOG_REBUILD_DEPLOY_HOOK_URL: create at
#     Project Settings → Git → Deploy Hooks. The cron POSTs here daily
#     at 02:30 UTC (08:00 IST) per apps/web/vercel.json.
CRON_SECRET=
BLOG_REBUILD_DEPLOY_HOOK_URL=
